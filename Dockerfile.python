FROM python:3.11-slim

WORKDIR /app

COPY oliva-api/app /app/app
COPY oliva-api/.env.example /app/.env
COPY oliva-api/pyproject.toml /app/

RUN pip install --no-cache-dir fastapi uvicorn[standard] pydantic pydantic-settings sqlalchemy aiosqlite aiohttp python-dotenv aiosmtplib

EXPOSE 3000

CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3000"]