FROM python:3.11-slim

WORKDIR /app

# Copy full API directory (includes app, .env, etc)
COPY oliva-api /app

# Install Python dependencies globally
RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    pydantic \
    pydantic-settings \
    sqlalchemy \
    aiosqlite \
    aiohttp \
    python-dotenv \
    aiosmtplib

# Expose port
EXPOSE 3000

# Run the API
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3000"]