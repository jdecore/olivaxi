---
import ThemeToggle from '../components/ThemeToggle.astro';
import { ClientRouter } from 'astro:transitions';
interface Props {
  title?: string;
}

const { title = "olivaξ" } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Monitoreo climático de olivares españoles - Protege tu olivar del cambio climático" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Literata:opsz,wght@7..72,400;7..72,500;7..72,600&family=Outfit:wght@400;500;600;700&family=Playfair+Display:wght@800&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <title>{title}</title>
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar-inner">
        <div class="nav-left">
          <a href="/" class="logo">
            <img src="/logo-32.png" alt="olivaξ" width="32" height="32" />
            <span>olivaξ</span>
          </a>
        </div>
        
        <div class="nav-center desktop-nav">
          <a href="/">Inicio</a>
          <a href="/consejero">Consejero</a>
          <a href="/variedades">Variedades</a>
          <a href="/agua-suelos">Agua y Suelos</a>
          <a href="/plagas">Plagas</a>
        </div>

        <div class="nav-right">
          <a href="/alertas" class="btn-primary">Activar alertas</a>
          <button class="btn-secondary"></button>
        </div>

        <button class="hamburger-btn" id="hamburger-btn" aria-label="Menú">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="nav-dropdown" id="nav-dropdown">
        <a href="/">Inicio</a>
        <a href="/consejero">Consejero</a>
        <a href="/variedades">Variedades</a>
        <a href="/agua-suelos">Agua y Suelos</a>
        <a href="/plagas">Plagas</a>
        <a href="/alertas">Activar alertas</a>
      </div>
    </nav>

    <div class="toggle-wrapper">
      <ThemeToggle />
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <p>Copyright© 2026 🫒 olivaξ — Diseñado y desarrollado por Juan Diego Enriquez — Hackathon CubePath 2026</p>
    </footer>

    <script>
      (function() {
        // Hamburger menu toggle
        const hamburgerBtn = document.getElementById('hamburger-btn');
        const dropdown = document.getElementById('nav-dropdown');
        
        hamburgerBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          hamburgerBtn.classList.toggle('active');
          dropdown.classList.toggle('active');
        });

        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target) && !hamburgerBtn?.contains(e.target)) {
            dropdown.classList.remove('active');
            hamburgerBtn?.classList.remove('active');
          }
        });

        window.addEventListener('modoOscuroChange', (e) => {
          document.documentElement.setAttribute('data-theme', e.detail.modoOscuro ? 'dark' : 'light');
        });
      })();

      document.addEventListener('astro:after-swap', () => {
        // Hamburger menu toggle (re-init after navigation)
        const hamburgerBtn = document.getElementById('hamburger-btn');
        const dropdown = document.getElementById('nav-dropdown');
        
        hamburgerBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          hamburgerBtn.classList.toggle('active');
          dropdown.classList.toggle('active');
        });

        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target) && !hamburgerBtn?.contains(e.target)) {
            dropdown.classList.remove('active');
            hamburgerBtn?.classList.remove('active');
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-aceituna: #1C1C1C;
    --color-sal: #F0ECE4;
    --color-bg: #F7F4EE;
    --color-limon: #D4E849;
    --color-muted: #4a4a40;
    --color-muted-bg: rgba(247, 244, 238, 0.85);
    --color-white: #FFFFFF;
    --color-border: #1C1C1C;
    --color-white-surface: #FFFFFF;
    --color-shadow: rgba(0, 0, 0, 0.1);
    --font-base: clamp(14px, 0.9rem + 0.5vw, 17px);
    --font-lg: clamp(18px, 1.2rem + 0.8vw, 28px);
    --font-xl: clamp(24px, 1.5rem + 1.2vw, 42px);
  }

  [data-theme="dark"] {
    --color-aceituna: #F7F4EE;
    --color-sal: #000000;
    --color-bg: #000000;
    --color-limon: #D4E849;
    --color-muted: #a0a095;
    --color-muted-bg: rgba(0, 0, 0, 0.85);
    --color-white: #1a1a1a;
    --color-border: #F7F4EE;
    --color-white-surface: #1a1a1a;
    --color-shadow: rgba(0, 0, 0, 0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: var(--font-base);
    background-color: var(--color-sal);
    color: var(--color-aceituna);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', system-ui, sans-serif;
    font-weight: 600;
    font-size: var(--font-lg);
  }

  h1 { font-size: var(--font-xl); }

  main {
    padding-top: 56px;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--color-white-surface);
    border-bottom: 1px solid var(--color-border);
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }

  .navbar:hover {
    opacity: 1;
  }

  .navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
  }

  .nav-left .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-white);
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    font-family: 'Outfit', system-ui, sans-serif;
    white-space: nowrap;
  }

  .nav-left .logo img {
    border-radius: 50%;
  }

  footer {
    background-color: var(--color-aceituna);
    color: var(--color-sal);
    text-align: center;
    padding: 1.5rem 0;
  }

  .card-neobrutal {
    border: 3px solid var(--color-border);
    border-radius: 0;
    box-shadow: 6px 6px 0 var(--color-border);
  }

  .btn-neobrutal {
    background: var(--color-limon);
    border: 3px solid var(--color-border);
    border-radius: 0;
    box-shadow: 4px 4px 0 var(--color-border);
    padding: 12px 24px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-neobrutal:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-border);
  }

  label {
    text-transform: uppercase;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  @media (max-width: 480px) {
    .card-neobrutal {
      box-shadow: 4px 4px 0 var(--color-border);
    }
    .btn-neobrutal {
      box-shadow: 3px 3px 0 var(--color-border);
    }
    .btn-neobrutal:hover {
      box-shadow: 4px 4px 0 var(--color-border);
    }
  }
</style>