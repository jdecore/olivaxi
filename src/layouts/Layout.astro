---
interface Props {
  title?: string;
}

const { title = "olivaξ" } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Monitoreo climático de olivares españoles - Protege tu olivar del cambio climático" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="preload" as="script" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Literata:opsz,wght@7..72,400;7..72,500;7..72,600&family=Outfit:wght@400;500;600;700&family=Playfair+Display:wght@800&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar-inner">
        <div class="nav-left">
          <a href="/" class="logo">
            <img src="/logo.svg" alt="olivaξ" class="logo-img" />
          </a>
        </div>
        
        <div class="nav-center desktop-nav">
          <a href="/">Inicio</a>
          <a href="/consejero">Consejero</a>
          <a href="/variedades">Variedades</a>
          <a href="/agua-suelos">Agua y Suelos</a>
          <a href="/plagas">Plagas</a>
        </div>

        <div class="nav-right">
          <button id="theme-toggle-btn" class="theme-toggle-btn" aria-label="Cambiar tema">☀️</button>
          <a href="/alertas" class="btn-alertas">Activar alertas</a>
        </div>

        <button class="hamburger-btn" id="hamburger-btn" aria-label="Menú">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="nav-dropdown" id="nav-dropdown">
        <a href="/">Inicio</a>
        <a href="/consejero">Consejero</a>
        <a href="/variedades">Variedades</a>
        <a href="/agua-suelos">Agua y Suelos</a>
        <a href="/plagas">Plagas</a>
        <a href="/alertas">Activar alertas</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>Copyright© 2026 🫒 olivaξ — Diseñado y desarrollado por Juan Diego Enriquez — Hackathon CubePath 2026</p>
    </footer>

    <script>
      (function() {
        // Hamburger menu toggle
        const hamburgerBtn = document.getElementById('hamburger-btn');
        const dropdown = document.getElementById('nav-dropdown');
        
        hamburgerBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          hamburgerBtn.classList.toggle('active');
          dropdown.classList.toggle('active');
        });

        // Theme toggle
        const themeBtn = document.getElementById('theme-toggle-btn');
        const html = document.documentElement;
        
        themeBtn?.addEventListener('click', () => {
          const current = html.getAttribute('data-theme') === 'dark';
          const next = !current;
          html.setAttribute('data-theme', next ? 'dark' : 'light');
          localStorage.setItem('theme', next ? 'dark' : 'light');
          themeBtn.textContent = next ? '🌙' : '☀️';
          window.dispatchEvent(new CustomEvent('modoOscuroChange', { detail: { modoOscuro: next } }));
        });

        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target) && !hamburgerBtn?.contains(e.target)) {
            dropdown.classList.remove('active');
            hamburgerBtn?.classList.remove('active');
          }
        });

        window.addEventListener('modoOscuroChange', (e) => {
          document.documentElement.setAttribute('data-theme', e.detail.modoOscuro ? 'dark' : 'light');
        });
      })();

      document.addEventListener('astro:after-swap', () => {
        // Hamburger menu toggle (re-init after navigation)
        const hamburgerBtn = document.getElementById('hamburger-btn');
        const dropdown = document.getElementById('nav-dropdown');
        const themeBtn = document.getElementById('theme-toggle-btn');
        const html = document.documentElement;
        
        hamburgerBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          hamburgerBtn.classList.toggle('active');
          dropdown.classList.toggle('active');
        });

        themeBtn?.addEventListener('click', () => {
          const current = html.getAttribute('data-theme') === 'dark';
          const next = !current;
          html.setAttribute('data-theme', next ? 'dark' : 'light');
          localStorage.setItem('theme', next ? 'dark' : 'light');
          themeBtn.textContent = next ? '🌙' : '☀️';
          window.dispatchEvent(new CustomEvent('modoOscuroChange', { detail: { modoOscuro: next } }));
        });

        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target) && !hamburgerBtn?.contains(e.target)) {
            dropdown.classList.remove('active');
            hamburgerBtn?.classList.remove('active');
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-aceituna: #1C1C1C;
    --color-sal: #F0ECE4;
    --color-bg: #F7F4EE;
    --color-limon: #D4E849;
    --color-muted: #4a4a40;
    --color-muted-bg: rgba(247, 244, 238, 0.85);
    --color-white: #FFFFFF;
    --color-border: #1C1C1C;
    --color-white-surface: #FFFFFF;
    --color-shadow: rgba(0, 0, 0, 0.1);
    --font-base: clamp(14px, 0.9rem + 0.5vw, 17px);
    --font-lg: clamp(18px, 1.2rem + 0.8vw, 28px);
    --font-xl: clamp(24px, 1.5rem + 1.2vw, 42px);
  }

  [data-theme="dark"] {
    --color-aceituna: #F7F4EE;
    --color-sal: #000000;
    --color-bg: #000000;
    --color-limon: #D4E849;
    --color-muted: #a0a095;
    --color-muted-bg: rgba(0, 0, 0, 0.85);
    --color-white: #1a1a1a;
    --color-border: #F7F4EE;
    --color-white-surface: #1a1a1a;
    --color-shadow: rgba(0, 0, 0, 0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: var(--font-base);
    background-color: var(--color-sal);
    color: var(--color-aceituna);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', system-ui, sans-serif;
    font-weight: 600;
    font-size: var(--font-lg);
  }

  h1 { font-size: var(--font-xl); }

  main {
    padding-top: 56px;
  }

  .navbar {
    position: fixed;
    top: 16px;
    left: 16px;
    right: 16px;
    z-index: 100;
    background-color: var(--color-white-surface);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    opacity: 1;
    contain: layout style;
    transform: translateZ(0);
    will-change: contents;
  }

  .navbar img {
    display: block;
    height: 60px;
    width: auto;
  }

  .navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
  }

  .nav-center.desktop-nav {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-center.desktop-nav a {
    color: var(--color-aceituna);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-center.desktop-nav a:hover {
    color: var(--color-limon);
  }

  @media (max-width: 900px) {
    .nav-center.desktop-nav {
      display: none;
    }
  }

  .nav-dropdown {
    display: none;
    flex-direction: column;
    padding: 16px 24px;
    background: var(--color-white-surface);
    border-top: 2px solid var(--color-border);
    border-radius: 0 0 14px 14px;
  }

  .nav-dropdown.active {
    display: flex;
  }

  .nav-dropdown a {
    color: var(--color-aceituna);
    text-decoration: none;
    font-weight: 500;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .nav-dropdown a:last-child {
    border-bottom: none;
  }

  @media (min-width: 901px) {
    .nav-dropdown {
      display: none !important;
    }
    .hamburger-btn {
      display: none;
    }
  }

  .hamburger-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .hamburger-btn span {
    width: 24px;
    height: 2px;
    background: var(--color-aceituna);
    transition: 0.3s;
  }

  .hamburger-btn.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger-btn.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-btn.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .nav-left .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-aceituna);
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    font-family: 'Outfit', system-ui, sans-serif;
    white-space: nowrap;
  }

  .nav-left .logo-img {
    height: 60px;
    width: auto;
    max-width: 120px;
  }

  .nav-left .logo .logo-icon {
    font-size: 1.4rem;
  }

  .nav-left .logo .logo-svg {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .nav-left .logo .logo-svg {
      width: 26px;
      height: 26px;
    }
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .theme-toggle-btn {
    background: var(--color-white-surface);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    width: 40px;
    height: 40px;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }

  .theme-toggle-btn:hover {
    transform: scale(1.05);
  }

  .btn-alertas {
    background: var(--color-limon);
    color: #000;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    border: 2px solid var(--color-border);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-alertas:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-shadow);
  }

  footer {
    background-color: var(--color-aceituna);
    color: var(--color-sal);
    text-align: center;
    padding: 1.5rem 0;
  }

  label {
    text-transform: uppercase;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  /* === SHARED UTILITY CLASSES === */

  /* Riesgo/Nivel badges */
  .riesgo-alto, .riesgo-item.alto, .estado-nivel.alto { background: rgba(239,68,68,0.15); color: #dc2626; }
  .riesgo-medio, .riesgo-item.medio, .estado-nivel.medio { background: rgba(245,158,11,0.15); color: #b45309; }
  .riesgo-bajo, .riesgo-item.bajo, .estado-nivel.bajo { background: rgba(34,197,94,0.15); color: #15803d; }

  /* Dot variants */
  .riesgo-dot.alto { background: #ef4444; }
  .riesgo-dot.medio { background: #f59e0b; }
  .riesgo-dot.bajo { background: #22c55e; }

  /* Shared info panels */
  .info-panel {
    padding: 12px;
    background: rgba(212,232,73,0.15);
    border-radius: 8px;
    font-size: 12px;
  }

  .info-panel .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }

  .info-panel .info-item {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 6px;
    background: rgba(255,255,255,0.5);
    border-radius: 4px;
    font-size: 11px;
  }

  .info-panel .info-section {
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .info-panel .info-section:last-child { border-bottom: none; margin-bottom: 0; }

  .info-panel .info-title {
    font-size: 10px;
    font-weight: 700;
    color: var(--color-aceituna);
    margin-bottom: 6px;
    letter-spacing: 0.05em;
  }

  /* Shared provincia selector */
  .provincia-selector {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .provincia-selector label {
    font-weight: 600;
    color: var(--color-muted);
    font-size: 13px;
  }

  .provincia-selector select, select.provincia-select {
    padding: 8px 16px;
    border: 2px solid var(--color-limon);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    background: var(--color-white-surface);
    color: var(--color-aceituna);
    cursor: pointer;
    font-family: inherit;
  }

  /* Shared card styles */
  .card-shadow {
    border: 3px solid var(--color-border);
    border-radius: 0;
    box-shadow: 4px 4px 0 var(--color-border);
  }

  .card-padding { padding: 20px; }

  .card-full {
    background: var(--color-white-surface);
    border: 3px solid var(--color-border);
    border-radius: 0;
    box-shadow: 4px 4px 0 var(--color-border);
    padding: 1.5rem;
  }

  /* Shared button styles */
  .btn-primary {
    background: var(--color-aceituna);
    color: var(--color-sal);
    padding: 10px 20px;
    border: 2px solid var(--color-border);
    border-radius: 6px;
    font-weight: 700;
    font-size: 12px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-muted);
    border: 2px solid var(--color-border);
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    padding: 8px 16px;
    font-size: 12px;
    transition: all 0.2s;
  }

  .btn-secondary:hover, .btn-secondary.active {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  /* Shared grid layouts */
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .grid-auto { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }

  /* Shared list styles */
  .list-clean {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }

  .list-clean li {
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 14px;
  }

  .list-clean li:last-child { border-bottom: none; }

  /* Shared tag/badge styles */
  .tag {
    display: inline-block;
    padding: 4px 10px;
    background: var(--color-limon);
    color: var(--color-aceituna);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
  }

  .badge {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .badge-alta { background: #FEF3C7; color: #92400E; }
  .badge-media { background: #DBEAFE; color: #1E40AF; }
  .badge-baja { background: #D1FAE5; color: #065F46; }

  /* Severity borders */
  .border-left-alto { border-left: 4px solid #ef4444; }
  .border-left-medio { border-left: 4px solid #f59e0b; }
  .border-left-bajo { border-left: 4px solid #22c55e; }

  /* Shared hero styles */
  .hero-dark {
    background: var(--color-aceituna);
    color: var(--color-sal);
    padding: 80px 1rem 3rem;
    text-align: center;
  }

  .hero-dark h1 {
    font-size: 1.75rem;
    font-weight: 700;
  }

  .hero-dark p {
    color: rgba(247,244,238,0.7);
    margin-top: 0.5rem;
  }

  /* Animation keyframes */
  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-in { animation: fadeSlideIn 0.5s ease forwards; }

  @media (max-width: 768px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
  }
</style>