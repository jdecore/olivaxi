---
const API_BASE = 'http://localhost:3000';
let provincia = Astro.props.provincia || null;
let datos = null;

if (provincia) {
  try {
    const res = await fetch(`${API_BASE}/api/analisis/${encodeURIComponent(provincia)}`);
    if (res.ok) {
      datos = await res.json();
    }
  } catch (e) {
    console.error('Error fetching analisis:', e);
  }
}

const getNivelColor = (nivel) => {
  const colores = {
    alta: { bg: 'rgba(34, 197, 94, 0.15)', border: '#22c55e', text: '#15803d' },
    media: { bg: 'rgba(245, 158, 11, 0.15)', border: '#f59e0b', text: '#b45309' },
    baja: { bg: 'rgba(239, 68, 68, 0.15)', border: '#ef4444', text: '#dc2626' },
    alto: { bg: 'rgba(239, 68, 68, 0.15)', border: '#ef4444', text: '#dc2626' },
    medio: { bg: 'rgba(245, 158, 11, 0.15)', border: '#f59e0b', text: '#b45309' },
    bajo: { bg: 'rgba(34, 197, 94, 0.15)', border: '#22c55e', text: '#15803d' },
  };
  return colores[nivel] || colores.bajo;
};

const getNivelLabel = (nivel) => {
  const labels = { alto: 'Alto', medio: 'Medio', bajo: 'Bajo' };
  return labels[nivel] || 'N/A';
};
---

{!provincia ? (
  <div class="analisis-panel">
    <p style={{ color: 'var(--color-muted)', textAlign: 'center', padding: '2rem' }}>
      Selecciona una provincia en el mapa o en el selector para ver el análisis.
    </p>
  </div>
) : datos ? (
  <div class="analisis-panel">
    <h3 style={{ fontFamily: 'Georgia, serif', fontSize: '16px', color: 'var(--color-aceituna)', marginBottom: '16px', display: 'flex', alignItems: 'center', gap: '8px' }}>
      📊 Análisis: {provincia}
    </h3>

    <div class="analisis-tarjetas">
      {datos.estres_hidrico && (
        <div class="analisis-tarjeta" style={{ borderLeftColor: getNivelColor(datos.estres_nivel).border }}>
          <div style={{ fontSize: '24px' }}>💧</div>
          <div style={{ flex: 1 }}>
            <div style={{ fontSize: '11px', color: 'var(--color-muted)', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
              Estrés Hídrico
            </div>
            <div style={{ fontSize: '13px', fontWeight: '600', color: 'var(--color-aceituna)', marginTop: '2px' }}>
              {datos.estres_hidrico}
            </div>
          </div>
          <div style={{ background: getNivelColor(datos.estres_nivel).bg, color: getNivelColor(datos.estres_nivel).text, padding: '4px 8px', borderRadius: '4px', fontSize: '11px', fontWeight: '700' }}>
            {getNivelLabel(datos.estres_nivel)}
          </div>
        </div>
      )}
    </div>

    {datos.alertas && datos.alertas.length > 0 && (
      <div class="analisis-alertas">
        {datos.alertas.map((alerta) => (
          <div style={{ background: '#FFF3CD', borderLeft: '4px solid #F0A500', borderRadius: '8px', padding: '12px 16px', marginBottom: '8px', fontSize: '12px', color: '#1C1C1C' }}>
            ⚠️ {alerta}
          </div>
        ))}
      </div>
    )}
  </div>
) : (
  <div class="analisis-panel">
    <p style={{ color: 'var(--color-muted)', textAlign: 'center', padding: '2rem' }}>
      Cargando análisis...
    </p>
  </div>
)}

<style>
.analisis-panel {
  background: var(--color-sal);
  border: 2px solid var(--color-border);
  border-radius: 6px;
  padding: 16px;
  margin-top: 16px;
}
.analisis-tarjetas {
  display: grid;
  gap: 12px;
}
.analisis-tarjeta {
  background: var(--color-white-surface);
  border: 2px solid var(--color-border);
  border-left-width: 4px;
  border-radius: 6px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.analisis-alertas {
  margin-top: 16px;
}
</style>

<script>
  const panel = document.querySelector('.analisis-panel');
  if (panel) {
    window.addEventListener('datos-provincia', (e) => {
      const datos = e.detail;
      if (!datos.provincia) return;
      
      const header = panel.querySelector('h3');
      if (header) {
        header.textContent = `📊 Análisis: ${datos.provincia}`;
      }
      
      const placeholder = panel.querySelector('p');
      if (placeholder && placeholder.textContent.includes('Selecciona')) {
        panel.innerHTML = '<p style="color: var(--color-muted); text-align: center; padding: 2rem;">Cargando análisis...</p>';
      }
    });
  }
</script>
