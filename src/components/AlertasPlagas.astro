---
const API_BASE = 'http://localhost:3000';
let provincia = Astro.props.provincia || null;
let datosProvincia = null;
let riesgos = [];

const iconos = { mosca: '🦟', polilla: '🦋', xylella: '🦠', repilo: '🍄' };
const nombres = { mosca: 'Mosca del olivo', polilla: 'Polilla del olivo', xylella: 'Xylella fastidiosa', repilo: 'Repilo' };

if (provincia && Astro.props.riesgosPlaga) {
  riesgos = [
    { plaga: 'mosca', nombre: nombres.mosca, icono: iconos.mosca, ...Astro.props.riesgosPlaga.mosca },
    { plaga: 'polilla', nombre: nombres.polilla, icono: iconos.polilla, ...Astro.props.riesgosPlaga.polilla },
    { plaga: 'xylella', nombre: nombres.xylella, icono: iconos.xylella, ...Astro.props.riesgosPlaga.xylella },
    { plaga: 'repilo', nombre: nombres.repilo, icono: iconos.repilo, ...Astro.props.riesgosPlaga.repilo }
  ];
}

const getNivelStyles = (nivel) => {
  const styles = {
    alto: { bg: '#FFE5E5', border: '#E74C3C', text: '#C0392B' },
    medio: { bg: '#FFF3CD', border: '#F0A500', text: '#856404' },
    bajo: { bg: '#E8F5E9', border: '#4CAF6F', text: '#2D6A4F' },
  };
  return styles[nivel] || styles.bajo;
};
---

{!provincia ? (
  <div class="plagas-panel">
    <div class="plagas-empty">
      <p style={{ color: 'var(--color-muted)', textAlign: 'center', padding: '2rem' }}>
        Selecciona tu provincia para ver alertas de plagas
      </p>
    </div>
  </div>
) : (
  <div class="plagas-panel">
    <h3 style={{ fontFamily: 'Georgia, serif', fontSize: '16px', color: 'var(--color-aceituna)', marginBottom: '4px' }}>
      🦠 Alertas de Plagas en Vivo
    </h3>
    <p style={{ fontSize: '12px', color: 'var(--color-muted)', marginBottom: '16px' }}>
      Basado en condiciones climáticas actuales en {provincia}
    </p>

    <div class="plagas-grid">
      {riesgos.map((item) => {
        const colores = getNivelStyles(item.nivel);
        return (
          <div class="plaga-tarjeta" style={{ borderColor: colores.border }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '8px' }}>
              <span style={{ fontSize: '18px' }}>{item.icono}</span>
              <span style={{ fontSize: '13px', fontWeight: '600', color: 'var(--color-aceituna)' }}>
                {item.nombre}
              </span>
            </div>
            <div style={{ background: colores.bg, color: colores.text, padding: '4px 8px', borderRadius: '4px', fontSize: '10px', fontWeight: '700', textTransform: 'uppercase', marginBottom: '8px', display: 'inline-block' }}>
              Riesgo {item.nivel}
            </div>
            <div style={{ fontSize: '12px', color: 'var(--color-muted)', marginBottom: '6px', lineHeight: '1.4' }}>
              {item.descripcion}
            </div>
            <div style={{ fontSize: '11px', fontWeight: '600', color: colores.text }}>
              {item.consejo}
            </div>
          </div>
        );
      })}
    </div>
  </div>
)}

<style>
.plagas-panel {
  background: var(--color-sal);
  border: 2px solid var(--color-border);
  border-radius: 6px;
  padding: 16px;
  margin-top: 16px;
}
.plagas-empty {
  text-align: center;
  padding: 2rem;
  color: var(--color-muted);
}
.plagas-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  container-type: inline-size;
}
@container (min-width: 300px) {
  .plagas-grid { grid-template-columns: 1fr 1fr; }
}
.plaga-tarjeta {
  background: var(--color-white-surface);
  border: 2px solid;
  border-radius: 6px;
  padding: 12px;
}
.plaga-tarjeta:has(.nivel-alto) {
  border-color: #DC3545;
  background: rgba(220, 53, 69, 0.05);
}
</style>

<script>
  const panel = document.querySelector('.plagas-panel');
  if (panel) {
    window.addEventListener('datos-provincia', (e) => {
      const datos = e.detail;
      if (!datos.provincia || !datos.riesgos_plaga) return;
      
      const header = panel.querySelector('h3');
      const subtitle = panel.querySelector('p');
      const empty = panel.querySelector('.plagas-empty');
      
      if (header) header.textContent = '🦠 Alertas de Plagas en Vivo';
      if (subtitle) subtitle.textContent = `Basado en condiciones climáticas actuales en ${datos.provincia}`;
      if (empty) empty.remove();
      
      const iconos = { mosca: '🦟', polilla: '🦋', xylella: '🦠', repilo: '🍄' };
      const nombres = { mosca: 'Mosca del olivo', polilla: 'Polilla del olivo', xylella: 'Xylella fastidiosa', repilo: 'Repilo' };
      
      const getNivelStyles = (nivel) => {
        const styles = {
          alto: { bg: '#FFE5E5', border: '#E74C3C', text: '#C0392B' },
          medio: { bg: '#FFF3CD', border: '#F0A500', text: '#856404' },
          bajo: { bg: '#E8F5E9', border: '#4CAF6F', text: '#2D6A4F' },
        };
        return styles[nivel] || styles.bajo;
      };
      
      const riesgos = [
        { plaga: 'mosca', nombre: nombres.mosca, icono: iconos.mosca, ...datos.riesgos_plaga.mosca },
        { plaga: 'polilla', nombre: nombres.polilla, icono: iconos.polilla, ...datos.riesgos_plaga.polilla },
        { plaga: 'xylella', nombre: nombres.xylella, icono: iconos.xylella, ...datos.riesgos_plaga.xylella },
        { plaga: 'repilo', nombre: nombres.repilo, icono: iconos.repilo, ...datos.riesgos_plaga.repilo }
      ];
      
      const grid = panel.querySelector('.plagas-grid');
      if (grid) {
        grid.innerHTML = '';
        riesgos.forEach((item) => {
          const colores = getNivelStyles(item.nivel);
          const div = document.createElement('div');
          div.className = 'plaga-tarjeta';
          div.style.borderColor = colores.border;
          div.innerHTML = `
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <span style="font-size: 18px;">${item.icono}</span>
              <span style="font-size: 13px; font-weight: 600; color: var(--color-aceituna);">${item.nombre}</span>
            </div>
            <div style="background: ${colores.bg}; color: ${colores.text}; padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; text-transform: uppercase; margin-bottom: 8px; display: inline-block;">
              Riesgo ${item.nivel}
            </div>
            <div style="font-size: 12px; color: var(--color-muted); margin-bottom: 6px; line-height: 1.4;">${item.descripcion}</div>
            <div style="font-size: 11px; font-weight: 600; color: ${colores.text};">${item.consejo}</div>
          `;
          grid.appendChild(div);
        });
      }
    });
  }
</script>
