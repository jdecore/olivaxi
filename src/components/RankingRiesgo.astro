---
const API_BASE = 'http://localhost:3000';
let provincias = [];
let cargando = true;

try {
  const res = await fetch(`${API_BASE}/api/clima`);
  if (res.ok) {
    const datos = await res.json();
    provincias = [...datos].sort((a, b) => b.temperatura - a.temperatura);
    cargando = false;
  }
} catch (e) {
  console.error('Error fetching clima:', e);
  cargando = false;
}

const top3 = provincias.slice(0, 3);
---

{cargando ? (
  <div style={{
    border: '2px solid var(--color-border)',
    borderRadius: '6px',
    background: 'var(--color-white-surface)',
    padding: '16px',
    fontFamily: "'Gill Sans', 'Gill Sans MT', 'Trebuchet MS', system-ui, sans-serif"
  }}>
    <div style={{
      display: 'flex',
      justifyContent: 'space-between',
      alignItems: 'center',
      marginBottom: '12px'
    }}>
      <span style={{
        fontFamily: "'Gill Sans', 'Gill Sans MT', 'Trebuchet MS', system-ui, sans-serif",
        fontSize: '15px',
        fontWeight: '600',
        color: 'var(--color-aceituna)'
      }}>Top riesgo hoy</span>
      <span style={{
        fontSize: '10px',
        color: 'var(--color-muted)',
        textTransform: 'uppercase',
        letterSpacing: '0.06em'
      }}>cargando...</span>
    </div>
  </div>
) : (
  <div style={{
    border: '2px solid var(--color-border)',
    borderRadius: '6px',
    background: 'var(--color-white-surface)',
    padding: '16px',
    fontFamily: "'Gill Sans', 'Gill Sans MT', 'Trebuchet MS', system-ui, sans-serif"
  }}>
    <div style={{
      display: 'flex',
      justifyContent: 'space-between',
      alignItems: 'center',
      marginBottom: '12px'
    }}>
      <span style={{
        fontFamily: "'Gill Sans', 'Gill Sans MT', 'Trebuchet MS', system-ui, sans-serif",
        fontSize: '15px',
        fontWeight: '600',
        color: 'var(--color-aceituna)'
      }}>Top riesgo hoy</span>
      <span style={{
        fontSize: '10px',
        color: 'var(--color-muted)',
        textTransform: 'uppercase',
        letterSpacing: '0.06em'
      }}>en vivo</span>
    </div>

    {top3.map((p, i) => {
      const riskStyle = {
        fontSize: '10px',
        fontWeight: '700',
        textTransform: 'uppercase',
        letterSpacing: '0.05em',
        padding: '3px 8px',
        borderRadius: '4px',
        border: '2px solid',
        background: p.riesgo === 'alto' ? 'rgba(220, 38, 38, 0.15)' : p.riesgo === 'medio' ? 'rgba(245, 158, 11, 0.15)' : 'rgba(34, 197, 94, 0.15)',
        color: p.riesgo === 'alto' ? '#dc2626' : p.riesgo === 'medio' ? '#92400e' : '#15803d',
        borderColor: p.riesgo === 'alto' ? '#dc2626' : p.riesgo === 'medio' ? '#92400e' : '#15803d'
      };

      return (
        <div key={p.provincia} style={{
          display: 'flex',
          alignItems: 'center',
          gap: '10px',
          padding: '8px 0',
          borderBottom: i < 2 ? '1px solid var(--color-border)' : 'none'
        }}>
          <span style={{
            fontFamily: "'Gill Sans', 'Gill Sans MT', 'Trebuchet MS', system-ui, sans-serif",
            fontSize: '18px',
            fontWeight: '600',
            color: 'var(--color-aceituna)',
            width: '20px'
          }}>{i + 1}</span>
          <div style={{ flex: 1 }}>
            <div style={{
              fontSize: '13px',
              fontWeight: '600',
              color: 'var(--color-aceituna)'
            }}>{p.provincia}</div>
            <div style={{
              fontSize: '11px',
              color: 'var(--color-muted)'
            }}>{p.temperatura}°C · {p.humedad}% 💧</div>
          </div>
          <span style={riskStyle}>{p.riesgo}</span>
        </div>
      );
    })}
  </div>
)}