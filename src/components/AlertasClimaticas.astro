---
const API_BASE = 'http://localhost:3000';
let provincia = Astro.props.provincia || null;
let datosProvincia = null;
let alertas = [];

const ALERTAS_UMBRALES = [
  { tipo: 'hongos', icono: '🦠', emoji: 'Hongos', condicion: (d) => d.humedad > 80, umbral: '>80%' },
  { tipo: 'sequia', icono: '🏜️', emoji: 'Sequía', condicion: (d) => d.humedad < 30, umbral: '<30%' },
  { tipo: 'calor', icono: '🔥', emoji: 'Calor extremo', condicion: (d) => d.temperatura > 35, umbral: '>35°C' },
  { tipo: 'inundacion', icono: '🌊', emoji: 'Inundaciones', condicion: (d) => d.lluvia > 10, umbral: '>10mm' }
];

const CONSEJOS = {
  hongos: 'Aplicar fungicida preventivo. Evitar riegos por aspersión.',
  sequia: 'Aumentar riego por goteo. Aplicar mulch para retención.',
  calor: 'Evitar podas ahora. Regar en horario nocturno.',
  inundacion: 'Revisar drenaje. Aplicar tratamiento anti-hongos.'
};

if (provincia) {
  try {
    const res = await fetch(`${API_BASE}/api/clima`);
    const datos = await res.json();
    datosProvincia = datos.find((p) => p.provincia === provincia);
    if (datosProvincia) {
      alertas = ALERTAS_UMBRALES
        .filter((a) => a.condicion(datosProvincia))
        .map((a) => ({ ...a, consejo: CONSEJOS[a.tipo] }));
    }
  } catch (e) {
    console.error('Error fetching clima:', e);
  }
}
---

<div class="alertas-climaticas">
  <div class="alertas-header">
    <div>
      <h3 class="alertas-title">🚨 Alertas Climáticas</h3>
      <p class="alertas-subtitle">
        {provincia ? `En ${provincia}` : 'Selecciona una provincia en el mapa'}
      </p>
    </div>
    {datosProvincia && (
      <div class="alertas-stats">
        <span class="stat-item">🌡️ {datosProvincia.temperatura}°C</span>
        <span class="stat-item">💧 {datosProvincia.humedad}%</span>
        <span class="stat-item">🌧️ {datosProvincia.lluvia}mm</span>
      </div>
    )}
  </div>

  {!provincia && (
    <div class="alertas-empty">
      Haz clic en una provincia del mapa para ver sus alertas
    </div>
  )}

  {provincia && alertas.length === 0 && (
    <div class="alertas-empty" style={{ color: '#22c55e' }}>
      ✅ Sin alertas activas. Condiciones normales.
    </div>
  )}

  {alertas.length > 0 && (
    <div class="alertas-list">
      {alertas.map((alerta) => (
        <div class="alerta-item">
          <span class="alerta-icono">{alerta.icono}</span>
          <div class="alerta-contenido">
            <div class="alerta-titulo">{alerta.emoji}</div>
            <div class="alerta-dato">
              Umbral: {alerta.umbral} • 
              {alerta.tipo === 'hongos' && `Humedad: ${datosProvincia?.humedad}%`}
              {alerta.tipo === 'sequia' && `Humedad: ${datosProvincia?.humedad}%`}
              {alerta.tipo === 'calor' && `Temperatura: ${datosProvincia?.temperatura}°C`}
              {alerta.tipo === 'inundacion' && `Lluvia: ${datosProvincia?.lluvia}mm`}
            </div>
            <div class="alerta-consejo">💡 {alerta.consejo}</div>
          </div>
        </div>
      ))}
    </div>
  )}
</div>

<style>
.alertas-climaticas {
  background: #FFFFFF;
  border: 2px solid var(--color-aceituna);
  border-radius: 6px;
  padding: 24px;
  min-height: 180px;
}
.alertas-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.alertas-title {
  font-family: 'Literata', Georgia, serif;
  font-size: 20px;
  color: #000000;
  margin: 0;
}
.alertas-subtitle {
  font-size: 14px;
  color: #333333;
  margin-top: 4px;
}
.alertas-stats {
  display: flex;
  gap: 24px;
  font-size: 14px;
  color: #333333;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 4px;
}
.alertas-empty {
  text-align: center;
  padding: 2rem;
  color: #333333;
  font-size: 15px;
}
.alertas-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.alerta-item {
  background: var(--color-limon);
  border: 2px solid var(--color-aceituna);
  border-radius: 6px;
  padding: 16px;
  display: flex;
  align-items: flex-start;
  gap: 16px;
}
.alerta-icono {
  font-size: 28px;
  flex-shrink: 0;
}
.alerta-contenido {
  flex: 1;
}
.alerta-titulo {
  font-size: 16px;
  font-weight: 700;
  color: #000000;
  margin-bottom: 6px;
}
.alerta-dato {
  font-size: 13px;
  color: #333333;
  margin-bottom: 8px;
}
.alerta-consejo {
  font-size: 14px;
  color: #000000;
  line-height: 1.4;
  padding-top: 10px;
  border-top: 1px solid rgba(0,0,0,0.2);
}
</style>

<script>
  const container = document.querySelector('.alertas-climaticas');
  if (container) {
    window.addEventListener('datos-provincia', (e) => {
      const datos = e.detail;
      const subtitle = container.querySelector('.alertas-subtitle');
      const stats = container.querySelector('.alertas-stats');
      const empty = container.querySelector('.alertas-empty');
      const list = container.querySelector('.alertas-list');
      
      if (subtitle) subtitle.textContent = `En ${datos.provincia}`;
      if (stats) {
        stats.innerHTML = `
          <span class="stat-item">🌡️ ${datos.temperatura}°C</span>
          <span class="stat-item">💧 ${datos.humedad}%</span>
          <span class="stat-item">🌧️ ${datos.lluvia}mm</span>
        `;
      }
      
      const alertas = [];
      if (datos.humedad > 80) {
        alertas.push({ icono: '🦠', emoji: 'Hongos', umbral: '>80%', consejo: 'Aplicar fungicida preventivo. Evitar riegos por aspersión.' });
      }
      if (datos.humedad < 30) {
        alertas.push({ icono: '🏜️', emoji: 'Sequía', umbral: '<30%', consejo: 'Aumentar riego por goteo. Aplicar mulch para retención.' });
      }
      if (datos.temperatura > 35) {
        alertas.push({ icono: '🔥', emoji: 'Calor extremo', umbral: '>35°C', consejo: 'Evitar podas ahora. Regar en horario nocturno.' });
      }
      if (datos.lluvia > 10) {
        alertas.push({ icono: '🌊', emoji: 'Inundaciones', umbral: '>10mm', consejo: 'Revisar drenaje. Aplicar tratamiento anti-hongos.' });
      }
      
      if (empty) empty.remove();
      if (list) list.remove();
      
      const listEl = document.createElement('div');
      listEl.className = 'alertas-list';
      
      if (alertas.length === 0) {
        const emptyEl = document.createElement('div');
        emptyEl.className = 'alertas-empty';
        emptyEl.style.color = '#22c55e';
        emptyEl.textContent = '✅ Sin alertas activas. Condiciones normales.';
        container.appendChild(emptyEl);
      } else {
        alertas.forEach((alerta) => {
          const item = document.createElement('div');
          item.className = 'alerta-item';
          item.innerHTML = `
            <span class="alerta-icono">${alerta.icono}</span>
            <div class="alerta-contenido">
              <div class="alerta-titulo">${alerta.emoji}</div>
              <div class="alerta-dato">Umbral: ${alerta.umbral}</div>
              <div class="alerta-consejo">💡 ${alerta.consejo}</div>
            </div>
          `;
          listEl.appendChild(item);
        });
        container.appendChild(listEl);
      }
    });
  }
</script>
