---
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
const variedadSeleccionada = Astro.props.variedad || '';
---

<div id="mapa-container" data-api-url={apiUrl} data-variedad={variedadSeleccionada}>
  <div id="mapa-filters">
    <button class="filter-btn active" data-filtro="temperatura">🌡️</button>
    <button class="filter-btn" data-filtro="humedad">💧</button>
    <button class="filter-btn" data-filtro="precipitacion">🌧️</button>
  </div>
  <div id="mapa"></div>
  <div id="mapa-legend"></div>
  <div id="mapa-loading">
    <div class="spinner"></div>
    <p>Cargando...</p>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" crossorigin />

<script type="module">
const API_BASE = 'http://45.90.237.135:3001';

const COLORS = {
  temp: [
    { max: 10, color: '#74B9FF' },
    { max: 20, color: '#55EFC4' },
    { max: 28, color: '#A8D8A8' },
    { max: 35, color: '#FDCB6E' },
    { max: 38, color: '#E17055' },
    { max: Infinity, color: '#D63031' }
  ],
  humedad: [
    { max: 20, color: '#D63031' },
    { max: 40, color: '#E17055' },
    { max: 60, color: '#FDCB6E' },
    { max: 80, color: '#55EFC4' },
    { max: Infinity, color: '#74B9FF' }
  ],
  lluvia: [
    { max: 0, color: '#FDCB6E' },
    { max: 2, color: '#55EFC4' },
    { max: 10, color: '#74B9FF' },
    { max: Infinity, color: '#0984e3' }
  ],
  riesgo: {
    'óptimo': '#16a34a',
    'bajo': '#22c55e',
    'medio': '#f59e0b',
    'crítico': '#ef4444'
  }
};

const getColor = (valor, tipo) => {
  const escala = COLORS[tipo === 'precipitacion' ? 'lluvia' : tipo] || COLORS.temp;
  for (const { max, color } of escala) {
    if (valor < max) return color;
  }
  return escala[escala.length - 1].color;
};

const getLegend = (filtro) => {
  const isDark = document.documentElement.dataset.theme === 'dark';
  const txt = isDark ? '#F7F4EE' : '#1C1C1C';
  const L = {
    temperatura: [['<10°C','#74B9FF'],['10-20°C','#55EFC4'],['20-28°C','#A8D8A8'],['28-35°C','#FDCB6E'],['35-38°C','#E17055'],['>38°C','#D63031']],
    humedad: [['<20%','#D63031'],['20-40%','#E17055'],['40-60%','#FDCB6E'],['60-80%','#55EFC4'],['>80%','#74B9FF']],
    precipitacion: [['0mm','#FDCB6E'],['<2mm','#55EFC4'],['2-10mm','#74B9FF'],['>10mm','#0984e3']]
  };
  return (L[filtro] || []).map(([l,c]) => `<span style="display:flex;align-items:center;gap:3px"><i style="width:10px;height:10px;background:${c};border-radius:3px"></i><span style="color:${txt};font-size:10px">${l}</span></span>`).join('');
};

let map, datos = [], filtro = 'temperatura', variedad = '', markers = [];

async function initMapa() {
  const load = document.getElementById('mapa-loading');
  const p = document.getElementById('mapa');
  
  if (map || !p) return;

  // Cargar datos
  try {
    const res = await fetch(`${API_BASE}/api/clima`);
    if (!res.ok) throw new Error('API error');
    datos = await res.json();
    console.log('[Mapa] Datos cargados:', datos.length);
  } catch (e) {
    console.error('[Mapa] Error datos:', e);
    load.querySelector('p').textContent = 'Error de datos';
    return;
  }

  // Cargar MapLibre
  const ml = await import('https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js');
  const maplibregl = ml.default;

  // Theme
  const isDark = document.documentElement.dataset.theme === 'dark';
  const styleUrl = isDark 
    ? 'https://tiles.openfreemap.org/styles/darkmatter' 
    : 'https://tiles.openfreemap.org/styles/liberty';

  map = new maplibregl.Map({
    container: p,
    style: styleUrl,
    center: [-3.5, 40.0],
    zoom: 6,
    minZoom: 5,
    maxZoom: 10,
    attributionControl: true
  });

  map.addControl(new maplibregl.NavigationControl(), 'top-right');

  map.on('load', () => {
    render(maplibregl);
    load.classList.add('hidden');
    document.getElementById('mapa-legend').innerHTML = getLegend(filtro);
  });

  map.on('error', (e) => {
    console.error('[Mapa] Error:', e);
    load.querySelector('p').textContent = 'Error mapa';
  });
}

function render(ml) {
  if (!map || !map.isStyleLoaded()) return;
  
  markers.forEach(m => m.remove());
  markers = [];

  const isDark = document.documentElement.dataset.theme === 'dark';
  const bg = isDark ? '#1a1a1a' : '#FFFFFF';
  const txt = isDark ? '#F7F4EE' : '#1C1C1C';

  datos.forEach((d, i) => {
    let color;
    if (variedad && d.riesgos_variedad?.[variedad]) {
      const nivel = d.riesgos_variedad[variedad].nivel;
      color = COLORS.riesgo[nivel] || COLORS.riesgo['óptimo'];
    } else {
      color = getColor(d[filtro], filtro);
    }

    const radius = 8 + (d.humedad / 100) * 8;
    const el = document.createElement('div');
    el.style.cssText = `width:${radius*2}px;height:${radius*2}px;background:${color};border:2.5px solid ${color};border-radius:50%;opacity:0.9;cursor:pointer`;

    const val = filtro === 'temperatura' ? d.temperatura + '°C' : filtro === 'humedad' ? d.humedad + '%' : d.lluvia + 'mm';
    
    el.innerHTML = `<div style="position:absolute;top:-30px;left:50%;transform:translateX(-50%);background:${bg};padding:4px 8px;border-radius:4px;font:11px sans-serif;color:${txt};white-space:nowrap">${d.provincia}: ${val}</div>`;
    el.style.position = 'relative';

    el.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('provincia-seleccionada', { detail: { provincia: d.provincia } }));
    });

    markers.push(
      new ml.Marker({ element: el })
        .setLngLat([d.lon, d.lat])
        .addTo(map)
    );
  });
}

// Event listeners
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filtro = btn.dataset.filtro;
    renderMarkers();
  });
});

window.addEventListener('variedad-seleccionada', e => {
  variedad = e.detail?.variedad || '';
  renderMarkers();
});

window.addEventListener('provincia-seleccionada', e => {
  if (!map || !e.detail?.provincia) return;
  const p = datos.find(d => d.provincia === e.detail.provincia);
  if (p?.lat && p?.lon) map.flyTo({ center: [p.lon, p.lat], zoom: 8, duration: 500 });
});

async function renderMarkers() {
  if (!map || !map.isStyleLoaded()) return;
  const ml = await import('https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js');
  render(ml.default);
  document.getElementById('mapa-legend').innerHTML = getLegend(filtro);
}

// Iniciar
const container = document.getElementById('mapa-container');
if (container?.dataset.variedad) variedad = container.dataset.variedad;
initMapa();
</script>

<style>
#mapa-container { position:relative;height:400px;width:100%;border:2px solid var(--color-sal);border-radius:8px;overflow:hidden;background:#f5f5f5 }
#mapa { height:100%;width:100%; }
#mapa-filters { position:absolute;top:10px;left:10px;z-index:10;display:flex;gap:4px;background:rgba(255,255,255,0.95);padding:6px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1) }
.filter-btn { padding:6px 10px;font-size:14px;border:1.5px solid var(--color-sal);border-radius:6px;background:var(--color-limon);color:var(--color-aceituna);cursor:pointer;font-weight:600 }
.filter-btn:hover { background:#c5d93e }
.filter-btn.active { background:#fff;border-color:var(--color-aceituna) }
#mapa-loading { position:absolute;inset:0;background:var(--color-bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:20;gap:12px }
#mapa-loading.hidden { display:none }
.spinner { width:36px;height:36px;border:3px solid var(--color-muted);border-top-color:var(--color-limon);border-radius:50%;animation:spin .8s linear infinite }
#mapa-legend { position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(255,255,255,0.95);border:2px solid var(--color-sal);border-radius:6px;padding:6px 12px;font-size:10px;z-index:10;display:flex;gap:10px;box-shadow:0 2px 8px rgba(0,0,0,0.1) }
@media(max-width:768px){ #mapa-container{height:320px} #mapa-filters{top:5px;left:5px;padding:4px } .filter-btn{padding:4px 8px;font-size:12px } }
@keyframes spin { to{transform:rotate(360deg)} }
</style>
