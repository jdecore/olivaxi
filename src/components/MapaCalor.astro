---
const variedadSeleccionada = Astro.props.variedad || '';
---

<olivaxi-mapa 
  id="mapa-container"
  data-variedad={variedadSeleccionada}
></olivaxi-mapa>

<script>
class OlivaxiMapa extends HTMLElement {
  constructor() {
    super();
    this.map = null;
    this.datos = [];
    this.filtro = 'temperatura';
    this.variedad = '';
    this.markers = [];
    this.inited = false;
    this.provinciaSeleccionada = '';
    this._flyToHandler = null;
    this._offEcosistema = null;
  }

  connectedCallback() {
    if (this.inited) return;
    this.inited = true;
    this.init();
  }

  async init() {
    import('../lib/ecosistema').then(({ default: Ecosistema }) => {
      this._ecosistema = Ecosistema;
      this._setupMap();
    });
  }

  async _setupMap() {
    const Ecosistema = this._ecosistema;
    const TILE_SERVER = 'https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json';

    while (this.firstChild) this.removeChild(this.firstChild);

    const style = document.createElement('style');
    style.textContent = `
      olivaxi-mapa { display: block; width: 100%; height: 100%; }
      .mapa-wrapper { position: relative; height: 100%; width: 100%; overflow: hidden; background: #e8e8e8; }
      .mapa-inner { height: 100%; width: 100%; }
      .mapa-filters { position: absolute; top: 8px; left: 8px; z-index: 10; display: flex; gap: 4px; }
      .filter-btn { padding: 8px 12px; font-size: 12px; border: 1.5px solid var(--color-border); border-radius: 4px; background: var(--color-white-surface); color: var(--color-aceituna); cursor: pointer; font-weight: 600; }
      .filter-btn:hover { background: var(--color-limon); }
      .filter-btn.active { background: var(--color-limon); }
      .mapa-loading { position: absolute; inset: 0; background: var(--color-bg); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 20; gap: 10px; }
      .mapa-loading.hidden { display: none; }
      .spinner { width: 28px; height: 28px; border: 2px solid var(--color-border); border-top-color: var(--color-limon); border-radius: 50%; animation: spin .8s linear infinite; }
      .mapa-legend { position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); width: min(96%, 760px); background: rgba(255,255,255,0.92); border: 1px solid var(--color-border); border-radius: 8px; padding: 8px 10px; font-size: 9px; z-index: 10; display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 6px; box-sizing: border-box; }
      .mapa-legend-item { display: flex; align-items: center; justify-content: flex-start; gap: 6px; min-width: 0; padding: 2px 4px; border-radius: 4px; }
      .mapa-legend-label { color: #1C1C1C; font-size: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 600; }
      @media (max-width: 640px) {
        .mapa-legend { grid-template-columns: repeat(2, minmax(0, 1fr)); width: min(96%, 360px); padding: 6px 8px; }
        .mapa-legend-label { font-size: 10px; }
        .filter-btn { padding: 10px 14px; font-size: 13px; }
      }
      .provincia-marker { }
      .provincia-marker:hover { transform: scale(1.3); }
      .provincia-marker.selected { border-color: #D4E849 !important; transform: scale(1.2); }
      @keyframes spin { to { transform: rotate(360deg); } }
    `;
    this.appendChild(style);

    const wrapper = document.createElement('div');
    wrapper.className = 'mapa-wrapper';

    const filters = document.createElement('div');
    filters.className = 'mapa-filters';
    [
      ['temperatura', '🌡️'],
      ['humedad', '💧'],
      ['precipitacion', '🌧️']
    ].forEach(([filtro, label], idx) => {
      const btn = document.createElement('button');
      btn.className = `filter-btn${idx === 0 ? ' active' : ''}`;
      btn.dataset.filtro = filtro;
      btn.textContent = label;
      filters.appendChild(btn);
    });

    const mapaInner = document.createElement('div');
    mapaInner.className = 'mapa-inner';
    const legend = document.createElement('div');
    legend.className = 'mapa-legend';
    const loadingEl = document.createElement('div');
    loadingEl.className = 'mapa-loading';
    const spinner = document.createElement('div');
    spinner.className = 'spinner';
    const loadingText = document.createElement('p');
    loadingText.textContent = 'Cargando...';
    loadingEl.appendChild(spinner);
    loadingEl.appendChild(loadingText);

    wrapper.appendChild(filters);
    wrapper.appendChild(mapaInner);
    wrapper.appendChild(legend);
    wrapper.appendChild(loadingEl);
    this.appendChild(wrapper);

    const loading = this.querySelector('.mapa-loading');
    const mapaDiv = this.querySelector('.mapa-inner');
    
    // Wait for maplibregl with longer timeout
    if (typeof maplibregl === 'undefined') {
      loading.querySelector('p').textContent = 'Cargando mapa...';
      for (let i = 0; i < 100; i++) {
        await new Promise(r => setTimeout(r, 100));
        if (typeof maplibregl !== 'undefined') break;
      }
      if (typeof maplibregl === 'undefined') {
        console.error('MapLibre not loaded after 10s');
        const msg = loading.querySelector('p');
        while (msg.firstChild) msg.removeChild(msg.firstChild);
        msg.appendChild(document.createTextNode('Error: Mapa no disponible.'));
        const br = document.createElement('br');
        const small = document.createElement('small');
        small.style.fontSize = '11px';
        small.textContent = '💡 Desactiva bloqueadores de anuncios para mejor experiencia';
        msg.appendChild(br);
        msg.appendChild(small);
        return;
      }
    }

    // Load data via ecosistema (cache compartido)
    loading.querySelector('p').textContent = 'Cargando datos...';
    try {
      this.datos = await Ecosistema.fetchClima();
      if (!this.datos || this.datos.length === 0) throw new Error('Sin datos');
    } catch (e) {
      console.error('Error datos:', e);
      loading.querySelector('p').textContent = 'Error de datos. Reintentando...';
      try {
        await new Promise(r => setTimeout(r, 700));
        this.datos = await Ecosistema.fetchClima();
      } catch (_) {}
      if (!this.datos || this.datos.length === 0) {
        loading.querySelector('p').textContent = 'Error de datos';
        return;
      }
      loading.querySelector('p').textContent = 'Datos recuperados';
      await new Promise(r => setTimeout(r, 300));
    }

    // Restaurar provincia seleccionada desde ecosistema
    this.provinciaSeleccionada = Ecosistema.provincia;

    // Create map
    loading.querySelector('p').textContent = 'Cargando mapa...';
    this.map = new maplibregl.Map({
      container: mapaDiv,
      style: TILE_SERVER,
      center: [-3.5, 40.0],
      zoom: 5.5,
      minZoom: 4,
      maxZoom: 10,
      attributionControl: false
    });

    this.map.on('load', () => {
      this.render();
      loading.classList.add('hidden');
      this.updateLegend();
    });

    // Events - filtros del mapa
    this.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        this.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        this.filtro = btn.dataset.filtro;
        this.render();
        this.updateLegend();
      });
    });

    // Escuchar cambios de variedad desde el ecosistema
    this._offEcosistema = Ecosistema.onChange((state) => {
      let needsFullRender = false;
      if (state.variedad !== this.variedad) {
        this.variedad = state.variedad;
        needsFullRender = true;
      }
      // Actualizar provincia seleccionada para highlight (solo estilo, no recrear)
      if (state.provincia !== this.provinciaSeleccionada) {
        this.provinciaSeleccionada = state.provincia;
        // Si se deselecciona provincia, mostrar España completa
        if (!state.provincia) {
          this.map.flyTo({ center: [-3.5, 40.0], zoom: 5.5, duration: 1000 });
        }
        if (needsFullRender) {
          this.render();
        } else {
          this.updateMarkerStyles();
        }
      } else if (needsFullRender) {
        this.render();
      }
    });

    // Escuchar flyTo desde index
    this._flyToHandler = (e) => {
      const { provincia } = e.detail || {};
      if (!provincia) return;
      const datos = this.datos.find(d => d.provincia === provincia);
      if (datos && this.map) {
        this.flyToProvince(datos.lat, datos.lon);
      }
    };
    window.addEventListener('flyToProvincia', this._flyToHandler);
  }

  disconnectedCallback() {
    if (typeof this._offEcosistema === 'function') {
      this._offEcosistema();
      this._offEcosistema = null;
    }
    if (this._flyToHandler) {
      window.removeEventListener('flyToProvincia', this._flyToHandler);
      this._flyToHandler = null;
    }
  }

  getColor(valor, tipo) {
    const colores = {
      temp: [[10,'#74B9FF'],[20,'#55EFC4'],[28,'#A8D8A8'],[35,'#FDCB6E'],[38,'#E17055'],[Infinity,'#D63031']],
      humedad: [[20,'#D63031'],[40,'#E17055'],[60,'#FDCB6E'],[80,'#55EFC4'],[Infinity,'#74B9FF']],
      lluvia: [[0,'#FDCB6E'],[2,'#55EFC4'],[10,'#74B9FF'],[Infinity,'#0984e3']]
    };
    const escala = colores[tipo === 'precipitacion' ? 'lluvia' : tipo] || colores.temp;
    for (const [max, color] of escala) {
      if (valor < max) return color;
    }
    return escala[escala.length - 1][1];
  }

  getMarkerColor(datos) {
    const riesgo = datos.riesgo || 'bajo';
    if (riesgo === 'alto' || riesgo === 'crítico') return '#ef4444';
    if (riesgo === 'medio') return '#f59e0b';
    return '#22c55e';
  }

  getRiskBadge(riesgo) {
    if (riesgo === 'alto' || riesgo === 'crítico') return '🔴';
    if (riesgo === 'medio') return '🟡';
    return '🟢';
  }

  getRiesgosActivos(datos) {
    if (Array.isArray(datos?.riesgosActivos) && datos.riesgosActivos.length) {
      return datos.riesgosActivos;
    }
    return [];
  }

  createPopupContent(d, val, riesgoColor) {
    const container = document.createElement('div');
    container.style.cssText = 'font-family:system-ui;padding:12px;background:#fff;color:#1C1C1C;border-radius:8px;min-width:200px;font-size:12px';

    const title = document.createElement('div');
    title.style.cssText = `font-weight:bold;font-size:14px;margin-bottom:8px;border-bottom:2px solid ${riesgoColor};padding-bottom:6px`;
    const titleInfo = document.createElement('span');
    titleInfo.style.cssText = 'font-size:11px;font-weight:normal';
    titleInfo.textContent = ` (${d.riesgo?.toUpperCase() || 'bajo'})`;
    title.appendChild(document.createTextNode(`${this.getRiskBadge(d.riesgo)} ${d.provincia}`));
    title.appendChild(titleInfo);
    container.appendChild(title);

    const clima = document.createElement('div');
    clima.style.marginBottom = '4px';
    clima.appendChild(document.createTextNode('🌡️ '));
    const valBold = document.createElement('b');
    valBold.textContent = val;
    clima.appendChild(valBold);
    clima.appendChild(document.createTextNode(` · 💧 ${d.humedad}% · 🌧️ ${d.lluvia}mm`));
    container.appendChild(clima);

    const appendRow = (prefix, value, suffix = '', emphasize = true) => {
      if (!value && value !== 0) return;
      const row = document.createElement('div');
      row.style.marginBottom = '4px';
      row.appendChild(document.createTextNode(`${prefix} `));
      const b = document.createElement('b');
      b.textContent = String(value);
      if (emphasize) row.appendChild(b);
      else row.appendChild(document.createTextNode(String(value)));
      if (suffix) row.appendChild(document.createTextNode(suffix));
      container.appendChild(row);
    };

    if (d.variedadPredominante) appendRow('🫒', d.variedadPredominante);
    if (d.tipoSuelo) appendRow('🪨', d.tipoSuelo);
    if (d.altitud) appendRow('⛰️', `${d.altitud}m`, '', false);
    if (d.pluviometriaAnual) appendRow('🌧️', d.pluviometriaAnual, 'mm/año', false);

    if (d.epocaCritica) {
      const critical = document.createElement('div');
      critical.style.cssText = 'margin-bottom:4px;padding:4px;background:#D4E84920;border-radius:4px';
      critical.appendChild(document.createTextNode('⚠️ '));
      const b = document.createElement('b');
      b.textContent = d.epocaCritica;
      critical.appendChild(b);
      container.appendChild(critical);
    }

    const riesgosActivos = this.getRiesgosActivos(d).slice(0, 6);
    if (riesgosActivos.length > 0) {
      const chips = document.createElement('div');
      chips.style.cssText = 'display:flex;flex-wrap:wrap;gap:4px;margin-top:6px';
      riesgosActivos.forEach((r) => {
        const chip = document.createElement('span');
        chip.style.cssText = `background:${riesgoColor}20;color:${riesgoColor};padding:2px 6px;border-radius:4px;font-size:10px`;
        const nivel = String(r.nivel || 'medio').toUpperCase();
        chip.textContent = `${r.icono || '⚠️'} ${r.titulo || r.tipo || 'Riesgo'} (${nivel})`;
        chips.appendChild(chip);
      });
      container.appendChild(chips);
    }

    const footer = document.createElement('div');
    footer.style.cssText = 'margin-top:8px;padding-top:8px;border-top:1px solid #ccc;color:#D4E849;font-size:10px';
    footer.textContent = 'Click para seleccionar →';
    container.appendChild(footer);
    return container;
  }

  render() {
    if (!this.map || !this.map.loaded()) return;
    
    this.markers.forEach(m => m.remove());
    this.markers = [];

    this.datos.forEach(d => {
      let color;
      if (this.filtro === 'riesgo' && this.variedad) {
        const rv = d.riesgos_variedad?.[this.variedad];
        color = rv?.nivel === 'alto' || rv?.nivel === 'crítico' ? '#ef4444' : rv?.nivel === 'medio' ? '#f59e0b' : '#22c55e';
      } else {
        color = this.getColor(d[this.filtro], this.filtro);
      }
      
      const isSelected = d.provincia === this.provinciaSeleccionada;
      const borderWidth = isSelected ? '3px' : '2px';
      const borderColor = isSelected ? '#D4E849' : '#fff';
      
      const el = document.createElement('div');
      el.dataset.provincia = d.provincia;
      el.className = 'provincia-marker' + (isSelected ? ' selected' : '');
      el.style.cssText = `width:16px;height:16px;background:${color};border:${borderWidth} solid ${borderColor};border-radius:50%;opacity:0.95;cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,0.4)`;
      
      const val = this.filtro === 'temperatura' ? d.temperatura + '°C' : 
                  this.filtro === 'humedad' ? d.humedad + '%' : 
                  this.filtro === 'precipitacion' ? d.lluvia + 'mm' :
                  d.riesgo || 'bajo';
      
      const riesgoColor = this.getMarkerColor(d);

      const popup = new maplibregl.Popup({ offset: [0, -12], closeButton: false }).setDOMContent(
        this.createPopupContent(d, val, riesgoColor)
      );

      el.addEventListener('click', () => {
        this._ecosistema.setProvincia(d.provincia);
      });

      this.markers.push(
        new maplibregl.Marker({ element: el })
          .setLngLat([d.lon, d.lat])
          .setPopup(popup)
          .addTo(this.map)
      );
    });
  }

  // Solo actualiza estilos de markers existentes (sin recrearlos)
  updateMarkerStyles() {
    this.markers.forEach(marker => {
      const el = marker.getElement();
      const prov = el.dataset.provincia;
      if (prov === this.provinciaSeleccionada) {
        el.classList.add('selected');
      } else {
        el.classList.remove('selected');
      }
    });
  }

  flyToProvince(lat, lon, zoom = 9) {
    if (!this.map) return;
    this.map.flyTo({
      center: [lon, lat],
      zoom: zoom,
      duration: 1500,
      essential: true
    });
  }

  getMarkerData(nombreProvincia) {
    return this.datos.find(d => d.provincia === nombreProvincia);
  }

  updateLegend() {
    const legend = this.querySelector('.mapa-legend');
    if (!legend) return;
    const L = {
      temperatura: [['<10°C','#74B9FF'],['10-20°C','#55EFC4'],['20-28°C','#A8D8A8'],['28-35°C','#FDCB6E'],['35-38°C','#E17055'],['>38°C','#D63031']],
      humedad: [['<20%','#D63031'],['20-40%','#E17055'],['40-60%','#FDCB6E'],['60-80%','#55EFC4'],['>80%','#74B9FF']],
      precipitacion: [['0mm','#FDCB6E'],['<2mm','#55EFC4'],['2-10mm','#74B9FF'],['>10mm','#0984e3']],
      riesgo: [['🟢 Bajo','#22c55e'],['🟡 Medio','#f59e0b'],['🔴 Alto','#ef4444']]
    };
    while (legend.firstChild) legend.removeChild(legend.firstChild);
    (L[this.filtro] || []).forEach(([label, color]) => {
      const item = document.createElement('span');
      item.className = 'mapa-legend-item';
      const swatch = document.createElement('i');
      swatch.style.cssText = `width:10px;height:10px;background:${color};border-radius:3px;flex:0 0 10px`;
      const text = document.createElement('span');
      text.className = 'mapa-legend-label';
      text.textContent = label;
      item.appendChild(swatch);
      item.appendChild(text);
      legend.appendChild(item);
    });
  }
}

customElements.define('olivaxi-mapa', OlivaxiMapa);
</script>

<!-- Preconnect a CDNs críticos -->
<link rel="preconnect" href="https://unpkg.com" crossorigin />
<link rel="preconnect" href="https://basemaps.cartocdn.com" crossorigin />

<!-- Cargar MapLibre inmediatamente en móvil -->
<script>
(function() {
  if (window.maplibregl) return;
  
  const loadMapLibre = () => {
    if (window.maplibregl) return;
    
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css';
    document.head.appendChild(link);
    
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js';
    script.crossOrigin = 'anonymous';
    document.head.appendChild(script);
  };
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadMapLibre, { once: true });
  } else {
    loadMapLibre();
  }
})();
</script>
