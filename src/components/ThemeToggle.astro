---
import styles from './ThemeToggle.module.css';
---

<button
  id="theme-toggle"
  class={styles.toggle}
  type="button"
  role="switch"
  aria-label="Cambiar tema"
  aria-checked="false"
>
  <span class={styles.track}>
    <span class={styles.sunPattern}></span>
    <span class={styles.moonPattern}></span>
  </span>
  <span class={styles.thumb}>
    <span class={styles.thumbIcon}>☀️</span>
  </span>
</button>
<span class={styles.visuallyHidden}>Cambiar entre modo claro y oscuro</span>

<script>
  function initToggle() {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;
    
    const thumb = toggle.querySelector('.thumbIcon');
    const html = document.documentElement;
    
    function setTheme(dark: boolean) {
      html.setAttribute('data-theme', dark ? 'dark' : 'light');
      localStorage.setItem('theme', dark ? 'dark' : 'light');
      toggle.setAttribute('aria-checked', String(dark));
      if (thumb) {
        thumb.textContent = dark ? '🌙' : '☀️';
      }
    }

    function initTheme() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const dark = stored === 'dark' || (!stored && prefersDark);
      setTheme(dark);
    }

    toggle.addEventListener('click', () => {
      const isDark = html.getAttribute('data-theme') === 'dark';
      setTheme(!isDark);
      
      // Dispatch event for React components
      window.dispatchEvent(new CustomEvent('modoOscuroChange', { 
        detail: { modoOscuro: !isDark } 
      }));
    });

    initTheme();
  }

  // Run on initial load
  initToggle();

  // Run after each ViewTransition
  document.addEventListener('astro:after-swap', initToggle);
</script>