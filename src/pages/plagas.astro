---
import Layout from '../layouts/Layout.astro';
import ProvinciaSelect from '../components/ProvinciaSelect.astro';

const plagas = [
  {
    id: 'mosca',
    nombre: 'Mosca del olivo',
    icono: '🪰',
    condiciones: ['Altas Temperaturas', 'Baja Lluvia (Sequía)'],
    tratamiento: 'Trampas masivas McPhail (70-100/ha); cebo proteico parcheo; insecticidas si >7% frutos picados. Con +3°C alarga actividad hasta noviembre.',
    severidad: 'alta'
  },
  {
    id: 'polilla',
    nombre: 'Polilla del olivo (Prays)',
    icono: '🦋',
    condiciones: ['Bajas Temperaturas', 'Altas Temperaturas', 'Baja Humedad', 'Baja Lluvia'],
    tratamiento: 'Bacillus thuringiensis en floración; aceites minerales; monitoreo con trampas. Más ciclos por temperaturas cálidas.',
    severidad: 'media'
  },
  {
    id: 'xylella',
    nombre: 'Xylella fastidiosa',
    icono: '🚨',
    condiciones: ['Altas Temperaturas', 'Baja Humedad'],
    tratamiento: 'Control de vectores (Philaenus), eliminación de focos y notificación fitosanitaria obligatoria.',
    severidad: 'alta'
  },
  {
    id: 'tuberculosis',
    nombre: 'Tuberculosis del olivo',
    icono: '🦠',
    condiciones: ['Bajas Temperaturas', 'Alta Humedad'],
    tratamiento: 'Aplicar cobre en heridas; mejorar drenaje y poda sanitaria. Tratar inmediatamente después de heladas.',
    severidad: 'media'
  },
  {
    id: 'repilo',
    nombre: 'Repilo',
    icono: '🍂',
    condiciones: ['Alta Humedad'],
    tratamiento: 'Cobre (máx 4kg/ha/año); bicarbonatos (500-1000g/hl); tratamientos preventivos post-invierno.',
    severidad: 'alta'
  },
  {
    id: 'barrenillo',
    nombre: 'Barrenillo',
    icono: '🪲',
    condiciones: ['Altas Temperaturas', 'Baja Humedad', 'Estrés hídrico'],
    tratamiento: 'Retirar leña de poda, trampeo de madera cebo y evitar debilidad del árbol por sequía.',
    severidad: 'media'
  },
  {
    id: 'cochinilla',
    nombre: 'Cochinilla',
    icono: '🐛',
    condiciones: ['Altas Temperaturas', 'Baja Humedad'],
    tratamiento: 'Aceites minerales; insecticidas sistémicos; mejorar ventilación. Por estrés hídrico aumenta.',
    severidad: 'baja'
  },
  {
    id: 'phytophthora',
    nombre: 'Phytophthora',
    icono: '🍄',
    condiciones: ['Alta Humedad', 'Alta Lluvia'],
    tratamiento: 'Mejorar drenaje; fungicidas específicos (metalaxyl, fosetil-Al); evitar encharcamiento.',
    severidad: 'alta'
  },
  {
    id: 'lepra',
    nombre: 'Lepra',
    icono: '🤕',
    condiciones: ['Bajas Temperaturas', 'Alta Humedad'],
    tratamiento: 'Cobre en heridas; poda sanitaria; eliminar restos vegetales afectados.',
    severidad: 'media'
  },
  {
    id: 'verticillium',
    nombre: 'Verticillium',
    icono: '🥀',
    condiciones: ['Alta Lluvia'],
    tratamiento: 'Rotación de cultivos; suelo solarizado; evitar heridas en raíces; variedades resistentes.',
    severidad: 'alta'
  }
];

const cambioClimatico = [
  { plaga: 'Mosca del olivo', cambio: '+3°C alarga actividad hasta noviembre', severidad: 'alta' },
  { plaga: 'Xylella fastidiosa', cambio: 'Expansión norteña, transmitida por Philaenus spumarius', severidad: 'critica' },
  { plaga: 'Hongos oportunistas', cambio: '+60% pérdidas proyectadas con +2°C', severidad: 'alta' }
];
---

<Layout title="Plagas del Olivar | olivaξ">
  <div class="page-header">
    <h1>🦠 Plagas del Olivar</h1>
    <p class="subtitle">Estado fitosanitario actualizado por provincia (RAIF + riesgos climáticos y de suelo)</p>
    <div class="provincia-bar">
      <ProvinciaSelect id="provincia-select-plagas" placeholder="Selecciona provincia..." />
      <div id="raif-status-bar" class="raif-status"></div>
    </div>
  </div>

  <div class="tabs-container">
    <button class="tab active" data-tab="todas">Todas</button>
    <button class="tab" data-tab="temperatura">Temperatura</button>
    <button class="tab" data-tab="humedad">Humedad</button>
    <button class="tab" data-tab="lluvia">Lluvia</button>
    <button class="tab" data-tab="clima">Cambio climático</button>
  </div>

  <section class="plagas-section" id="plagas-grid">
    {plagas.map((p, idx) => (
      <div 
        class="plaga-card" 
        data-condiciones={p.condiciones.join(",")}
        data-nombre={p.nombre}
        data-severidad={p.severidad}
      >
        <div class="plaga-inner">
          <div class="plaga-front">
            <span class="plaga-icon">{p.icono}</span>
            <h3>{p.nombre}</h3>
            <div class="condiciones-box">
              <span class="condiciones-label">Condiciones que la favorecen:</span>
              <div class="condiciones-tags">
                {p.condiciones.map(c => (
                  <span class="condicion-tag">{c}</span>
                ))}
              </div>
            </div>
            <span class="flip-hint">Click para ver tratamiento →</span>
          </div>
          <div class="plaga-back">
            <span class="plaga-icon">{p.icono}</span>
            <h3>💊 Tratamiento</h3>
            <p class="tratamiento-text">{p.tratamiento}</p>
            <div class="condiciones-footer">
              <span class="footer-label">Afectada por:</span>
              <div class="condiciones-tags">
                {p.condiciones.map(c => (
                  <span class="condicion-tag">{c}</span>
                ))}
              </div>
            </div>
            <span class="flip-hint">← Volver</span>
          </div>
        </div>
      </div>
    ))}
  </section>

  <section class="clima-section" id="clima-section" style="display: none;">
    <div class="clima-hero">
      <h2>🌡️ Plagas Aumentadas por el Cambio Climático</h2>
      <p>El calentamiento global está modificando la distribución y frecuencia de las plagas del olivar</p>
    </div>
    <div class="clima-grid">
      {cambioClimatico.map((item) => (
        <div class={`clima-card severidad-${item.severidad}`}>
          <h3>{item.plaga}</h3>
          <p class="cambio">{item.cambio}</p>
          <span class={`badge-severidad ${item.severidad}`}>{item.severidad}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  import OlivaxiEcosistema from '../lib/ecosistema';

  const raifStatusBar = document.getElementById('raif-status-bar');

  const condicionesMap = {
    'temperatura': ['Bajas Temperaturas', 'Altas Temperaturas'],
    'humedad': ['Baja Humedad', 'Alta Humedad'],
    'lluvia': ['Baja Lluvia', 'Alta Lluvia']
  };

  const PLAGAS_CONSEJOS = {
    mosca: { alto: '🧪 Tratamiento urgente: cebo proteico + trampa McPhail', medio: '🪰 Vigilar: instala trampas masivas', bajo: '✅ Sin riesgo activo' },
    polilla: { alto: '🦋 Tratamiento inmediato: Bacillus thuringiensis', medio: '🪓 Poda sanitaria + monitoreo', bajo: '✅ Sin riesgo activo' },
    repilo: { alto: '🍄 Fungicida urgente: cobre + bicarbonatos', medio: '🌳 Poda para aireación + evitar riego', bajo: '✅ Sin riesgo activo' },
    xylella: { alto: '🚨 Notificar autoridades + eliminar afectados', medio: '🛡️ Medidas preventivas activas', bajo: '✅ Sin riesgo activo' },
    tuberculosis: { alto: '🧴 Aplicar cobre tras heridas y heladas', medio: '✂️ Poda sanitaria y desinfección', bajo: '✅ Riesgo controlado' },
    barrenillo: { alto: '🪲 Retira madera atacada y coloca cebos', medio: '🌳 Vigila ramas débiles', bajo: '✅ Riesgo controlado' },
    cochinilla: { alto: '🧪 Tratamiento localizado + aceites', medio: '👀 Monitoriza colonias', bajo: '✅ Riesgo bajo' },
    phytophthora: { alto: '💧 Mejora drenaje + fungicida específico', medio: '🕳️ Evita encharcamiento', bajo: '✅ Riesgo bajo' },
    lepra: { alto: '🧴 Cobre preventivo y saneo', medio: '🌿 Elimina tejido afectado', bajo: '✅ Riesgo bajo' },
    verticillium: { alto: '🥀 Arranque sanitario y control estricto', medio: '🛡️ Prevención en suelo', bajo: '✅ Riesgo bajo' }
  };
  
    const PLAGAS_CONDICIONES = {
    mosca: (d) => d.clima.temperatura > 20 && d.clima.humedad < 70 ? '🔥 IDEALES' : d.clima.temperatura > 25 ? '🌡️ FAVORABLES' : '❄️ DESFAVORABLES',
    polilla: (d) => d.clima.temperatura > 15 && d.clima.temperatura < 30 ? '🔥 IDEALES' : '❄️ DESFAVORABLES',
    repilo: (d) => d.clima.humedad > 70 ? '💧 IDEALES (alta humedad)' : d.clima.humedad > 50 ? '💧 FAVORABLES' : '✅ DESFAVORABLES',
    xylella: (d) => '🚨 Siempre riesgo (transmitida por vectores)',
    tuberculosis: (d) => d.clima.humedad > 70 && d.clima.temperatura < 18 ? '🧫 FAVORABLES' : '✅ DESFAVORABLES',
    barrenillo: (d) => d.clima.temperatura > 28 && d.clima.humedad < 55 ? '🔥 IDEALES' : '🌡️ MODERADAS',
    cochinilla: (d) => d.clima.temperatura > 26 && d.clima.humedad < 60 ? '🔥 IDEALES' : '✅ DESFAVORABLES',
    phytophthora: (d) => d.clima.lluvia > 5 && d.clima.humedad > 75 ? '💧 IDEALES' : '✅ DESFAVORABLES',
    lepra: (d) => d.clima.humedad > 70 && d.clima.temperatura < 15 ? '🌧️ FAVORABLES' : '✅ DESFAVORABLES',
    verticillium: (d) => (d.suelo?.humedad ?? 0) > 65 ? '🌱 FAVORABLES (suelo húmedo)' : '✅ DESFAVORABLES'
  };

  const RIESGO_KEY_BY_TIPO = {
    repilo_hongo: 'repilo',
    verticilosis: 'verticillium',
    antracnosis: 'phytophthora',
    tuberculosis: 'tuberculosis'
  };

  // --- Render datos de plagas ---
  function renderPlagasData(d) {
    const getIcon = (nivel) => nivel === 'alto' ? '🔴' : nivel === 'medio' ? '🟡' : '🟢';
    
    if (raifStatusBar) {
      const endemicas = d.provinciaInfo?.plagasEndemicas?.length ? `<span>🏠 Endémicas: ${d.provinciaInfo.plagasEndemicas.join(', ')}</span>` : '';
      const raifDate = d.provinciaInfo?.plagasUltimaActualizacion ? `<span>🗓️ RAIF: ${d.provinciaInfo.plagasUltimaActualizacion}</span>` : '';
      raifStatusBar.innerHTML = `
        <span>🪰 Mosca: ${getIcon(d.plagas?.mosca?.nivel)} ${d.plagas?.mosca?.nivel || 'bajo'}</span>
        <span>🦋 Polilla: ${getIcon(d.plagas?.polilla?.nivel)} ${d.plagas?.polilla?.nivel || 'bajo'}</span>
        <span>🍂 Repilo: ${getIcon(d.plagas?.repilo?.nivel)} ${d.plagas?.repilo?.nivel || 'bajo'}</span>
        <span>🚨 Xylella: ${getIcon(d.plagas?.xylella?.nivel)} ${d.plagas?.xylella?.nivel || 'bajo'}</span>
        <span>🌡️ ${d.clima?.temperatura || '?'}°C • 💧 ${d.clima?.humedad || '?'}%</span>
        ${raifDate}
        ${endemicas}
      `;
    }
    
    const plagasMap = {
      'Mosca del olivo': 'mosca',
      'Polilla del olivo (Prays)': 'polilla',
      'Repilo': 'repilo',
      'Xylella fastidiosa': 'xylella',
      'Tuberculosis del olivo': 'tuberculosis',
      'Barrenillo': 'barrenillo',
      'Cochinilla': 'cochinilla',
      'Phytophthora': 'phytophthora',
      'Lepra': 'lepra',
      'Verticillium': 'verticillium'
    };
    document.querySelectorAll('.plaga-card').forEach(card => {
      const nombre = card.dataset.nombre;
      const plagaKey = plagasMap[nombre];
      if (!plagaKey) return;
      
      const riesgoEntry = (d.riesgosActivos || []).find(r =>
        (r.tipo === plagaKey || RIESGO_KEY_BY_TIPO[r.tipo] === plagaKey)
      );
      const nivel = d.plagas?.[plagaKey]?.nivel || riesgoEntry?.nivel || 'bajo';
      const condiciones = PLAGAS_CONDICIONES[plagaKey] ? PLAGAS_CONDICIONES[plagaKey](d) : 'N/A';
      const consejo = PLAGAS_CONSEJOS[plagaKey]?.[nivel] || 'Sin datos';
      const fuente = d.plagas?.[plagaKey]?.fuente === 'RAIF' ? 'RAIF' : (riesgoEntry ? 'Modelo climático/suelo' : 'Base técnica');
      
      let estadoDiv = card.querySelector('.plaga-estado-dinamico');
      if (!estadoDiv) {
        estadoDiv = document.createElement('div');
        estadoDiv.className = 'plaga-estado-dinamico';
        card.querySelector('.plaga-front')?.appendChild(estadoDiv);
      }
      
      estadoDiv.innerHTML = `
        <div class="estado-provincial">
          <div class="estado-header"><span class="estado-nivel ${nivel}">${getIcon(nivel)} ${nivel.toUpperCase()}</span></div>
          <div class="estado-detalle">🌡️ ${condiciones}</div>
          <div class="estado-detalle">🧾 Fuente: ${fuente}</div>
          <div class="estado-consejo">💡 ${consejo}</div>
        </div>
      `;

      // Store nivel for sorting
      card.dataset.nivelRiesgo = nivel === 'alto' ? '3' : nivel === 'medio' ? '2' : '1';
    });

    // Reordenar cards por riesgo: alto → medio → bajo
    const grid = document.getElementById('plagas-grid');
    if (grid) {
      const cards = Array.from(grid.querySelectorAll('.plaga-card'));
      cards.sort((a, b) => {
        return (parseInt(b.dataset.nivelRiesgo) || 1) - (parseInt(a.dataset.nivelRiesgo) || 1);
      });
      cards.forEach(card => grid.appendChild(card));
    }
  }

  // --- Cargar datos via ecosistema ---
  async function cargarDatosProvincia() {
    const provincia = OlivaxiEcosistema.provincia;
    if (!provincia) {
      if (raifStatusBar) raifStatusBar.innerHTML = '';
      return;
    }
    const d = await OlivaxiEcosistema.fetchDashboard();
    if (d) renderPlagasData(d);
  }

  // --- Escuchar cambios del ecosistema ---
  OlivaxiEcosistema.onChange((state) => {
    if (state.dashboardData && state.dashboardData.provincia === state.provincia) {
      renderPlagasData(state.dashboardData);
    } else if (state.provincia) {
      cargarDatosProvincia();
    }
  });

  // --- Tabs de filtrado ---
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      const tabName = tab.dataset.tab;
      const grid = document.getElementById('plagas-grid');
      const climaSection = document.getElementById('clima-section');
      
      if (tabName === 'clima') {
        grid.style.display = 'none';
        climaSection.style.display = 'block';
      } else {
        grid.style.display = 'grid';
        climaSection.style.display = 'none';
        
        const filtro = condicionesMap[tabName] || [];
        document.querySelectorAll('.plaga-card').forEach(card => {
          const condiciones = card.dataset.condiciones.split(',');
          const matches = filtro.length === 0 || filtro.some(f => condiciones.includes(f));
          card.style.display = matches ? 'block' : 'none';
        });
      }
    });
  });

  // --- Flip cards ---
  document.querySelectorAll('.plaga-card').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('flipped');
    });
  });
</script>

<style is:global>
  .page-header {
    text-align: center;
    padding: 3rem 1rem 1rem;
    background: var(--color-sal);
  }

  .page-header h1 {
    font-size: 1.75rem;
    color: var(--color-aceituna);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-muted);
    font-size: 1rem;
  }

  .provincia-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .provincia-bar select {
    padding: 8px 16px;
    border: 2px solid var(--color-limon);
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    background: var(--color-white-surface);
    color: var(--color-aceituna);
    cursor: pointer;
  }

  .raif-status {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 12px;
    padding: 6px 12px;
    background: rgba(212,232,73,0.15);
    border-radius: 20px;
  }

  .raif-status span {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .plaga-estado-dinamico {
    margin-top: 10px;
    padding: 10px;
    background: rgba(255,255,255,0.9);
    border-radius: 6px;
    border-left: 3px solid var(--color-limon);
  }

  .plaga-estado-dinamico .estado-header {
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .plaga-estado-dinamico .estado-nivel.alto { color: #dc2626; }
  .plaga-estado-dinamico .estado-nivel.medio { color: #b45309; }
  .plaga-estado-dinamico .estado-nivel.bajo { color: #15803d; }

  .plaga-estado-dinamico .estado-detalle {
    font-size: 10px;
    color: var(--color-muted);
    margin-bottom: 3px;
  }

  .plaga-estado-dinamico .estado-consejo {
    font-size: 10px;
    padding: 4px 6px;
    background: rgba(212,232,73,0.2);
    border-radius: 4px;
  }

  .tabs-container {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    flex-wrap: wrap;
    background: var(--color-sal);
    border-bottom: 2px solid var(--color-border);
  }

  .tab {
    padding: 8px 16px;
    background: transparent;
    border: 2px solid var(--color-border);
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    color: var(--color-muted);
    transition: all 0.2s;
  }

  .tab:hover { color: var(--color-aceituna); }
  .tab.active { background: var(--color-limon); color: var(--color-aceituna); border-color: var(--color-limon); }

  .plagas-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    background: var(--color-sal);
  }

  @media (min-width: 768px) { .plagas-section { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .plagas-section { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (min-width: 1400px) { .plagas-section { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .plaga-card {
    perspective: 1000px;
    cursor: pointer;
    height: 320px;
  }

  .plaga-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s;
    transform-style: preserve-3d;
  }

  .plaga-card.flipped .plaga-inner { transform: rotateY(180deg); }

  .plaga-front, .plaga-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 0;
    padding: 1.25rem;
    background: var(--color-white-surface);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    display: flex;
    flex-direction: column;
  }

  .plaga-back {
    transform: rotateY(180deg);
    background: var(--color-white-surface);
  }

  .plaga-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .plaga-card h3 { font-size: 1.1rem; color: var(--color-aceituna); margin-bottom: 0.75rem; }

  .condiciones-box {
    background: var(--color-sal);
    border-radius: 4px;
    padding: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .condiciones-label {
    font-size: 0.7rem;
    color: var(--color-muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .condiciones-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .condicion-tag {
    font-size: 10px;
    padding: 3px 8px;
    background: var(--color-limon);
    color: var(--color-aceituna);
    border-radius: 3px;
    font-weight: 600;
  }

  .flip-hint {
    font-size: 0.7rem;
    color: var(--color-muted);
    text-align: center;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .tratamiento-text {
    font-size: 0.85rem;
    color: var(--color-aceituna);
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
  }

  .condiciones-footer {
    background: var(--color-sal);
    border-radius: 4px;
    padding: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .footer-label {
    font-size: 0.65rem;
    color: var(--color-muted);
    display: block;
    margin-bottom: 0.35rem;
  }

  .clima-section {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1rem;
    background: var(--color-sal);
  }

  .clima-hero {
    text-align: center;
    margin-bottom: 2rem;
  }

  .clima-hero h2 { font-size: 1.5rem; color: var(--color-aceituna); margin-bottom: 0.5rem; }
  .clima-hero p { color: var(--color-muted); }

  .clima-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) { .clima-grid { grid-template-columns: 1fr 1fr 1fr; } }

  .clima-card {
    background: var(--color-white-surface);
    border: 2px solid var(--color-border);
    border-radius: 6px;
