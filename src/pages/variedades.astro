---
import Layout from '../layouts/Layout.astro';
import ComparadorVariedades from '../components/ComparadorVariedades.astro';

const varieties = [
  {
    id: "cornicabra",
    nombre: "Cornicabra",
    origen: "Castilla-La Mancha",
    etiqueta: "RÚSTICA",
    categoria: ["alta-temp", "baja-temp", "baja-humedad", "baja-lluvia"],
    descripcion: "La más resistente al frío y sequía. Tolera hasta -10°C y 40°C. Ideal para clima continental.",
    notas_climaticas: "Tolera frío intenso (-10°C), calor extremo (40°C), y sequía severa. Sensible a humedad alta.",
    clima: { frio: 95, calor: 90, sequia: 95, humedad: 40, productividad: 75 },
    resistencia: { seca: "Muy alta", calor: "Muy alta", frio: "Muy alta", humedad: "Media" },
    rango: { frio: "-10°C", calor: "40°C", humedad: "<80%" },
    riesgos: "Vulnerable a enfermedades fúngicas con humedad persistente."
  },
  {
    id: "picual",
    nombre: "Picual",
    origen: "Jaén, Andalucía",
    etiqueta: "REINA",
    categoria: ["alta-temp", "alta-produccion"],
    descripcion: "50% del olivar español. Máxima productividad y resistente a mosca. Tolera hasta 40°C.",
    notas_climaticas: "Tolera frío hasta -7°C y calor hasta 40°C. Sensible a humedad alta y repilo.",
    clima: { frio: 80, calor: 85, sequia: 70, humedad: 35, productividad: 95 },
    resistencia: { seca: "Buena", calor: "Muy alta", frio: "Alta", humedad: "Baja" },
    rango: { frio: "-7°C", calor: "40°C", humedad: "<75%" },
    riesgos: "Sensible a Xylella, repilo y antracnosis en ambientes húmedos."
  },
  {
    id: "arbequina",
    nombre: "Arbequina",
    origen: "Lleida, Cataluña",
    etiqueta: "SUPERINTENSIVA",
    categoria: ["alta-produccion", "alta-humedad"],
    descripcion: "Ideal para riego y plantaciones intensivas. Resistente a Prays y hongos. Sensible al frío intenso.",
    notas_climaticas: "Tolera frío hasta -5°C, pero calor limitado a 35°C. Sensible a sequía y humedad alta.",
    clima: { frio: 70, calor: 50, sequia: 40, humedad: 35, productividad: 90 },
    resistencia: { seca: "Baja", calor: "Media", frio: "Muy alta", humedad: "Baja" },
    rango: { frio: "-5°C", calor: "35°C", humedad: "<70%" },
    riesgos: "Alta vulnerabilidad a hongos y estrés hídrico. Requiere manejo sanitario."
  },
  {
    id: "hojiblanca",
    nombre: "Hojiblanca",
    origen: "Málaga, Andalucía",
    etiqueta: "DOBLE APTITUD",
    categoria: ["alta-temp"],
    descripcion: "Aceite y mesa. Resistente al calor del sur. Tolera hasta 38°C con buena productividad.",
    notas_climaticas: "Tolera calor hasta 38°C. Resfriamiento medio (-3°C). Sensible a frío intenso y humedad.",
    clima: { frio: 55, calor: 80, sequia: 65, humedad: 50, productividad: 72 },
    resistencia: { seca: "Media-alta", calor: "Alta", frio: "Media", humedad: "Media" },
    rango: { frio: "-3°C", calor: "38°C", humedad: "<75%" },
    riesgos: "Sensibilidad media a heladas y enfermedades fúngicas."
  },
  {
    id: "manzanilla",
    nombre: "Manzanilla",
    origen: "Sevilla, Andalucía",
    etiqueta: "MESA",
    categoria: ["alta-humedad", "baja-lluvia"],
    descripcion: "La variedad de mesa por excelencia. Gran calibre. Necesita agua y sensible a condiciones extremas.",
    notas_climaticas: "Tolera calor hasta 38°C pero sensible a sequía (-30% productividad). Sensible a humedad.",
    clima: { frio: 45, calor: 65, sequia: 35, humedad: 25, productividad: 70 },
    resistencia: { seca: "Baja", calor: "Media-alta", frio: "Media", humedad: "Baja" },
    rango: { frio: "-3°C", calor: "38°C", humedad: "<70%" },
    riesgos: "Muy sensible a repilo, antracnosis y Xylella. Requiere clima seco."
  },
  {
    id: "empeltre",
    nombre: "Empeltre",
    origen: "Aragón",
    etiqueta: "CONTINENTAL",
    categoria: ["baja-temp", "baja-humedad", "baja-lluvia"],
    descripcion: "Tradicional del Valle del Ebro. Resistente a sequía y condiciones adversas. Tolera -5°C.",
    notas_climaticas: "Tolera frío hasta -5°C y calor hasta 38°C. Muy resistente a sequía (secano).",
    clima: { frio: 70, calor: 75, sequia: 85, humedad: 45, productividad: 65 },
    resistencia: { seca: "Muy alta", calor: "Media-alta", frio: "Media", humedad: "Media" },
    rango: { frio: "-5°C", calor: "38°C", humedad: "<75%" },
    riesgos: "Media sensibilidad a hongos en ambientes húmedos persistentes."
  }
];
---

<Layout title="Variedades de Olivo - olivaξ">
  <div class="var-container">
    <header class="var-header">
      <div class="var-header-content">
        <span class="var-label">🧬 LABORATORIO</span>
        <h1 class="var-title">Variedades de Olivo</h1>
        <p class="var-subtitle">Compara resistencia climática, plagas y enfermedades para elegir la mejor opción para tu zona</p>
        <div class="provincia-selector">
          <label for="select-provincia">📍 Filtrar por provincia:</label>
          <select id="select-provincia">
            <option value="">Todas las provincias</option>
            <option value="Jaén">Jaén</option>
            <option value="Córdoba">Córdoba</option>
            <option value="Sevilla">Sevilla</option>
            <option value="Granada">Granada</option>
            <option value="Málaga">Málaga</option>
            <option value="Badajoz">Badajoz</option>
            <option value="Toledo">Toledo</option>
            <option value="Ciudad Real">Ciudad Real</option>
            <option value="Almería">Almería</option>
            <option value="Huelva">Huelva</option>
          </select>
        </div>
        <div class="provincia-info-bar" id="provincia-info-bar" style="display:none"></div>
      </div>
    </header>

    <div class="var-filters">
      <button data-filter="all" class="filter-btn active">TODAS</button>
      <button data-filter="alta-temp" class="filter-btn">🔥 CALOR ALTO</button>
      <button data-filter="baja-temp" class="filter-btn">❄️ FRÍO</button>
      <button data-filter="alta-humedad" class="filter-btn">💧 HUMEDAD ALTA</button>
      <button data-filter="baja-humedad" class="filter-btn">🏜️ HUMEDAD BAJA</button>
      <button data-filter="baja-lluvia" class="filter-btn">🌧️ POCA LLUVIA</button>
      <button data-filter="alta-produccion" class="filter-btn">📈 PRODUCCIÓN</button>
    </div>

    <div class="var-grid">
      {varieties.map((v) => (
        <div class="var-card" data-categoria={v.categoria.join(",")} data-id={v.id}>
          <div class="var-card-header">
            <span class="var-badge">{v.etiqueta}</span>
          </div>
          
          <h2 class="var-name">🫒 {v.nombre}</h2>
          <p class="var-origen">📍 {v.origen}</p>
          <p class="var-desc">{v.descripcion}</p>
          
          <div class="var-rangos">
            <div class="rango-item">
              <span class="rango-icon">❄️</span>
              <span class="rango-label">Frío</span>
              <span class="rango-value">{v.rango.frio}</span>
            </div>
            <div class="rango-item">
              <span class="rango-icon">🔥</span>
              <span class="rango-label">Calor</span>
              <span class="rango-value">{v.rango.calor}</span>
            </div>
            <div class="rango-item">
              <span class="rango-icon">💧</span>
              <span class="rango-label">Humedad</span>
              <span class="rango-value">{v.rango.humedad}</span>
            </div>
          </div>

          <div class="var-bars">
            <div class="var-bar-row">
              <span class="var-bar-label">❄️ FRÍO</span>
              <div class="var-bar-bg"><div class="var-bar-fill" style={`width: ${v.clima.frio}%`}></div></div>
              <span class="var-bar-pct">{v.clima.frio}%</span>
            </div>
            <div class="var-bar-row">
              <span class="var-bar-label">🔥 CALOR</span>
              <div class="var-bar-bg"><div class="var-bar-fill calor" style={`width: ${v.clima.calor}%`}></div></div>
              <span class="var-bar-pct">{v.clima.calor}%</span>
            </div>
            <div class="var-bar-row">
              <span class="var-bar-label">🏜️ SEQUÍA</span>
              <div class="var-bar-bg"><div class="var-bar-fill sequia" style={`width: ${v.clima.sequia}%`}></div></div>
              <span class="var-bar-pct">{v.clima.sequia}%</span>
            </div>
            <div class="var-bar-row">
              <span class="var-bar-label">💧 HUMEDAD</span>
              <div class="var-bar-bg"><div class="var-bar-fill humedad" style={`width: ${v.clima.humedad}%`}></div></div>
              <span class="var-bar-pct">{v.clima.humedad}%</span>
            </div>
            <div class="var-bar-row">
              <span class="var-bar-label">📊 PROD.</span>
              <div class="var-bar-bg"><div class="var-bar-fill prod" style={`width: ${v.clima.productividad}%`}></div></div>
              <span class="var-bar-pct">{v.clima.productividad}%</span>
            </div>
          </div>

          <div class="var-resist">
            <h4>RESISTENCIAS</h4>
            <div class="res-grid">
              <span class="res-tag">{v.resistencia.frio} ❄️</span>
              <span class="res-tag">{v.resistencia.calor} 🔥</span>
              <span class="res-tag">{v.resistencia.seca} 🏜️</span>
              <span class="res-tag">{v.resistencia.humedad} 💧</span>
            </div>
          </div>

          <div class="var-riesgos">
            <h4>⚠️ RIESGOS</h4>
            <p>{v.riesgos}</p>
          </div>

          <div class="dynamic-riesgo" style="margin-bottom: 8px;">
            <span class="dynamic-riesgo-badge" data-variedad={v.id} style="display:none">-</span>
            <div class="dynamic-riesgo-detail" style="display:none;margin-top:4px;font-size:9px;color:var(--color-muted)"></div>
          </div>

          <button class="var-btn" data-nombre={v.nombre}>COMPARAR</button>
        </div>
      ))}
    </div>

    <div class="sticky-bar" id="sticky-bar" style="display: none;">
      Selecciona otra variedad para comparar
    </div>

    <div class="compare-panel" id="compare-panel" style="display: none;">
      <button class="clear-btn" id="clear-btn">× LIMPIAR</button>
      <h3 class="compare-title" id="compare-title"></h3>
      <table class="compare-table">
        <thead>
          <tr>
            <th>MÉTRICA</th>
            <th id="th-a"></th>
            <th id="th-b"></th>
          </tr>
        </thead>
        <tbody id="compare-tbody"></tbody>
      </table>
    </div>
  </div>
</Layout>

<style is:global>
  :global(body) { overflow-x: hidden; }

  .var-container {
    background: var(--color-sal);
    min-height: 100vh;
    padding-top: 10px;
  }

  .var-header {
    background: var(--color-aceituna);
    padding: 2rem 1.5rem 2rem;
    border-bottom: 4px solid var(--color-limon);
    position: relative;
    overflow: hidden;
    margin-top: 30px;
  }

  .var-header::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(212, 232, 73, 0.1));
    clip-path: polygon(30% 0, 100% 0, 100% 100%, 0% 100%);
  }

  .var-header-content {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .var-label {
    display: inline-block;
    background: var(--color-limon);
    color: var(--color-aceituna);
    font-size: 11px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 2px;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  .var-title {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    color: var(--color-sal);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .var-subtitle {
    color: rgba(247, 244, 238, 0.7);
    font-size: 14px;
    margin: 1rem 0 0;
    max-width: 500px;
    line-height: 1.5;
  }

  .provincia-selector {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .provincia-selector label {
    color: rgba(247, 244, 238, 0.8);
    font-size: 13px;
    font-weight: 600;
  }

  .provincia-selector select {
    background: rgba(255,255,255,0.9);
    border: 2px solid var(--color-limon);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-aceituna);
    cursor: pointer;
  }

  .provincia-info-bar {
    margin-top: 0.75rem;
    padding: 8px 12px;
    background: rgba(212,232,73,0.2);
    border-radius: 6px;
    font-size: 12px;
    color: var(--color-sal);
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .var-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    padding: 1.5rem 1rem;
    background: var(--color-aceituna);
    border-bottom: 2px solid var(--color-limon);
  }

  .filter-btn {
    padding: 8px 16px;
    border: 2px solid var(--color-limon);
    border-radius: 0;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    background: transparent;
    color: var(--color-sal);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.15s;
  }

  .filter-btn:hover { background: rgba(212, 232, 73, 0.2); }

  .filter-btn.active {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  .var-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
    padding: 24px 16px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .var-card {
    background: var(--color-white-surface);
    border: 3px solid var(--color-border);
    border-radius: 0;
    padding: 20px;
    box-shadow: 6px 6px 0 var(--color-border);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .var-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--color-border);
  }

  .var-card-header { display: flex; justify-content: flex-end; margin-bottom: 8px; }

  .var-badge {
    background: var(--color-aceituna);
    color: var(--color-limon);
    font-size: 10px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 0;
    letter-spacing: 0.5px;
  }

  .var-name {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--color-aceituna);
    margin: 8px 0 4px;
  }

  .var-origen {
    font-size: 12px;
    color: var(--color-muted);
    margin: 0 0 12px;
    font-weight: 600;
  }

  .var-desc {
    font-size: 13px;
    color: var(--color-aceituna);
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .var-rangos {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    padding: 12px;
    background: var(--color-sal);
    border: 2px solid var(--color-border);
  }

  .rango-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .rango-icon { font-size: 16px; }

  .rango-label {
    font-size: 9px;
    color: var(--color-muted);
    font-weight: 700;
    text-transform: uppercase;
  }

  .rango-value {
    font-size: 11px;
    color: var(--color-aceituna);
    font-weight: 800;
  }

  .var-bars {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
  }

  .var-bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .var-bar-label {
    font-size: 10px;
    color: var(--color-muted);
    font-weight: 700;
    width: 70px;
    flex-shrink: 0;
  }

  .var-bar-bg {
    flex: 1;
    height: 8px;
    background: var(--color-sal);
    border: 1px solid var(--color-border);
  }

  .var-bar-fill {
    height: 100%;
    background: #06B6D4;
    transition: width 0.3s;
  }

  .var-bar-fill.calor { background: #F59E0B; }
  .var-bar-fill.sequia { background: var(--color-limon); }
  .var-bar-fill.humedad { background: #8B5CF6; }
  .var-bar-fill.prod { background: #3B82F6; }

  .var-bar-pct {
    font-size: 11px;
    font-weight: 800;
    color: var(--color-aceituna);
    width: 35px;
    text-align: right;
  }

  .var-resist { margin-bottom: 12px; }

  .var-resist h4 {
    font-size: 10px;
    font-weight: 800;
    color: var(--color-muted);
    margin: 0 0 8px;
    letter-spacing: 0.5px;
  }

  .res-grid { display: flex; flex-wrap: wrap; gap: 6px; }

  .res-tag {
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    background: var(--color-sal);
    border: 1px solid var(--color-border);
    color: var(--color-aceituna);
  }

  .var-riesgos {
    margin-bottom: 16px;
    padding: 10px;
    background: rgba(239, 68, 68, 0.08);
    border-left: 3px solid #EF4444;
  }

  .var-riesgos h4 {
    font-size: 10px;
    font-weight: 800;
    color: #EF4444;
    margin: 0 0 4px;
  }

  .var-riesgos p {
    font-size: 11px;
    color: var(--color-aceituna);
    margin: 0;
    line-height: 1.4;
  }

  .var-btn {
    width: 100%;
    padding: 12px;
    background: var(--color-aceituna);
    color: var(--color-white);
    font-size: 12px;
    font-weight: 800;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.15s;
  }

  .var-btn:hover {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  .var-btn.selected {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  .dynamic-riesgo-badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
  }

  .detail-tag {
    display: inline-block;
    padding: 4px 8px;
    margin: 2px;
    background: var(--color-limon);
    color: var(--color-aceituna);
    font-size: 9px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.15s;
  }

  .detail-tag:hover {
    background: var(--color-aceituna);
    color: var(--color-limon);
  }

  .sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-aceituna);
    color: var(--color-limon);
    padding: 14px 20px;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
    z-index: 1000;
    border-top: 2px solid var(--color-limon);
  }

  .compare-panel {
    border: 3px solid var(--color-border);
    border-radius: 0;
    background: var(--color-white-surface);
    padding: 24px;
    margin: 32px auto;
    max-width: 900px;
    box-shadow: 8px 8px 0 var(--color-border);
  }

  .clear-btn {
    background: #EF4444;
    color: var(--color-white);
    border: none;
    font-size: 11px;
    font-weight: 800;
    padding: 8px 16px;
    cursor: pointer;
    float: right;
    text-transform: uppercase;
  }

  .clear-btn:hover { background: #DC2626; }

  .compare-title {
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: var(--color-aceituna);
    margin: 0 0 20px;
    padding-right: 100px;
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
  }

  .compare-table th {
    text-align: left;
    padding: 12px 8px;
    font-size: 11px;
    font-weight: 800;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--color-border);
  }

  .compare-table th:nth-child(2),
  .compare-table th:nth-child(3) {
    text-align: center;
    color: var(--color-aceituna);
    font-size: 13px;
  }

  .compare-table td {
    padding: 12px 8px;
    font-size: 12px;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-sal);
    text-align: center;
  }

  .compare-table td:first-child {
    text-align: left;
    font-weight: 700;
    color: var(--color-aceituna);
  }

  .compare-table td.winner { background: var(--color-limon); }

  .compare-table .tag-resalta { 
    background: var(--color-limon); 
    color: var(--color-aceituna);
    padding: 4px 8px;
    font-weight: 700;
    font-size: 10px;
  }

  @media (max-width: 768px) {
    .var-grid { grid-template-columns: 1fr; padding: 16px 12px; gap: 12px; }
    .var-card { padding: 14px; box-shadow: 4px 4px 0 var(--color-border); }
    .var-header { padding: 1.5rem 1rem; margin-top: 50px; }
    .var-title { font-size: 1.5rem; }
    .var-subtitle { font-size: 0.85rem; }
    .var-filters { padding: 1rem 0.5rem; gap: 6px; }
    .filter-btn { padding: 6px 10px; font-size: 10px; }
    .compare-panel { padding: 1rem; margin: 1rem; }
    .compare-table { font-size: 11px; }
    .compare-title { font-size: 1rem; padding-right: 0; }
    .clear-btn { position: static; margin-bottom: 1rem; }
  }
</style>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, '') || 'http://localhost:3000';
  const provinciaSelect = document.getElementById('select-provincia');
  const provinciaInfoBar = document.getElementById('provincia-info-bar');
  const VARIEDADES_KEYS = ['cornicabra', 'picual', 'arbequina', 'hojiblanca', 'manzanilla', 'empeltre'];
  let datosProvincia = null;
  let riesgosVariedad = {};

  const savedProvincia = localStorage.getItem('olivaxi_provincia');
  if (savedProvincia && provinciaSelect) {
    provinciaSelect.value = savedProvincia;
    cargarDatosProvincia(savedProvincia);
  }

  async function cargarDatosProvincia(provincia) {
    if (!provincia) {
      datosProvincia = null;
      riesgosVariedad = {};
      if (provinciaInfoBar) provinciaInfoBar.style.display = 'none';
      actualizarRiesgos();
      return;
    }
    
    try {
      const controller = new AbortController();
      const t = setTimeout(() => controller.abort(), 5000);
      const res = await fetch(`${API_BASE}/api/clima/dashboard?provincia=${encodeURIComponent(provincia)}`, { signal: controller.signal });
      clearTimeout(t);
      if (!res.ok) return;
      const d = await res.json();
      
      if (d.ok) {
        datosProvincia = d;
        riesgosVariedad = d.riesgos?.variedad || {};
        
        if (provinciaInfoBar) {
          provinciaInfoBar.innerHTML = `
            <span>🌡️ ${d.clima.temperatura}°C</span>
            <span>💧 ${d.clima.humedad}%</span>
            <span>🫒 ${d.provinciaInfo.variedadPredominante}</span>
            <span>🪨 ${d.provinciaInfo.tipoSuelo}</span>
            <span>⚠️ ${d.provinciaInfo.epocaCritica ? 'Época crítica: '+d.provinciaInfo.epocaCritica : ''}</span>
          `;
          provinciaInfoBar.style.display = 'flex';
        }
        
        actualizarRiesgos();
      }
    } catch (e) {
      console.error('Error loading province data:', e);
    }
  }

  function actualizarRiesgos() {
    VARIEDADES_KEYS.forEach(v => {
      const card = Array.from(document.querySelectorAll('.var-card')).find(c => c.dataset.id === v);
      if (!card) return;
      
      const badge = card.querySelector('.dynamic-riesgo-badge');
      const detailDiv = card.querySelector('.dynamic-riesgo-detail');
      
      if (badge && riesgosVariedad[v]) {
        const nivel = riesgosVariedad[v].nivel || 'bajo';
        const score = riesgosVariedad[v].score || 0;
        const detalle = riesgosVariedad[v].detalle || [];
        
        badge.textContent = `${nivel.toUpperCase()} (${score}/10)`;
        badge.className = `dynamic-riesgo-badge riesgo-${nivel}`;
        badge.style.display = 'inline-block';
        
        if (detailDiv && detalle.length > 0) {
          detailDiv.innerHTML = detalle.slice(0, 2).map(d => `<a href="/consejero?pregunta=${encodeURIComponent('¿Cómo tratar ' + d + '?')}" class="detail-tag">💬 ${d}</a>`).join('');
          detailDiv.style.display = 'block';
        }
      }
    });
  }

  provinciaSelect?.addEventListener('change', () => {
    const prov = provinciaSelect.value;
    localStorage.setItem('olivaxi_provincia', prov);
    cargarDatosProvincia(prov);
  });

  window.addEventListener('olivaxi-state-change', (e) => {
    if (e.detail?.provincia && provinciaSelect) {
      provinciaSelect.value = e.detail.provincia;
      cargarDatosProvincia(e.detail.provincia);
    }
  });

  const seleccionadas = [];

  document.querySelectorAll('.var-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.closest('.var-card')?.dataset.id;
      const nombre = btn.dataset.nombre;
      const idx = seleccionadas.indexOf(id);
      
      if (idx > -1) {
        seleccionadas.splice(idx, 1);
        btn.textContent = 'COMPARAR';
        btn.classList.remove('selected');
      } else if (seleccionadas.length < 2) {
        seleccionadas.push(id);
        btn.textContent = '✓ SELECCIONADA';
        btn.classList.add('selected');
      } else {
        seleccionadas[1] = id;
        document.querySelectorAll('.var-btn').forEach(b => {
          if (seleccionadas.includes(b.closest('.var-card')?.dataset.id)) {
            b.textContent = '✓ SELECCIONADA';
            b.classList.add('selected');
          } else {
            b.textContent = 'COMPARAR';
            b.classList.remove('selected');
          }
        });
      }
      
      actualizarUI();
    });
  });

  function getCardData(id) {
    const card = Array.from(document.querySelectorAll('.var-card')).find(c => c.dataset.id === id);
    if (!card) return null;
    
    const btn = card.querySelector('.var-btn');
    const name = btn?.dataset.nombre;
    const bars = card.querySelectorAll('.var-bar-row');
    
    return {
      nombre: name,
      frio: parseInt(bars[0]?.querySelector('.var-bar-pct')?.textContent || '0'),
      calor: parseInt(bars[1]?.querySelector('.var-bar-pct')?.textContent || '0'),
      sequia: parseInt(bars[2]?.querySelector('.var-bar-pct')?.textContent || '0'),
      humedad: parseInt(bars[3]?.querySelector('.var-bar-pct')?.textContent || '0'),
      productividad: parseInt(bars[4]?.querySelector('.var-bar-pct')?.textContent || '0'),
    };
  }

  document.getElementById('clear-btn')?.addEventListener('click', () => {
    seleccionadas.length = 0;
    document.querySelectorAll('.var-btn').forEach(b => {
      b.textContent = 'COMPARAR';
      b.classList.remove('selected');
    });
    actualizarUI();
  });

  function actualizarUI() {
    const stickyBar = document.getElementById('sticky-bar');
    const comparePanel = document.getElementById('compare-panel');

    if (seleccionadas.length === 1) {
      stickyBar.style.display = 'block';
      comparePanel.style.display = 'none';
    } else if (seleccionadas.length === 2) {
      stickyBar.style.display = 'none';
      comparePanel.style.display = 'block';
      renderComparacion();
    } else {
      stickyBar.style.display = 'none';
      comparePanel.style.display = 'none';
    }
  }

  function renderComparacion() {
    const a = getCardData(seleccionadas[0]);
    const b = getCardData(seleccionadas[1]);

    document.getElementById('compare-title').textContent = `COMPARACIÓN: ${a.nombre} vs ${b.nombre}`;
    document.getElementById('th-a').textContent = a.nombre;
    document.getElementById('th-b').textContent = b.nombre;

    const metrics = [
      { key: 'frio', label: '❄️ FRÍO', type: 'bar' },
      { key: 'calor', label: '🔥 CALOR', type: 'bar' },
      { key: 'sequia', label: '🏜️ SEQUÍA', type: 'bar' },
      { key: 'humedad', label: '💧 HUMEDAD', type: 'bar' },
      { key: 'productividad', label: '📊 PRODUCCIÓN', type: 'bar' }
    ];

    const tbody = document.getElementById('compare-tbody');
    tbody.innerHTML = metrics.map(m => {
      const valA = a[m.key];
      const valB = b[m.key];
      
      let winnerA = '', winnerB = '';
      if (valA > valB) winnerA = 'winner';
      if (valB > valA) winnerB = 'winner';

      const colorClass = m.key === 'frio' ? '' : m.key;

      return `<tr>
        <td>${m.label}</td>
        <td class="${winnerA}">
          <div class="bar-container"><div class="bar-bg" style="width:80px;height:8px;background:#F7F4EE;border:1px solid #1C1C1C;"><div class="${winnerA ? 'winner-fill' : colorClass + '-fill'}" style="width:${valA}%;height:100%;background:${getColor(m.key, valA)}"></div></div><span style="margin-left:8px;font-weight:700;">${valA}%</span></div>
        </td>
        <td class="${winnerB}">
          <div class="bar-container"><div class="bar-bg" style="width:80px;height:8px;background:#F7F4EE;border:1px solid #1C1C1C;"><div class="${winnerB ? 'winner-fill' : colorClass + '-fill'}" style="width:${valB}%;height:100%;background:${getColor(m.key, valB)}"></div></div><span style="margin-left:8px;font-weight:700;">${valB}%</span></div>
        </td>
      </tr>`;
    }).join('');
  }

  function getColor(key, val) {
    if (key === 'frio') return val > 70 ? '#06B6D4' : val > 50 ? '#06B6D4' : '#06B6D4';
    if (key === 'calor') return val > 70 ? '#F59E0B' : val > 50 ? '#F59E0B' : '#F59E0B';
    if (key === 'sequia') return val > 70 ? '#D4E849' : val > 50 ? '#D4E849' : '#D4E849';
    if (key === 'humedad') return val > 50 ? '#8B5CF6' : '#8B5CF6';
    if (key === 'productividad') return val > 80 ? '#3B82F6' : '#3B82F6';
    return '#1C1C1C';
  }

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const filter = btn.dataset.filter;
      document.querySelectorAll('.var-card').forEach(card => {
        if (filter === 'all') {
          card.style.display = '';
        } else {
          const categorias = card.dataset.categoria || '';
          const tieneCategoria = categorias.includes(filter);
          card.style.display = tieneCategoria ? '' : 'none';
        }
      });
    });
  });

  // Escuchar cambios de estado desde otras páginas (index, chat)
  window.addEventListener('olivaxi-state-change', (e) => {
    console.log('Variedades recibió cambio:', e.detail);
  });
</script>