---
import Layout from '../layouts/Layout.astro';
import ChatConsejero from '../components/ChatConsejero.jsx';
---

<Layout title="Consejero | olivaξ">
  <main class="main-container">
    <div class="chat-wrapper">
      <ChatConsejero client:load />
    </div>
  </main>
</Layout>

<style>
  .main-container {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: #f5f0e8;
    overflow: hidden;
    position: relative;
    z-index: 1;
    padding-top: 48px;
  }

  .chat-wrapper {
    flex: 1;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    padding: 0;
    background: transparent;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 900px) {
    .main-container {
      padding-top: 56px;
    }
  }

  body > footer {
    display: none;
  }
</style>
