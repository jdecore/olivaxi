---
import Layout from '../layouts/Layout.astro';
import ChatConsejero from '../components/ChatConsejero.jsx';
---

<Layout title="Consejero | olivaξ">
  <main class="main-container">
    <div class="chat-wrapper">
      <ChatConsejero client:visible />
    </div>
  </main>
</Layout>

<style is:global>
  .main-container {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-sal);
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  main { padding-top: 0 !important; }

  .chat-wrapper {
    flex: 1;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    padding: 0;
    background: transparent;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  footer { display: none !important; }
  .navbar { z-index: 1000 !important; }
</style>
