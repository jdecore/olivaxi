---
import Layout from '../layouts/Layout.astro';
import ChatConsejero from '../components/ChatConsejero.jsx';
---

<Layout title="Consejero | olivaξ">
  <main class="main-container">
    <div class="chat-wrapper">
      <ChatConsejero client:visible />
    </div>
  </main>
</Layout>

<style is:global>
  .main-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #f5efe8;
    padding-bottom: 40px;
  }

  .chat-wrapper {
    flex: 1;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    padding: 70px 16px 16px;
    min-height: 100vh;
    background: transparent;
  }

  footer {
    display: none !important;
  }
</style>
