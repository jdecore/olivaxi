---
import Layout from '../layouts/Layout.astro';
import ChatConsejero from '../components/ChatConsejero.jsx';
---

<Layout title="Consejero | olivaξ">
  <main class="main-container">
    <div class="chat-wrapper">
      <ChatConsejero client:visible />
    </div>
  </main>
</Layout>

<style is:global>
  .main-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-sal);
    padding-bottom: 40px;
  }

  .chat-wrapper {
    flex: 1;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    padding: 90px 16px 16px;
    min-height: 100vh;
    border: 3px solid var(--color-border);
    border-radius: 0;
    box-shadow: 6px 6px 0 var(--color-border);
  }

  footer {
    display: none !important;
  }
</style>
