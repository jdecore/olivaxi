---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Agua y Suelos - olivaξ">
  <style is:global>
    .agua-hero {
      background: var(--color-bg);
      color: var(--color-aceituna);
      padding: 100px 1rem 2rem;
      text-align: center;
    }

    .agua-hero-badge {
      display: inline-block;
      background: var(--color-limon);
      color: var(--color-aceituna);
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .agua-hero h1 {
      font-family: 'Literata', Georgia, serif;
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      color: var(--color-aceituna);
    }

    .agua-hero p {
      color: var(--color-muted);
      max-width: 600px;
      margin: 0 auto 1.5rem;
      font-size: 1rem;
    }

    .provincia-bar-agua {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .provincia-bar-agua select {
      padding: 10px 20px;
      border: 2px solid var(--color-limon);
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      background: var(--color-white-surface);
      color: var(--color-aceituna);
      cursor: pointer;
    }

    .suelo-datos {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      width: 100%;
      max-width: 600px;
    }
    .suelo-datos.hidden { display: none; }
    
    /* Skeleton loading: más suave y visual */
    .suelo-datos.loading .suelo-dato {
      background: linear-gradient(120deg, #f5f3ef 20%, #efebe5 35%, #f5f3ef 50%);
      background-size: 220% 100%;
      animation: skeletonShimmer 1.8s ease-in-out infinite;
    }
    .suelo-datos.loading .suelo-dato:nth-child(1) { animation-delay: 0s; }
    .suelo-datos.loading .suelo-dato:nth-child(2) { animation-delay: 0.15s; }
    .suelo-datos.loading .suelo-dato:nth-child(3) { animation-delay: 0.3s; }
    .suelo-datos.loading .suelo-dato:nth-child(4) { animation-delay: 0.45s; }
    @keyframes skeletonShimmer {
      0% { background-position: 0% 50%; }
      100% { background-position: 100% 50%; }
    }
    .suelo-datos.loading .suelo-dato .icon,
    .suelo-datos.loading .suelo-dato .value,
    .suelo-datos.loading .suelo-dato .label,
    .suelo-datos.loading .suelo-dato .status {
      visibility: hidden;
    }
    .suelo-datos.loading .suelo-dato::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 60%;
      height: 8px;
      background: rgba(180, 180, 180, 0.35);
      border-radius: 4px;
      transform: translate(-50%, -50%);
    }
    .suelo-datos.loading .suelo-dato::after {
      content: '';
      position: absolute;
      top: 65%;
      left: 50%;
      width: 40%;
      height: 6px;
      background: rgba(160, 160, 160, 0.28);
      border-radius: 3px;
      transform: translate(-50%, -50%);
    }

    .suelo-dato {
      background: var(--color-white-surface);
      border: 1px solid var(--color-border);
      padding: 14px 12px;
      border-radius: 10px;
      text-align: center;
      transition: transform .35s cubic-bezier(.22,1,.36,1), box-shadow .35s ease, border-color .35s ease, background-color .35s ease;
      position: relative;
      overflow: hidden;
      will-change: transform;
    }
    .suelo-datos.animated .suelo-dato {
      animation: kpiIn .72s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .suelo-datos.animated .suelo-dato:nth-child(1) { animation-delay: .04s; }
    .suelo-datos.animated .suelo-dato:nth-child(2) { animation-delay: .10s; }
    .suelo-datos.animated .suelo-dato:nth-child(3) { animation-delay: .16s; }
    .suelo-datos.animated .suelo-dato:nth-child(4) { animation-delay: .22s; }
    @keyframes kpiIn {
      0% { opacity: 0; transform: translateY(18px) scale(0.97); filter: blur(2px); }
      65% { opacity: 1; transform: translateY(-2px) scale(1.01); filter: blur(0); }
      100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
    }
    .suelo-dato:hover {
      transform: translateY(-3px);
      box-shadow: 0 4px 12px rgba(0,0,0,.06);
      border-color: rgba(180,180,180,.5);
    }

    .suelo-dato .icon { font-size: 1.4rem; margin-bottom: 6px; }
    .suelo-dato .value {
      font-size: 1.3rem;
      font-weight: 700;
      transition: color .25s ease, opacity .25s ease, transform .25s ease;
    }
    .suelo-dato .value.ok { color: #16a34a; }
    .suelo-dato .value.warning { color: #d97706; }
    .suelo-dato .value.danger { color: #dc2626; }
    .suelo-dato .label { font-size: 0.75rem; color: var(--color-muted); margin-top: 6px; }
    .suelo-dato .status {
      font-size: 0.7rem;
      margin-top: 6px;
      font-weight: 600;
      transition: color .25s ease, opacity .25s ease, transform .25s ease;
    }
    .suelo-dato .status.ok { color: #16a34a; }
    .suelo-dato .status.warning { color: #d97706; }
    .suelo-dato .status.danger { color: #dc2626; }
    .suelo-dato .value.updating,
    .suelo-dato .status.updating {
      opacity: 0.35;
      transform: translateY(3px);
    }
    .suelo-dato.updated {
      animation: dataUpdate .65s cubic-bezier(.22,1,.36,1);
    }
    @keyframes dataUpdate {
      0% { background-color: rgba(212,232,73,0.30); box-shadow: 0 0 0 rgba(212,232,73,0); }
      40% { background-color: rgba(212,232,73,0.18); box-shadow: 0 6px 18px rgba(212,232,73,0.22); }
      100% { background-color: var(--color-white-surface); }
    }
    @media (prefers-reduced-motion: reduce) {
      .suelo-datos.loading .suelo-dato::after,
      .suelo-datos.loading .suelo-dato::before,
      .suelo-datos.animated .suelo-dato { animation: none !important; }
      .suelo-dato { transition: none !important; }
      .suelo-dato .value,
      .suelo-dato .status { transition: none !important; }
      .suelo-dato.updated { animation: none !important; }
    }

    @media(max-width: 600px) {
      .suelo-datos { grid-template-columns: repeat(2, 1fr); }
      .suelo-dato { padding: 10px 8px; }
      .suelo-dato .value { font-size: 1rem; }
      .suelo-dato .label { font-size: 0.8rem; }
      .agua-hero { padding: 80px 1rem 1.5rem; }
      .agua-hero h1 { font-size: 1.5rem; }
      .agua-hero p { font-size: 0.9rem; }
      .agua-grid { grid-template-columns: 1fr; }
      .agua-card { padding: 1rem; }
      .agua-card h2 { font-size: 1.1rem; }
    }

    .area-section {
      padding: 2rem 1rem;
      margin-bottom: 1rem;
      transition: all 0.4s ease;
    }
    
    .area-section.agua { background: linear-gradient(135deg, #F5FAFC 0%, #EBF4F7 100%); }
    .area-section.agua.selected { background: linear-gradient(135deg, #D4E8F0 0%, #C5DDE9 100%); }
    
    .area-section.suelo { background: linear-gradient(135deg, #FAF7F2 0%, #F3EDE3 100%); }
    .area-section.suelo.selected { background: linear-gradient(135deg, #E8DDD0 0%, #DDD2C4 100%); }
    
    .area-section.conservacion { background: linear-gradient(135deg, #F6F9F4 0%, #EDF2EB 100%); }
    .area-section.conservacion.selected { background: linear-gradient(135deg, #D8E5D4 0%, #CADBC6 100%); }

    .area-container {
      max-width: 1000px;
      margin: 0 auto;
    }

    .area-header {
      text-align: center;
      margin-bottom: 1.5rem;
      cursor: pointer;
    }
    
    .area-header:hover .area-title {
      transform: scale(1.02);
    }
    
    .area-title {
      font-family: 'Literata', Georgia, serif;
      font-size: 1.5rem;
      color: var(--color-aceituna);
      margin-bottom: 0.5rem;
      transition: transform 0.3s ease;
    }
    
    .area-title.agua { color: #2A6B7C; }
    .area-title.suelo { color: #6B5344; }
    .area-title.conservacion { color: #3D5A3D; }
    
    .area-subtitle {
      color: var(--color-muted);
      font-size: 0.9rem;
    }

    .carousel-wrapper {
      position: relative;
      max-width: 800px;
      margin: 0 auto;
    }

    .carousel-track {
      display: flex;
      transition: transform 0.4s ease;
    }

    .carousel-slide {
      flex: 0 0 100%;
      padding: 0 50px;
      box-sizing: border-box;
    }

    .carousel-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--color-white-surface);
      border: 2px solid var(--color-border);
      cursor: pointer;
      font-size: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .carousel-nav:hover { 
      background: var(--color-limon); 
      border-color: var(--color-limon);
    }
    
    .carousel-nav.prev { left: 0; }
    .carousel-nav.next { right: 0; }
    
    .carousel-nav.disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }
    
    .carousel-nav.disabled:hover {
      background: var(--color-white-surface);
      border-color: var(--color-border);
    }

    .carousel-dots { 
      display: flex; 
      justify-content: center; 
      gap: 8px; 
      margin-top: 16px; 
    }
    
    .carousel-dot { 
      width: 10px; 
      height: 10px; 
      border-radius: 50%; 
      background: rgba(0,0,0,0.15); 
      cursor: pointer; 
      transition: all 0.2s; 
      border: none;
    }
    
    .carousel-dot:hover { background: rgba(0,0,0,0.3); }
    .carousel-dot.active { 
      background: var(--color-aceituna); 
      transform: scale(1.2); 
    }
    
    .area-section.agua .carousel-dot.active { background: #1A4A5E; }
    .area-section.suelo .carousel-dot.active { background: #5C4A2E; }
    .area-section.conservacion .carousel-dot.active { background: #2E4A2E; }

    .agua-card {
      background: var(--color-white-surface);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 1.5rem;
    }

    .agua-card h2 {
      font-size: 1.1rem;
      color: var(--color-aceituna);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .agua-card p {
      color: var(--color-muted);
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .agua-list { list-style: none; padding: 0; margin: 0.75rem 0; }
    .agua-list li { padding: 6px 0; border-bottom: 1px solid #eee; color: var(--color-muted); font-size: 0.85rem; }
    .agua-list li:last-child { border-bottom: none; }

    .agua-stat {
      display: inline-block;
      background: var(--color-limon);
      color: var(--color-aceituna);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 700;
      margin-right: 6px;
    }

    .agua-tip {
      background: rgba(212,232,73,0.2);
      border: 1px solid var(--color-limon);
      border-radius: 6px;
      padding: 0.75rem;
      margin-top: 0.75rem;
    }

    .agua-tip-title { font-weight: 700; color: var(--color-aceituna); margin-bottom: 0.25rem; font-size: 0.85rem; }
    .agua-tip p { font-size: 0.8rem; margin: 0; }

    .agua-full { grid-column: 1 / -1; }

    .agua-plan {
      background: var(--color-white-surface);
      border: 2px solid var(--color-limon);
      border-radius: 8px;
      padding: 1.5rem;
      margin: 0 auto 2rem;
      max-width: 600px;
    }
    .agua-plan-title { font-weight: 700; color: var(--color-aceituna); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 8px; }
    .agua-plan-text { font-size: 0.95rem; color: var(--color-muted); }
    .agua-plan-btn { display: inline-block; margin-top: 12px; padding: 10px 16px; background: var(--color-limon); color: var(--color-aceituna); border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 0.85rem; }

    .alert-strip-wrap { max-width: 800px; margin: 0 auto 1.5rem; padding: 0 1rem; }
    .alert-strip { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 12px 16px; border-radius: 8px; font-size: 14px; font-weight: 600; gap: 12px; background: rgba(239,68,68,0.1); border: 2px solid #ef4444; color: #991b1b; flex-wrap: wrap; }
    .alert-strip-content { display: flex; align-items: center; gap: 10px; flex: 1; min-width: 200px; }
    .alert-strip-icon { font-size: 18px; }
    .alert-strip-text { font-size: 13px; }
    .alert-strip-btn { padding: 8px 16px; background: #ef4444; color: white; border-radius: 6px; font-size: 12px; text-decoration: none; white-space: nowrap; border: none; cursor: pointer; }
    .alert-strip-panel { display: none; margin-top: 12px; padding: 16px; background: #fff; border: 1px solid #ef4444; border-radius: 8px; }
    .alert-strip-panel.open { display: block; }
    .alert-option { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid #eee; }
    .alert-option:last-child { border-bottom: none; }
    .alert-option-icon { font-size: 20px; }
    .alert-option-text strong { display: block; font-size: 13px; }
    .alert-option-text span { font-size: 11px; color: #666; }
  </style>

  <section class="agua-hero">
    <div class="agua-hero-badge">📡 Datos en tiempo real · Open-Meteo</div>
    <h1>💧 Agua y Suelos</h1>
    <p>Gestión eficiente del agua y cuidado del suelo para olivares resilientes al cambio climático</p>
    <div class="provincia-bar-agua">
      <select id="provincia-select-agua" class="provincia-select">
        <option value="">Selecciona provincia para ver datos en tiempo real...</option>
        <option value="Jaén">Jaén</option>
        <option value="Córdoba">Córdoba</option>
        <option value="Sevilla">Sevilla</option>
        <option value="Granada">Granada</option>
        <option value="Málaga">Málaga</option>
        <option value="Badajoz">Badajoz</option>
        <option value="Toledo">Toledo</option>
        <option value="Ciudad Real">Ciudad Real</option>
        <option value="Almería">Almería</option>
        <option value="Huelva">Huelva</option>
      </select>
      <div class="suelo-datos hidden" id="suelo-datos">
        <div class="suelo-dato">
          <div class="icon">🌡️</div>
          <div class="value" id="suelo-temp">-</div>
          <div class="label">Temp Suelo</div>
          <div class="status" id="suelo-temp-status"></div>
        </div>
        <div class="suelo-dato">
          <div class="icon">💧</div>
          <div class="value" id="suelo-humedad">-</div>
          <div class="label">Humedad</div>
          <div class="status" id="suelo-humedad-status"></div>
        </div>
        <div class="suelo-dato">
          <div class="icon">📈</div>
          <div class="value" id="suelo-eto">-</div>
          <div class="label">ETo mm/hoy</div>
          <div class="status" id="suelo-eto-status"></div>
        </div>
        <div class="suelo-dato">
          <div class="icon">🌧️</div>
          <div class="value" id="suelo-lluvia">-</div>
          <div class="label">Lluvia</div>
          <div class="status" id="suelo-lluvia-status"></div>
        </div>
      </div>
    </div>
  </section>

  <div class="alert-strip-wrap">
    <div class="alert-strip">
      <div class="alert-strip-content">
        <span class="alert-strip-icon">⚠️</span>
        <span class="alert-strip-text">Los fertilizantes pueden encarecerse por la tensión en Oriente Medio. Existen alternativas naturales para tu olivo.</span>
      </div>
      <button class="alert-strip-btn" onclick="this.parentElement.nextElementSibling.classList.toggle('open')">Ver alternativas</button>
    </div>
    <div class="alert-strip-panel">
      <div class="alert-option">
        <span class="alert-option-icon">🌿</span>
        <div class="alert-option-text"><strong>Cubiertas vegetales</strong><span>Fijan nitrógeno y mejoran estructura del suelo</span></div>
      </div>
      <div class="alert-option">
        <span class="alert-option-icon">🪵</span>
        <div class="alert-option-text"><strong>Compost de poda</strong><span>Recicla restos de poda como abono orgánico</span></div>
      </div>
      <div class="alert-option">
        <span class="alert-option-icon">⬛</span>
        <div class="alert-option-text"><strong>Biochar</strong><span>Aumenta retención de agua hasta 3x</span></div>
      </div>
      <div class="alert-option">
        <span class="alert-option-icon">🌱</span>
        <div class="alert-option-text"><strong>Abonos verdes</strong><span>Leguminosas que aportan nitrógeno natural</span></div>
      </div>
      <a href="/consejero?q=¿Cómo+implemento+cubiertas+vegetales+y+alternativas+a+fertilizantes+en+mi+olivar?" class="alert-strip-btn" style="display:inline-block;margin-top:12px;width:auto">¿Cómo lo implemento? → Consejero IA</a>
    </div>
  </div>

  <div class="agua-plan" id="agua-plan" style="display:none">
    <div class="agua-plan-title">🎯 Plan de acción para tu suelo hoy</div>
    <div class="agua-plan-text" id="agua-plan-text"></div>
    <a href="#" class="agua-plan-btn" id="agua-plan-btn">¿Necesitas un plan personalizado? → Consejero IA</a>
  </div>

  <!-- ÁREA AGUA -->
  <section class="area-section agua">
    <div class="area-container">
      <div class="area-header">
        <h2 class="area-title agua">💧 Agua</h2>
        <p class="area-subtitle">Gestión eficiente del agua de riego para tu olivar</p>
      </div>
      
      <div class="carousel-wrapper" id="carousel-agua">
        <button class="carousel-nav prev" onclick="moveCarousel('agua', -1)">❮</button>
        <div class="carousel-track">
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>💧 Gestión del Agua</h2>
              <p>El olivo es tolerante a la sequía, pero el cambio climático está alterando los patrones de precipitación. Una gestión eficiente del agua es crucial.</p>
              <div class="agua-tip">
                <div class="agua-tip-title">📊 Necesidades hídricas</div>
                <p>Un olivo adulto necesita 1.000-1.500 mm/año. El riego deficitario puede reducir el consumo hasta 40% sin pérdidas significativas de rendimiento.</p>
              </div>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🛠️ Riego por Goteo</h2>
              <p>El sistema de riego por goteo es el más eficiente para olivares. Permite un control preciso del agua y la fertilización.</p>
              <ul class="agua-list">
                <li>💧 Caudal recomendado: 4 L/h/árbol</li>
                <li>⏱️ Frecuencia: 2-3 veces/semana</li>
                <li>📏 Laterales: 1 por hilera</li>
                <li>🔧 Goteros: 2-4 por árbol</li>
              </ul>
              <div class="agua-tip">
                <div class="agua-tip-title">⚡ Ahorro</div>
                <p>El goteo consume 30-40% menos agua que el riego por gravedad.</p>
              </div>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🧪 Calidad del Agua</h2>
              <p>La calidad del agua de riego afecta directamente la salud del olivo y la calidad del aceite.</p>
              <ul class="agua-list">
                <li><span class="agua-stat">CE</span> Conductividad: &lt;4 dS/m</li>
                <li><span class="agua-stat">SAR</span> Sodio: &lt;10 meq/L</li>
                <li><span class="agua-stat">CL</span> Cloruros: &lt;400 mg/L</li>
                <li><span class="agua-stat">pH</span> Agua: 6.5-8.0</li>
              </ul>
            </div>
          </div>
        </div>
        <button class="carousel-nav next" onclick="moveCarousel('agua', 1)">❯</button>
      </div>
      <div class="carousel-dots" id="dots-agua"></div>
    </div>
  </section>

  <!-- ÁREA SUELO -->
  <section class="area-section suelo">
    <div class="area-container">
      <div class="area-header">
        <h2 class="area-title suelo">🪨 Suelo</h2>
        <p class="area-subtitle">Cuida la tierra que sustenta tus olivos</p>
      </div>
      
      <div class="carousel-wrapper" id="carousel-suelo">
        <button class="carousel-nav prev" onclick="moveCarousel('suelo', -1)">❮</button>
        <div class="carousel-track">
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🪨 Tipos de Suelo</h2>
              <p>El olivo se adapta a diversos suelos, pero prospera en profundo, bien drenado y con buena capacidad de retención de agua.</p>
              <ul class="agua-list">
                <li><span class="agua-stat">ÓPTIMO</span> Franco-arcilloso con buen drenaje</li>
                <li><span class="agua-stat">BUENO</span> Suelos calcáreos (hasta 40% caliza)</li>
                <li><span class="agua-stat">LIMITADO</span> Suelos muy arcillosos (&gt;50%)</li>
                <li><span class="agua-stat">PROBLEMA</span> Suelos encharcadizos</li>
              </ul>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🌱 Materia Orgánica</h2>
              <p>La materia orgánica mejora la estructura del suelo, la capacidad de retención de agua y la disponibilidad de nutrientes.</p>
              <ul class="agua-list">
                <li>✅ Objetivo: &gt;2% materia orgánica</li>
                <li>📈 Medios actuales: 0.5-1.5%</li>
                <li>🧪 Enmienda: Compost, estiércol, biochar</li>
                <li>🌿 Cubiertas vegetales incrementan 0.5%/año</li>
              </ul>
              <div class="agua-tip">
                <div class="agua-tip-title">💡 Dato clave</div>
                <p>Cada 1% de materia orgánica aumenta la capacidad de retención de agua en 20.000 litros/ha.</p>
              </div>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🔬 Análisis de Suelo</h2>
              <p>Antes de fertilizar o enmendar, realiza un análisis de suelo para conocer los niveles de nutrientes y pH.</p>
              <ul class="agua-list">
                <li><span class="agua-stat">pH</span> Óptimo: 6.5-8.5</li>
                <li><span class="agua-stat">N</span> Nitrógeno: 20-40 ppm</li>
                <li><span class="agua-stat">P</span> Fósforo: 10-25 ppm</li>
                <li><span class="agua-stat">K</span> Potasio: 150-300 ppm</li>
              </ul>
            </div>
          </div>
        </div>
        <button class="carousel-nav next" onclick="moveCarousel('suelo', 1)">❯</button>
      </div>
      <div class="carousel-dots" id="dots-suelo"></div>
    </div>
  </section>

  <!-- ÁREA CONSERVACIÓN -->
  <section class="area-section conservacion">
    <div class="area-container">
      <div class="area-header">
        <h2 class="area-title conservacion">🛡️ Conservación</h2>
        <p class="area-subtitle">Prácticas sostenibles para proteger tu olivar</p>
      </div>
      
      <div class="carousel-wrapper" id="carousel-conservacion">
        <button class="carousel-nav prev" onclick="moveCarousel('conservacion', -1)">❮</button>
        <div class="carousel-track">
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🛡️ Prácticas de Conservación</h2>
              <p>Técnicas recomendadas para mejorar la infiltración y retención de agua en el suelo:</p>
              <ul class="agua-list">
                <li><strong>🌿 Cubiertas vegetales</strong> — Entre filas, reducen escorrentía 50%</li>
                <li><strong>⬛ Biochar</strong> — Aumenta retención de agua 3x</li>
                <li><strong>🪵 Mulching</strong> — Mantillo de paja o restos de poda</li>
                <li><strong>🪨 Laboreo mínimo</strong> — Conservar estructura del suelo</li>
                <li><strong>📐 Contour farming</strong> — Cultivo siguiendo curvas de nivel</li>
                <li><strong>💧 Zanjas de infiltración</strong> — Captura agua de escorrentía</li>
              </ul>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="agua-card">
              <h2>🌡️ Adaptación al Cambio Climático</h2>
              <p>Estrategias para gestionar el estrés hídrico:</p>
              <ul class="agua-list">
                <li>📅 Riego deficitario controlado</li>
                <li>🌳 Poda para reducir área foliar</li>
                <li>🛡️ Protectores solares para frutos</li>
                <li>📊 Monitorización con sensores</li>
              </ul>
            </div>
          </div>
        </div>
        <button class="carousel-nav next" onclick="moveCarousel('conservacion', 1)">❯</button>
      </div>
      <div class="carousel-dots" id="dots-conservacion"></div>
    </div>
  </section>

</Layout>

<script>
  import OlivaxiEcosistema from '../lib/ecosistema';

  const sueloDatos = document.getElementById('suelo-datos');
  const sueloTemp = document.getElementById('suelo-temp');
  const sueloTempStatus = document.getElementById('suelo-temp-status');
  const sueloHumedad = document.getElementById('suelo-humedad');
  const sueloHumedadStatus = document.getElementById('suelo-humedad-status');
  const sueloEto = document.getElementById('suelo-eto');
  const sueloEtoStatus = document.getElementById('suelo-eto-status');
  const sueloLluvia = document.getElementById('suelo-lluvia');
  const sueloLluviaStatus = document.getElementById('suelo-lluvia-status');
  const aguaPlan = document.getElementById('agua-plan');
  const aguaPlanText = document.getElementById('agua-plan-text');
  const aguaPlanBtn = document.getElementById('agua-plan-btn');
  const provinciaSelectAgua = document.getElementById('provincia-select-agua');

  function getQuickDataFromClima() {
    const prov = OlivaxiEcosistema.provincia;
    const clima = OlivaxiEcosistema.climaData;
    if (!prov || !Array.isArray(clima)) return null;
    const row = clima.find(r => r.provincia === prov);
    if (!row) return null;
    return {
      provincia: row.provincia,
      clima: { lluvia: row.lluvia ?? 0 },
      suelo: {
        temperatura: row.suelo_temp ?? 0,
        humedad: row.suelo_humedad ?? 0,
        evapotranspiracion: row.evapotranspiracion ?? 0
      },
      provinciaInfo: { tipoSuelo: row.tipoSuelo || '' }
    };
  }

  function getStatusClass(value, type) {
    if (type === 'temp') {
      if (value < 10 || value > 30) return { class: 'danger', text: '⚠️ Crítico' };
      if (value < 15 || value > 25) return { class: 'warning', text: '⚡ Atención' };
      return { class: 'ok', text: '✅ Normal' };
    }
    if (type === 'humedad') {
      if (value < 20 || value > 80) return { class: 'danger', text: '⚠️ Crítico' };
      if (value < 30 || value > 70) return { class: 'warning', text: '⚡ Atención' };
      return { class: 'ok', text: '✅ Normal' };
    }
    if (type === 'eto') {
      if (value > 6) return { class: 'danger', text: '🔥 Muy alto' };
      if (value > 4) return { class: 'warning', text: '⚡ Alto' };
      return { class: 'ok', text: '✅ Normal' };
    }
    if (type === 'lluvia') {
      if (value > 10) return { class: 'ok', text: '✅ Lluvia' };
      if (value > 0) return { class: 'warning', text: '🌧️ Ligera' };
      return { class: 'ok', text: '☀️ Sin lluvia' };
    }
    return { class: '', text: '' };
  }

  function smoothSetText(el, text) {
    if (!el) return;
    const next = String(text ?? '');
    if (el.textContent === next) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      el.textContent = next;
      return;
    }
    el.classList.add('updating');
    setTimeout(() => {
      el.textContent = next;
      el.classList.remove('updating');
      const card = el.closest('.suelo-dato');
      if (card) {
        card.classList.remove('updated');
        requestAnimationFrame(() => card.classList.add('updated'));
        setTimeout(() => card.classList.remove('updated'), 300);
      }
    }, 150);
  }

  function smoothSetStatus(el, status) {
    if (!el || !status) return;
    const nextClass = `status ${status.class}`;
    const nextText = status.text || '';
    if (el.className === nextClass && el.textContent === nextText) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      el.className = nextClass;
      el.textContent = nextText;
      return;
    }
    el.classList.add('updating');
    setTimeout(() => {
      el.className = nextClass;
      el.textContent = nextText;
      el.classList.remove('updating');
    }, 150);
  }

  async function loadDashboardData() {
    const prov = OlivaxiEcosistema.provincia;
    if (!prov) return null;
    
    const existing = OlivaxiEcosistema.dashboardData;
    if (existing && existing.provincia === prov) {
      return existing;
    }
    
    return await OlivaxiEcosistema.fetchDashboard();
  }

  function renderSueloData(d) {
    if (!d) {
      if (sueloDatos) sueloDatos.classList.add('hidden');
      if (aguaPlan) aguaPlan.style.display = 'none';
      return;
    }

    const temp = Math.round(d.suelo?.temperatura || 0);
    let humedadRaw = d.suelo?.humedad || 0;
    const humedad = humedadRaw <= 1 ? Math.round(humedadRaw * 100) : Math.round(humedadRaw);
    const humedadDisplay = Math.min(humedad, 100);
    const eto = d.suelo?.evapotranspiracion || 0;
    const lluvia = d.clima?.lluvia || 0;
    const tipoSuelo = d.provinciaInfo?.tipoSuelo || '';
    const provincia = d.provincia || '';

    const tempStatus = getStatusClass(temp, 'temp');
    const humedadStatus = getStatusClass(humedadDisplay, 'humedad');
    const etoStatus = getStatusClass(eto, 'eto');
    const lluviaStatus = getStatusClass(lluvia, 'lluvia');

    if (sueloDatos) {
      smoothSetText(sueloTemp, `${temp}°C`);
      smoothSetStatus(sueloTempStatus, tempStatus);
      
      smoothSetText(sueloHumedad, `${humedadDisplay}%`);
      smoothSetStatus(sueloHumedadStatus, humedadStatus);
      
      smoothSetText(sueloEto, eto.toFixed(1));
      smoothSetStatus(sueloEtoStatus, etoStatus);
      
      smoothSetText(sueloLluvia, `${lluvia.toFixed(1)}mm`);
      smoothSetStatus(sueloLluviaStatus, lluviaStatus);
      
      const shouldAnimate = sueloDatos.classList.contains('loading') || sueloDatos.classList.contains('hidden');
      sueloDatos.classList.remove('hidden', 'loading');
      if (shouldAnimate) {
        sueloDatos.classList.remove('animated');
        requestAnimationFrame(() => sueloDatos.classList.add('animated'));
        setTimeout(() => sueloDatos.classList.remove('animated'), 900);
      }
    }

    let planTexto = '';
    const esArenoso = tipoSuelo?.toLowerCase().includes('aren');
    const esHumedadBaja = humedadDisplay < 30;
    const esEToAlta = eto > 4.5;
    const esSinLluvia = lluvia === 0;
    const esHumedadAlta = humedadDisplay > 80;

    if (esArenoso && esHumedadBaja) {
      planTexto = '🟡 Riega hoy, el suelo arenoso drena rápido.';
    } else if (esEToAlta && esSinLluvia) {
      planTexto = '🟠 Alta evapotranspiración, aumenta frecuencia de riego.';
    } else if (esHumedadAlta) {
      planTexto = '🟢 Suelo bien hidratado, riego innecesario hoy.';
    } else if (esHumedadBaja) {
      planTexto = '🟡 Humedad baja, considera riego ligero.';
    } else {
      planTexto = '🟢 Condiciones de suelo óptimas para el olivar.';
    }

    if (aguaPlan && aguaPlanText) {
      aguaPlanText.textContent = planTexto;
      const query = `Plan+personalizado+riego+suelo+${provincia}+temp${temp}°C+humedad${humedadDisplay}%+ETo${eto.toFixed(1)}mm`;
      aguaPlanBtn.href = `/consejero?q=${query}`;
      aguaPlan.style.display = 'block';
    }
  }

  const carouselState = {
    agua: { current: 0, total: 3 },
    suelo: { current: 0, total: 3 },
    conservacion: { current: 0, total: 2 }
  };

  let selectedArea = null;

  document.querySelectorAll('.area-header').forEach(header => {
    header.addEventListener('click', () => {
      const section = header.closest('.area-section');
      const area = section?.classList.contains('agua') ? 'agua' : 
                   section?.classList.contains('suelo') ? 'suelo' : 
                   section?.classList.contains('conservacion') ? 'conservacion' : null;
      
      if (!area) return;
      
      if (selectedArea === area) {
        section.classList.remove('selected');
        selectedArea = null;
      } else {
        document.querySelectorAll('.area-section').forEach(s => s.classList.remove('selected'));
        section.classList.add('selected');
        selectedArea = area;
      }
    });
  });

  window.moveCarousel = function(area, direction) {
    const state = carouselState[area];
    if (!state) return;
    
    state.current += direction;
    if (state.current < 0) state.current = state.total - 1;
    if (state.current >= state.total) state.current = 0;
    
    updateCarousel(area);
  };

  function updateCarousel(area) {
    const state = carouselState[area];
    const wrapper = document.getElementById('carousel-' + area);
    const track = wrapper?.querySelector('.carousel-track');
    if (!track || !state) return;
    
    track.style.transform = `translateX(-${state.current * 100}%)`;
    
    wrapper.querySelectorAll('.carousel-nav').forEach(btn => {
      btn.classList.remove('disabled');
    });
    
    const dotsContainer = document.getElementById('dots-' + area);
    if (dotsContainer) {
      dotsContainer.innerHTML = '';
      for (let i = 0; i < state.total; i++) {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === state.current ? ' active' : '');
        dot.onclick = () => {
          state.current = i;
          updateCarousel(area);
        };
        dotsContainer.appendChild(dot);
      }
    }
  }

  ['agua', 'suelo', 'conservacion'].forEach(area => updateCarousel(area));

  function syncWithEcosistema() {
    const prov = OlivaxiEcosistema.provincia;
    
    if (prov) {
      if (provinciaSelectAgua && provinciaSelectAgua.value !== prov) {
        provinciaSelectAgua.value = prov;
      }

      if (sueloDatos) {
        sueloDatos.classList.remove('hidden');
        if (!sueloTemp.textContent || sueloTemp.textContent === '-') {
          sueloDatos.classList.add('loading');
        }
      }

      // Pintado rápido: usa datos de dashboard cacheado o clima compartido
      const cachedDashboard = OlivaxiEcosistema.dashboardData;
      if (cachedDashboard && cachedDashboard.provincia === prov) {
        renderSueloData(cachedDashboard);
      } else {
        const quick = getQuickDataFromClima();
        if (quick) renderSueloData(quick);
      }

      // Si no hay clima aún, pedirlo para mostrar KPIs base sin esperar dashboard completo
      if (!getQuickDataFromClima() && !Array.isArray(OlivaxiEcosistema.climaData)) {
        OlivaxiEcosistema.fetchClima().then(() => {
          const quickAfter = getQuickDataFromClima();
          if (quickAfter) renderSueloData(quickAfter);
        });
      }

      // Refresco definitivo con dashboard completo
      loadDashboardData().then(d => {
        if (d) renderSueloData(d);
        else if (sueloDatos) sueloDatos.classList.remove('loading');
      });
    } else {
      renderSueloData(null);
    }
  }

  const offEcosistema = OlivaxiEcosistema.onChange(() => {
    syncWithEcosistema();
  }, { immediate: true });
  window.addEventListener('beforeunload', offEcosistema);
</script>
