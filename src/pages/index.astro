<script>
  const decisionesGrid = document.getElementById('decisiones-grid');
  const analisisOlivar = document.getElementById('analisis-olivar');
  const alertasPlagas = document.getElementById('alertas-plagas');
  const selectProvincia = document.getElementById('select-provincia');
  const selectVariedad = document.getElementById('select-variedad');
  const alertasPanel = document.getElementById('alertas-panel');

  function guardarSeleccion(tipo: string, valor: string) {
    localStorage.setItem('olivaxi_' + tipo, valor);
  }

  function renderAlertasPanel(datos: any, variedad: string) {
    if (!alertasPanel) return;
    
    const alertas: {icon: string, text: string, level: string}[] = [];
    
    const riesgos_olivar = datos?.riesgos_olivar || {};
    const riesgos_plaga = datos?.riesgos_plaga || {};
    const riesgos_variedad = datos?.riesgos_variedad || {};

    // Riesgos de la variedad seleccionada (del backend)
    const rv = riesgos_variedad[variedad];
    if (rv) {
      if (rv.nivel === 'crítico') {
        alertas.push({ icon: '🔴', text: `Riesgo crítico para ${variedad}`, level: 'high' });
        rv.detalle?.forEach((d: string) => alertas.push({ icon: '⚠️', text: d, level: 'high' }));
      } else if (rv.nivel === 'medio') {
        alertas.push({ icon: '🟡', text: `Riesgo medio para ${variedad}`, level: 'medium' });
        rv.detalle?.forEach((d: string) => alertas.push({ icon: '⚠️', text: d, level: 'medium' }));
      }
    }

    // Riesgos del olivar (del backend)
    const agregarRiesgo = (riesgo: any, icono: string, texto: string) => {
      if (riesgo?.nivel === 'alto') alertas.push({ icon: icono, text: texto || riesgo.descripcion, level: 'high' });
    };
    agregarRiesgo(riesgos_olivar.calor, '🔥', '');
    agregarRiesgo(riesgos_olivar.baja_humedad, '🏜️', '');
    agregarRiesgo(riesgos_olivar.alta_humedad, '🦠', '');
    agregarRiesgo(riesgos_olivar.baja_lluvia, '🏜️', '');
    agregarRiesgo(riesgos_olivar.alta_lluvia, '🌊', '');

    // Riesgos de plagas
    agregarRiesgo(riesgos_plaga.mosca, '🦟', 'Mosca activa');
    agregarRiesgo(riesgos_plaga.polilla, '🦋', 'Polilla activa');
    agregarRiesgo(riesgos_plaga.xylella, '🦠', 'Xylella - Riesgo crítico');
    agregarRiesgo(riesgos_plaga.repilo, '🍄', 'Repilo activo');

    if (alertas.length === 0) {
      alertasPanel.innerHTML = `<p class="panel-msg" style="color: #22c55e;">✅ Sin alertas activas. Condiciones normales.</p>`;
    } else {
      alertasPanel.innerHTML = alertas.map(a => `
        <div class="alerta-mini" style="padding: 8px; margin-bottom: 6px; border-radius: 4px; background: ${a.level === 'high' ? 'rgba(239, 68, 68, 0.15)' : 'rgba(245, 158, 11, 0.15)'}; border-left: 3px solid ${a.level === 'high' ? '#ef4444' : '#f59e0b'};">
          <span style="margin-right: 6px;">${a.icon}</span>
          <span style="font-size: 12px; color: var(--color-aceituna);">${a.text}</span>
        </div>
      `).join('');
    }
  }

  async function fetchAnalisisProvincia(provincia) {
    try {
      const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, '') || 'http://localhost:3000';
      const [climaRes, analisisRes] = await Promise.all([
        fetch(`${apiBase}/api/clima`),
        fetch(`${apiBase}/api/analisis/${encodeURIComponent(provincia)}`)
      ]);
      
      const datos = await climaRes.json();
      const analisis = analisisRes.ok ? await analisisRes.json() : null;
      
      const provData = datos.find((p) => p.provincia === provincia);
      if (provData) {
        renderDecisiones(provincia, analisis, provData);
        const variedad = selectVariedad?.value || '';
        renderAlertasPanel(provData, variedad);
        window.dispatchEvent(new CustomEvent('datos-provincia', {
          detail: {
            provincia: provData.provincia,
            temperatura: provData.temperatura,
            humedad: provData.humedad,
            lluvia: provData.lluvia,
            riesgos_plaga: provData.riesgos_plaga,
            riesgos_olivar: provData.riesgos_olivar
          }
        }));
      } else {
        decisionesGrid.innerHTML = '<div class="decisiones-placeholder"><p>No hay datos para esta provincia.</p></div>';
      }
    } catch (err) {
      console.error('Error cargando datos:', err);
      decisionesGrid.innerHTML = '<div class="decisiones-placeholder"><p>Error al cargar datos.</p></div>';
    }
  }

  function renderDecisiones(provincia, analisis, climaData) {
    const tempDisplay = climaData?.temperatura ? `${climaData.temperatura}°C` : '--';
    const humedadDisplay = climaData?.humedad ? `${climaData.humedad}%` : '--';
    const lluviaDisplay = climaData?.lluvia ? `${climaData.lluvia}mm` : '--';
    const riesgo = climaData?.riesgo || 'bajo';
    
    const recomendaciones = analisis?.recomendaciones || [];
    const alertas = analisis?.alertas || [];

    decisionesGrid.innerHTML = `
      <div class="decision-card temp">
        <div class="decision-label">Temperatura actual</div>
        <div class="decision-value">${tempDisplay}</div>
        <div style="font-size: 10px; color: var(--color-muted); margin-top: 4px;">
          💧 ${humedadDisplay} · 🌧️ ${lluviaDisplay}
        </div>
      </div>
      <div class="decision-card riesgo ${riesgo}">
        <div class="decision-label">Nivel de riesgo</div>
        <div class="decision-value ${riesgo}">${riesgo === 'alto' ? 'Alto' : riesgo === 'medio' ? 'Medio' : 'Bajo'}</div>
        ${alertas.length > 0 ? `<div style="font-size: 10px; color: #ef4444; margin-top: 4px;">⚠️ ${alertas[0]}</div>` : ''}
      </div>
      <div class="decision-card acciones">
        <div class="decision-label">Recomendaciones</div>
        <ul class="decision-actions">
          ${recomendaciones.length > 0 
            ? recomendaciones.map(r => `<li>${r}</li>`).join('')
            : '<li>✅ Condiciones óptimas</li><li>🌱 Buenas condiciones para tratamientos</li>'}
        </ul>
      </div>
    `;
  }

  // Listen for province selection from map
  window.addEventListener('provincia-seleccionada', (e) => {
    fetchAnalisisProvincia(e.detail.provincia);
  });

  // Select provincia change
  selectProvincia?.addEventListener('change', (e) => {
    const provincia = e.target.value;
    if (provincia) {
      guardarSeleccion('provincia', provincia);
      fetchAnalisisProvincia(provincia);
      // Emitir evento unificado para otras páginas
      window.dispatchEvent(new CustomEvent('olivaxi-state-change', { 
        detail: { provincia, variedad: selectVariedad?.value || null } 
      }));
    }
  });

  // Select variedad change
  selectVariedad?.addEventListener('change', (e) => {
    const variedad = e.target.value;
    if (variedad) {
      guardarSeleccion('variedad', variedad);
      // Emitir evento unificado para otras páginas
      window.dispatchEvent(new CustomEvent('olivaxi-state-change', { 
        detail: { provincia: selectProvincia?.value || null, variedad } 
      }));
      
      const provincia = selectProvincia?.value;
      if (provincia) {
        const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, '') || 'http://localhost:3000';
        fetch(`${apiBase}/api/clima`).then(r => r.json()).then(datos => {
          const provData = datos.find((p: any) => p.provincia === provincia);
          if (provData) renderAlertasPanel(provData, variedad);
        });
      }
    }
  });

  // Escuchar cambios de otras páginas
  window.addEventListener('olivaxi-state-change', (e) => {
    const { provincia, variedad } = e.detail;
    if (provincia && provincia !== selectProvincia?.value) {
      selectProvincia.value = provincia;
      fetchAnalisisProvincia(provincia);
    }
    if (variedad && variedad !== selectVariedad?.value) {
      selectVariedad.value = variedad;
    }
  });

  // Click on Top 3 cards
  document.querySelectorAll('.top3-card').forEach(card => {
    card.addEventListener('click', () => {
      const provincia = card.dataset.provincia;
      if (provincia) {
        if (selectProvincia) selectProvincia.value = provincia;
        window.dispatchEvent(new CustomEvent('provincia-seleccionada', { detail: { provincia } }));
      }
    });
  });

  // Restore from localStorage
  const provGuardada = localStorage.getItem('olivaxi_provincia');
  const varGuardada = localStorage.getItem('olivaxi_variedad');
  if (provGuardada && selectProvincia) {
    selectProvincia.value = provGuardada;
    fetchAnalisisProvincia(provGuardada);
  }
  if (varGuardada && selectVariedad) {
    selectVariedad.value = varGuardada;
  }
</script>