---
import Layout from '../layouts/Layout.astro';
import MapaCalor from '../components/MapaCalor.astro';
---

<Layout title="olivaξ - Protege tu olivar del cambio climático">
<style is:global>
.hero-section{min-height:40vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:50px 24px 30px;gap:16px}
.hero-title{font-size:clamp(36px,6vw,56px);font-weight:700;color:var(--color-aceituna);margin:0;max-width:700px}
.hero-subtitle{font-size:clamp(16px,2vw,20px);font-weight:400;color:var(--color-muted);margin:0;max-width:600px;line-height:1.5}
.hero-contextual{font-size:clamp(14px,1.5vw,16px);font-weight:600;color:var(--color-aceituna);margin-top:8px;padding:8px 16px;background:rgba(212,232,73,0.2);border-radius:20px}
@keyframes heroFadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.hero-title,.hero-subtitle,.hero-contextual{animation:heroFadeIn .8s ease-out both}
.hero-subtitle{animation-delay:.15s}
.hero-contextual{animation-delay:.3s}
@media(max-width:640px){.hero-section{min-height:30vh;padding:40px 16px 20px;gap:10px}.hero-title{font-size:1.75rem}.hero-subtitle{font-size:.9rem}}
.bento-grid{display:grid;grid-template-columns:60fr 40fr;gap:8px;max-width:1200px;margin:0 auto 1rem;padding:0 1rem}
.mapa-card,.sidebar-panels{background:var(--color-white-surface);border:2px solid var(--color-border);border-radius:6px;overflow:hidden}
.mapa-card{display:flex;flex-direction:column}
.mapa-card :global(olivaxi-mapa){flex:1;min-height:0}
.sidebar-panels{background:var(--color-limon)}
.carousel-container{display:flex;flex-direction:column;height:100%}
.carousel-nav{display:flex;background:var(--color-limon);border-bottom:2px solid var(--color-border);flex-shrink:0}
.carousel-tab{flex:1;padding:12px 8px;border:none;border-right:1px solid var(--color-border);background:transparent;color:var(--color-aceituna);font-size:12px;font-weight:700;cursor:pointer;text-align:center}
.carousel-tab:last-child{border-right:none}
.carousel-tab:hover{background:rgba(255,255,255,.5)}
.carousel-tab.active{background:var(--color-white-surface)}
.carousel-slide{display:none;flex-direction:column;flex:1;padding:12px;gap:8px;overflow-y:auto}
.carousel-slide.active{display:flex}
.provincias-grid,.variedades-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px}
.provincia-btn,.variedad-btn{padding:10px 8px;border:1.5px solid var(--color-border);background:var(--color-white-surface);border-radius:4px;cursor:pointer;font-size:12px;font-weight:600;color:var(--color-aceituna);text-align:center}
.provincia-btn:hover,.variedad-btn:hover{background:var(--color-aceituna);color:var(--color-sal)}
.provincia-btn.selected,.variedad-btn.selected{background:var(--color-aceituna);color:var(--color-sal)}
.provincia-btn .riesgo-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:4px}
.riesgo-dot.alto{background:#ef4444}.riesgo-dot.medio{background:#f59e0b}.riesgo-dot.bajo{background:#22c55e}
.provincia-btn .temp{font-size:10px;color:var(--color-muted);display:block;margin-top:2px}
.variedad-btn{text-align:left}.variedad-btn .nombre{font-weight:700}
.variedad-btn .riesgo-label{font-size:9px;padding:2px 5px;border-radius:3px;display:inline-block;margin-top:4px}
.riesgo-label.alto{background:rgba(239,68,68,.15);color:#dc2626}.riesgo-label.medio{background:rgba(245,158,11,.15);color:#b45309}.riesgo-label.bajo{background:rgba(34,197,94,.15);color:#15803d}
.variedades-link{display:block;text-align:center;padding:8px;margin-top:8px;background:var(--color-white-surface);border:1.5px dashed var(--color-border);border-radius:4px;color:var(--color-aceituna);font-size:11px;font-weight:600;text-decoration:none}
.variedades-link:hover{background:var(--color-aceituna);color:var(--color-sal);border-style:solid}
.alertas-list{flex:1;overflow-y:auto}
.alerta-item{padding:8px;margin-bottom:6px;border-radius:4px;border-left:3px solid;font-size:11px;background:var(--color-white-surface)}
.alerta-item.alto{border-color:#ef4444}.alerta-item.medio{border-color:#f59e0b}.alerta-item.bajo{border-color:#22c55e}
.alerta-actions{display:flex;gap:8px;flex-shrink:0}
.alerta-action-btn{flex:1;padding:8px;border:1.5px solid var(--color-border);background:var(--color-white-surface);border-radius:4px;font-size:11px;font-weight:600;color:var(--color-aceituna);text-decoration:none;text-align:center}
.alerta-action-btn:hover{background:var(--color-aceituna);color:var(--color-sal)}
.no-province-msg{text-align:center;padding:16px;color:var(--color-aceituna);font-size:12px;background:var(--color-white-surface);border-radius:4px}
.provincia-info{padding:8px;margin-bottom:8px;background:rgba(212,232,73,0.15);border-radius:6px;font-size:10px}
.provincia-info div{margin-bottom:2px}
.quick-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:8px}
.quick-stat{padding:6px;text-align:center;background:var(--color-white-surface);border-radius:4px;border:1px solid var(--color-border)}
.quick-stat .icon{font-size:14px}
.quick-stat .value{font-size:11px;font-weight:700;color:var(--color-aceituna)}
.quick-stat .label{font-size:8px;color:var(--color-muted)}
.consejos-panel{margin-top:8px;padding:8px;background:rgba(255,255,255,0.7);border-radius:4px;border-left:3px solid var(--color-limon)}
.consejos-panel .titulo{font-size:10px;font-weight:700;color:var(--color-aceituna);margin-bottom:4px}
.consejos-panel .consejo{font-size:9px;color:var(--color-muted);margin-bottom:2px}
@media(max-width:900px){.bento-grid{grid-template-columns:1fr}.mapa-card{height:300px}.sidebar-panels{min-height:300px}}
@media(max-width:600px){.bento-grid{gap:6px;padding:0 .5rem}.mapa-card{height:260px}.sidebar-panels{min-height:260px}.provincias-grid,.variedades-grid{gap:4px}}
.premium-cards{margin:0 auto 1rem;padding:0 1rem;max-width:1200px}
.cards-wrapper{position:relative}
.cards-container{display:flex;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;-ms-overflow-style:none;padding:8px 0}
.cards-container::-webkit-scrollbar{display:none}
.premium-card{flex:0 0 280px;background:var(--color-white-surface);border:2px solid var(--color-border);border-radius:8px;overflow:hidden;text-decoration:none;scroll-snap-align:center;transition:transform .15s ease}
.premium-card:hover{transform:translateY(-2px)}
.card-image{height:100px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--color-limon) 0%,var(--color-aceituna) 100%)}
.premium-card:nth-child(2) .card-image{background:linear-gradient(135deg,#74B9FF 0%,#0984e3 100%)}
.premium-card:nth-child(3) .card-image{background:linear-gradient(135deg,#55EFC4 0%,#00b894 100%)}
.card-icon{font-size:2rem}
.card-content{padding:12px}
.card-category{font-size:.7rem;font-weight:700;color:var(--color-muted);letter-spacing:.1em}
.card-title{font-size:.95rem;font-weight:700;color:var(--color-aceituna);margin:4px 0}
.card-text{font-size:.85rem;color:var(--color-muted)}
.card-dynamic{font-size:.8rem;color:var(--color-aceituna);font-weight:600;margin-top:4px}
.cards-nav{display:flex;justify-content:center;gap:8px;margin-top:8px}
.cards-nav-btn{width:36px;height:36px;border-radius:50%;border:2px solid var(--color-border);background:var(--color-white-surface);color:var(--color-aceituna);font-size:1rem;cursor:pointer}
.cards-nav-btn:hover{background:var(--color-limon)}
.cards-dots{display:flex;justify-content:center;gap:6px;margin-top:4px}
.cards-dot{width:8px;height:8px;border-radius:50%;background:var(--color-muted);opacity:.4}
.cards-dot.active{background:var(--color-limon);opacity:1}
.mi-olivar-panel{display:none;margin:0 auto 1rem;padding:0 1rem;max-width:1200px}
.mi-olivar-panel.visible{display:block}
.mi-olivar-card{background:var(--color-white-surface);border:2px solid var(--color-limon);border-radius:8px;padding:16px;position:relative}
.mi-olivar-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.mi-olivar-title{font-size:.9rem;font-weight:700;color:var(--color-aceituna);display:flex;align-items:center;gap:8px}
.mi-olivar-close{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--color-muted);padding:4px}
.mi-olivar-content{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px}
.mi-olivar-stat{padding:10px;background:rgba(212,232,73,.1);border-radius:6px;text-align:center}
.mi-olivar-stat .icon{font-size:1.2rem}
.mi-olivar-stat .value{font-size:1.1rem;font-weight:700;color:var(--color-aceituna)}
.mi-olivar-stat .label{font-size:.7rem;color:var(--color-muted)}
.mi-olivar-alerts{margin-top:12px;display:flex;flex-wrap:wrap;gap:6px}
.mi-olivar-alert{padding:4px 10px;border-radius:12px;font-size:.75rem;font-weight:600}
.mi-olivar-alert.alto{background:rgba(239,68,68,.15);color:#dc2626}
.mi-olivar-alert.medio{background:rgba(245,158,11,.15);color:#b45309}
.mi-olivar-alert.bajo{background:rgba(34,197,94,.15);color:#15803d}
.mi-olivar-actions{display:flex;gap:8px;margin-top:12px}
.mi-olivar-btn{flex:1;padding:8px;border:1.5px solid var(--color-border);background:var(--color-white-surface);border-radius:6px;font-size:.8rem;font-weight:600;color:var(--color-aceituna);text-decoration:none;text-align:center}
.mi-olivar-btn:hover{background:var(--color-limon)}
.narrative-section{display:none;margin:0 auto 1rem;padding:0 1rem;max-width:1200px}
.narrative-section.visible{display:block}
.narrative-card{background:var(--color-white-surface);border:2px solid var(--color-border);border-radius:8px;padding:20px}
.narrative-title{font-size:1rem;font-weight:700;color:var(--color-aceituna);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.narrative-content{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}
.narrative-item{padding:12px;background:rgba(212,232,73,.1);border-radius:6px}
.narrative-item .narrative-label{font-size:.75rem;color:var(--color-muted);margin-bottom:4px}
.narrative-item .narrative-value{font-size:1.1rem;font-weight:700;color:var(--color-aceituna)}
.narrative-item .narrative-sub{font-size:.8rem;color:var(--color-muted)}
.narrative-item.positivo .narrative-value{color:#dc2626}
.narrative-item.negativo .narrative-value{color:#15803d}
.riesgo-badge{position:absolute;top:10px;right:10px;z-index:10;padding:6px 12px;border-radius:20px;font-size:11px;font-weight:700;background:var(--color-white-surface);border:2px solid;display:flex;align-items:center;gap:6px;cursor:pointer;transition:transform .15s ease}
.riesgo-badge:hover{transform:scale(1.05)}
.riesgo-badge.alto{border-color:#ef4444;color:#dc2626}
.riesgo-badge.medio{border-color:#f59e0b;color:#b45309}
.riesgo-badge.bajo{border-color:#22c55e;color:#15803d}
.mapa-card{position:relative;transition:border-color .3s ease,border-width .3s ease}
.mapa-card.riesgo-alto{border-color:#ef4444;border-width:4px}
.mapa-card.riesgo-medio{border-color:#f59e0b;border-width:4px}
.mapa-card.riesgo-bajo{border-color:#22c55e;border-width:2px}
.card-actions{padding:0 12px 12px}
.card-btn-secondary{display:block;text-align:center;padding:8px;background:var(--color-limon);border-radius:6px;font-size:11px;font-weight:600;color:var(--color-aceituna);text-decoration:none;transition:background .15s ease,color .15s ease}
.card-btn-secondary:hover{background:var(--color-aceituna);color:var(--color-sal)}
</style>

<section class="hero-section">
<h1 class="hero-title">Ciencia aplicada al cultivo</h1>
<p class="hero-subtitle">Convierte datos científicos en decisiones prácticas en tiempo real para proteger tus olivos.</p>
<div class="hero-contextual" id="hero-contextual">Selecciona una provincia para ver datos en tiempo real</div>
</section>

<div class="bento-grid">
  <div class="mapa-card" id="mapa-card-wrapper"><MapaCalor id="mapa-calor" /><div class="riesgo-badge bajo" id="riesgo-badge">✅ Sin riesgo</div></div>
<div class="sidebar-panels carousel-container">
<div class="carousel-nav">
<button class="carousel-tab active" data-slide="provincias">📍 Provincias</button>
<button class="carousel-tab" data-slide="variedades">🫒 Variedades</button>
<button class="carousel-tab" data-slide="alertas">🚨 Alertas</button>
</div>
<div class="carousel-slide active" id="slide-provincias"><div class="provincias-grid" id="provincias-grid"></div></div>
<div class="carousel-slide" id="slide-variedades"><div class="variedades-grid" id="variedades-grid"></div><a href="/variedades" class="variedades-link">No sé mi variedad →</a></div>
<div class="carousel-slide" id="slide-alertas"><div class="alertas-list" id="alertas-list"><div class="no-province-msg">Selecciona una provincia para ver alertas.</div></div><div class="alerta-actions"><a href="/plagas" class="alerta-action-btn">🔬 Guía Plagas</a><a href="/alertas" class="alerta-action-btn">🔔 Activar Notificaciones</a></div></div>
</div>
</div>

<section class="premium-cards">
<div class="cards-wrapper">
<div class="cards-container" id="cards-container">
<a href="/agua-suelos" class="premium-card" id="card-suelo"><div class="card-image"><span class="card-icon">🌡️</span></div><div class="card-content"><span class="card-category">SUELO</span><h3 class="card-title">Estado del suelo</h3><p class="card-dynamic" id="card-suelo-text">Cargando datos...</p></div></a>
<a href="/variedades" class="premium-card"><div class="card-image"><span class="card-icon">🫒</span></div><div class="card-content"><span class="card-category">VARIEDAD</span><h3 class="card-title">Predominante</h3><p class="card-dynamic" id="card-variedad-text">Selecciona provincia</p></div></a>
<a href="/consejero" class="premium-card" id="card-consejo"><div class="card-image"><span class="card-icon">💡</span></div><div class="card-content"><span class="card-category">CONSEJO</span><h3 class="card-title">Consejo del día</h3><p class="card-dynamic" id="card-consejo-text">Sin datos aún</p></div><div class="card-actions"><span class="card-btn-secondary" id="card-chat-btn">💬 Preguntar al asesor</span></div></a>
</div>
<div class="cards-nav"><button class="cards-nav-btn" id="prev-btn">←</button><button class="cards-nav-btn" id="next-btn">→</button></div>
<div class="cards-dots"><span class="cards-dot active" data-index="0"></span><span class="cards-dot" data-index="1"></span><span class="cards-dot" data-index="2"></span></div>
</div>
</section>

<div class="mi-olivar-panel" id="mi-olivar-panel">
<div class="mi-olivar-card">
<div class="mi-olivar-header">
<span class="mi-olivar-title">🌿 Mi Olivar</span>
<button class="mi-olivar-close" id="mi-olivar-close">×</button>
</div>
<div class="mi-olivar-content" id="mi-olivar-content"></div>
<div class="mi-olivar-alerts" id="mi-olivar-alerts"></div>
<div class="mi-olivar-actions">
<a href="/agua-suelos" class="mi-olivar-btn">💧 Riego</a>
<a href="/consejero" class="mi-olivar-btn">💬 Asesor IA</a>
<a href="/alertas" class="mi-olivar-btn">🔔 Alertas</a>
</div>
</div>
</div>

<div class="narrative-section" id="narrative-section">
<div class="narrative-card">
<div class="narrative-title">📊 Cambio Climático - Tendencias en tu zona</div>
<div class="narrative-content" id="narrative-content"></div>
</div>
</div>

<script>
import OlivaxiEcosistema from '../lib/ecosistema';

// --- DOM refs ---
const $ = (id) => document.getElementById(id);
const PROVINCIAS_GRID = $('provincias-grid');
const VARIEDADES_GRID = $('variedades-grid');
const ALERTAS_LIST = $('alertas-list');
const HERO_CONTEXTUAL = $('hero-contextual');
const CARD_SUELO_TEXT = $('card-suelo-text');
const CARD_VARIEDAD_TEXT = $('card-variedad-text');
const CARD_CONSEJO_TEXT = $('card-consejo-text');
const MI_OLIVAR_PANEL = $('mi-olivar-panel');
const MI_OLIVAR_CONTENT = $('mi-olivar-content');
const MI_OLIVAR_ALERTS = $('mi-olivar-alerts');
const MI_OLIVAR_CLOSE = $('mi-olivar-close');
const NARRATIVE_SECTION = $('narrative-section');
const NARRATIVE_CONTENT = $('narrative-content');
const MAPA_CARD = $('mapa-card-wrapper');
const RIESGO_BADGE = $('riesgo-badge');
const CARD_CHAT_BTN = $('card-chat-btn');
const CAROUSEL_TABS = document.querySelectorAll('.carousel-tab');
const CAROUSEL_SLIDES = document.querySelectorAll('.carousel-slide');

// --- Estado local (derivado del ecosistema) ---
let datosClima = [];
let dashboardData = null;

// --- Helpers UI ---
function getRiesgoClass(r) {
  if (!r) return 'bajo';
  if (r === 'alto' || r === 'crítico') return 'alto';
  if (r === 'medio' || r === 'media') return 'medio';
  return 'bajo';
}

function getRiesgoGlobal(d) {
  const activos = d?.riesgosActivos || [];
  if (activos.length === 0) return 'bajo';
  const priority = { 'crítico': 4, 'alto': 3, 'medio': 2, 'bajo': 1 };
  return activos.reduce((prev, curr) =>
    (priority[curr.nivel] || 1) > (priority[prev?.nivel] || 1) ? curr : prev,
    { nivel: 'bajo' }
  ).nivel;
}

// --- Carousel ---
function initCarousel() {
  CAROUSEL_TABS.forEach(t => t.addEventListener('click', () => {
    const s = t.dataset.slide;
    CAROUSEL_TABS.forEach(x => x.classList.remove('active'));
    CAROUSEL_SLIDES.forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    document.getElementById('slide-' + s)?.classList.add('active');
  }));
}

function switchToAlertasTab() {
  CAROUSEL_TABS.forEach(x => x.classList.remove('active'));
  CAROUSEL_SLIDES.forEach(x => x.classList.remove('active'));
  document.querySelector('[data-slide="alertas"]')?.classList.add('active');
  document.getElementById('slide-alertas')?.classList.add('active');
}

// --- Render: Provincias Grid ---
function renderProvinciasGrid() {
  if (!PROVINCIAS_GRID || !datosClima.length) return;
  const prov = OlivaxiEcosistema.provincia;
  const var_ = OlivaxiEcosistema.variedad;

  PROVINCIAS_GRID.innerHTML = datosClima.map(p =>
    `<button class="provincia-btn ${prov === p.provincia ? 'selected':''}" data-provincia="${p.provincia}">
      <span class="riesgo-dot ${getRiesgoClass(p.riesgo)}"></span>${p.provincia}
      <div class="temp">${p.temperatura}°C</div>
    </button>`
  ).join('');

  PROVINCIAS_GRID.querySelectorAll('.provincia-btn').forEach(b => b.addEventListener('click', () => {
    OlivaxiEcosistema.setProvincia(b.dataset.provincia);
    window.dispatchEvent(new CustomEvent('flyToProvincia', { detail: { provincia: b.dataset.provincia } }));
    switchToAlertasTab();
  }));
}

// --- Render: Variedades Grid ---
function renderVariedadesGrid() {
  if (!VARIEDADES_GRID) return;
  const prov = OlivaxiEcosistema.provincia;
  const var_ = OlivaxiEcosistema.variedad;
  const V = { cornicabra: 'Cornicabra', picual: 'Picual', arbequina: 'Arbequina', hojiblanca: 'Hojiblanca', manzanilla: 'Manzanilla', empeltre: 'Empeltre' };
  const provData = prov ? datosClima.find(x => x.provincia === prov) : null;

  VARIEDADES_GRID.innerHTML = Object.entries(V).map(([id, nombre]) => {
    const riesgo = provData?.riesgos_variedad?.[id]?.nivel || 'bajo';
    return `<button class="variedad-btn ${var_ === id ? 'selected' : ''}" data-variedad="${id}">
      <div class="nombre">${nombre}</div>
      <span class="riesgo-label ${riesgo}">${riesgo.toUpperCase()}</span>
    </button>`;
  }).join('');

  VARIEDADES_GRID.querySelectorAll('.variedad-btn').forEach(b => b.addEventListener('click', () => {
    OlivaxiEcosistema.setVariedad(b.dataset.variedad);
  }));
}

// --- Render: Alertas Panel (sidebar) ---
function renderAlertasPanel(d) {
  if (!ALERTAS_LIST) return;
  const prov = OlivaxiEcosistema.provincia;
  const var_ = OlivaxiEcosistema.variedad;

  if (!prov) {
    ALERTAS_LIST.innerHTML = '<div class="no-province-msg">Selecciona una provincia para ver alertas.</div>';
    return;
  }
  const riesgos = [];
  const rv = d?.riesgos_variedad?.[var_];
  if (rv) {
    const n = rv.nivel || 'bajo';
    riesgos.push({ icon: n === 'crítico' || n === 'alto' ? '🔴' : n === 'medio' ? '🟡' : '🟢', text: 'Riesgo ' + n + ' para ' + var_, level: n === 'crítico' ? 'alto' : n });
  }
  const ro = d?.riesgos_olivar || {};
  if (ro.calor?.nivel === 'alto') riesgos.push({ icon: '🔥', text: ro.calor.descripcion, level: 'alto' });
  if (ro.calor?.nivel === 'medio') riesgos.push({ icon: '🌡️', text: ro.calor.descripcion, level: 'medio' });
  if (ro.baja_humedad?.nivel === 'alto') riesgos.push({ icon: '🏜️', text: ro.baja_humedad.descripcion, level: 'alto' });
  if (ro.frio?.nivel === 'alto') riesgos.push({ icon: '❄️', text: ro.frio.descripcion, level: 'alto' });
  const rp = d?.riesgos_plaga || {};
  if (rp.mosca?.nivel === 'alto') riesgos.push({ icon: '🪰', text: rp.mosca.descripcion, level: 'alto' });
  if (rp.mosca?.nivel === 'medio') riesgos.push({ icon: '🪰', text: rp.mosca.descripcion, level: 'medio' });
  if (rp.polilla?.nivel === 'alto') riesgos.push({ icon: '🦋', text: rp.polilla.descripcion, level: 'alto' });
  if (rp.polilla?.nivel === 'medio') riesgos.push({ icon: '🦋', text: rp.polilla.descripcion, level: 'medio' });
  if (rp.repilo?.nivel === 'alto') riesgos.push({ icon: '🍂', text: rp.repilo.descripcion, level: 'alto' });

  const info = d ? `<div class="provincia-info"><div><strong>🫒</strong> ${d.variedadPredominante || 'N/A'} &nbsp; <strong>🪨</strong> ${d.tipoSuelo || 'N/A'}</div><div><strong>⛰️</strong> ${d.altitud || '?'}m &nbsp; <strong>🌧️</strong> ${d.pluviometriaAnual || '?'}mm/año</div></div>` : '';
  const quickStats = d ? `<div class="quick-stats"><div class="quick-stat"><div class="icon">🌡️</div><div class="value">${d.temperatura}°C</div><div class="label">Temp</div></div><div class="quick-stat"><div class="icon">💧</div><div class="value">${d.humedad}%</div><div class="label">Humedad</div></div><div class="quick-stat"><div class="icon">${getRiesgoClass(d.riesgo) === 'alto' ? '🔴' : getRiesgoClass(d.riesgo) === 'medio' ? '🟡' : '🟢'}</div><div class="value">${d.riesgo || 'bajo'}</div><div class="label">Riesgo</div></div></div>` : '';
  const riesgosHtml = riesgos.length > 0 ? riesgos.map(r => `<div class="alerta-item ${r.level}">${r.icon} ${r.text}</div>`).join('') : '<div class="alerta-item bajo">✅ Sin riesgos activos</div>';
  const consejosHtml = d?.consejos?.length ? `<div class="consejos-panel"><div class="titulo">💡 Consejos</div>${d.consejos.slice(0, 2).map(c => `<div class="consejo">${c.replace(/^\S+\s/, '')}</div>`).join('')}</div>` : '';

  ALERTAS_LIST.innerHTML = info + quickStats + riesgosHtml + consejosHtml;
}

// --- Render: Riesgo Badge + Mapa border ---
function updateRiesgoBadge(d) {
  if (!RIESGO_BADGE || !MAPA_CARD) return;
  const nivel = getRiesgoGlobal(d);
  const labels = { 'alto': '🔴 Riesgo alto', 'medio': '🟡 Riesgo medio', 'bajo': '✅ Riesgo bajo' };
  RIESGO_BADGE.className = 'riesgo-badge ' + nivel;
  RIESGO_BADGE.textContent = labels[nivel] || labels.bajo;
  RIESGO_BADGE.onclick = () => switchToAlertasTab();
  MAPA_CARD.className = 'mapa-card riesgo-' + nivel;
}

// --- Render: Mi Olivar panel ---
function renderMiOlivarPanel(d) {
  if (!MI_OLIVAR_PANEL || !d) return;
  MI_OLIVAR_PANEL.classList.add('visible');
  const eti = d.suelo?.evapotranspiracion || 0;
  const kc = 0.7;
  const riegoDiario = Math.round(eti * kc * 100) / 100;
  MI_OLIVAR_CONTENT.innerHTML = `<div class="mi-olivar-stat"><div class="icon">🌡️</div><div class="value">${d.clima.temperatura}°C</div><div class="label">Temp. aire</div></div><div class="mi-olivar-stat"><div class="icon">🪨</div><div class="value">${d.suelo.temperatura}°C</div><div class="label">Temp. suelo</div></div><div class="mi-olivar-stat"><div class="icon">💧</div><div class="value">${d.suelo.humedad}%</div><div class="label">Humedad</div></div><div class="mi-olivar-stat"><div class="icon">🚿</div><div class="value">${riegoDiario} L/ha</div><div class="label">Riego diario</div></div>`;
  const alertsHtml = (d.riesgosActivos || []).slice(0, 4).map(r => `<span class="mi-olivar-alert ${r.nivel}">${r.icono} ${r.titulo}</span>`).join('');
  MI_OLIVAR_ALERTS.innerHTML = alertsHtml || '<span class="mi-olivar-alert bajo">✅ Sin riesgos activos</span>';
}

// --- Render: Narrative section ---
function renderNarrativeSection(d) {
  if (!NARRATIVE_SECTION || !d || !d.comparacionHistorica) return;
  NARRATIVE_SECTION.classList.add('visible');
  const comp = d.comparacionHistorica;
  const tempClass = comp.variacion > 0 ? 'positivo' : comp.variacion < 0 ? 'negativo' : '';
  NARRATIVE_CONTENT.innerHTML = `<div class="narrative-item ${tempClass}"><div class="narrative-label">Temperatura actual vs media</div><div class="narrative-value">${comp.temperaturaActual}°C</div><div class="narrative-sub">${comp.mensaje}</div></div><div class="narrative-item ${comp.riesgoCalor ? 'positivo' : ''}"><div class="narrative-label">Riesgo de calor</div><div class="narrative-value">${comp.riesgoCalor ? '🔥 Alto' : '✅ Normal'}</div><div class="narrative-sub">${comp.riesgoCalor ? 'Protege del estrés térmico' : 'Condiciones normales'}</div></div><div class="narrative-item ${comp.deficitLluvia ? 'positivo' : ''}"><div class="narrative-label">Precipitación</div><div class="narrative-value">${comp.precipitacionActual}mm</div><div class="narrative-sub">${comp.deficitLluvia ? '⚠️ Déficit' : 'Normal'}</div></div>`;
}

// --- Render: Dashboard completo ---
function renderDashboard(d) {
  dashboardData = d;
  const plaga = d.plagas;
  const plagaIcons = (l) => l === 'alto' ? '🔴' : l === 'medio' ? '🟡' : '🟢';
  HERO_CONTEXTUAL.textContent = `${d.clima.temperatura}°C • 💧 ${d.clima.humedad}% • ${plaga.polilla ? `Polilla ${plagaIcons(plaga.polilla.nivel)}` : ''}`;
  CARD_SUELO_TEXT.textContent = `${Math.round(d.suelo?.temperatura || 0)}°C • 💧 ${Math.round((d.suelo?.humedad || 0) * 100)}% • 📈 ${(d.suelo?.evapotranspiracion || 0).toFixed(1)}mm`;
  CARD_VARIEDAD_TEXT.textContent = d.provinciaInfo?.variedadPredominante || 'N/A';
  CARD_CONSEJO_TEXT.textContent = d.consejos?.[0]?.replace(/^\S+\s/, '') || 'Sin consejo';
  if (CARD_CHAT_BTN) {
    const prov = OlivaxiEcosistema.provincia;
    const var_ = OlivaxiEcosistema.variedad;
    CARD_CHAT_BTN.onclick = (e) => {
      e.preventDefault();
      window.location.href = '/consejero?provincia=' + encodeURIComponent(prov) + (var_ ? '&variedad=' + encodeURIComponent(var_) : '');
    };
  }
  renderMiOlivarPanel(d);
  renderNarrativeSection(d);
  updateRiesgoBadge(d);
}

// --- Render maestro: se llama cuando cambia el estado del ecosistema ---
function renderAll() {
  const prov = OlivaxiEcosistema.provincia;
  const var_ = OlivaxiEcosistema.variedad;

  renderProvinciasGrid();
  renderVariedadesGrid();

  if (prov && datosClima.length) {
    const p = datosClima.find(x => x.provincia === prov);
    if (p) renderAlertasPanel(p);
  } else {
    renderAlertasPanel(null);
  }

  // Usar dashboard del ecosistema si existe
  const dash = OlivaxiEcosistema.dashboardData;
  if (dash && dash.provincia === prov) {
    renderDashboard(dash);
  }
}

// --- Carga inicial ---
let retryCount = 0;
async function loadData() {
  try {
    datosClima = await OlivaxiEcosistema.fetchClima();
    retryCount = 0;
    if (datosClima.length) {
      renderAll();
      // Si hay provincia guardada, fetch dashboard
      if (OlivaxiEcosistema.provincia) {
        const d = await OlivaxiEcosistema.fetchDashboard();
        if (d) renderDashboard(d);
      }
    }
  } catch (e) {
    console.error('[loadData] Error:', e);
    if (retryCount < 2) {
      retryCount++;
      setTimeout(loadData, 1000 * retryCount);
    } else if (PROVINCIAS_GRID) {
      PROVINCIAS_GRID.innerHTML = '<div class="no-province-msg">Error al cargar. <button onclick="location.reload()">Reintentar</button></div>';
    }
  }
}

// --- Escuchar cambios del ecosistema ---
OlivaxiEcosistema.onChange((state) => {
  renderProvinciasGrid();
  renderVariedadesGrid();

  // Si hay datos de clima, renderizar alertas
  if (datosClima.length && state.provincia) {
    const p = datosClima.find(x => x.provincia === state.provincia);
    if (p) renderAlertasPanel(p);
  } else {
    renderAlertasPanel(null);
  }

  // Si hay dashboard data del ecosistema, renderizar
  if (state.dashboardData && state.dashboardData.provincia === state.provincia) {
    renderDashboard(state.dashboardData);
  }
});

// --- Cerrar Mi Olivar ---
if (MI_OLIVAR_CLOSE) {
  MI_OLIVAR_CLOSE.addEventListener('click', () => {
    MI_OLIVAR_PANEL.classList.remove('visible');
  });
}

// --- Init ---
initCarousel();
loadData();
</script>
</Layout>
