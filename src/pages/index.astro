---
import Layout from '../layouts/Layout.astro';
import MapaCalor from '../components/MapaCalor.jsx';
import AlertasClimaticas from '../components/AlertasClimaticas.jsx';
import AnalisisOlivar from '../components/AnalisisOlivar.jsx';
import AlertasPlagas from '../components/AlertasPlagas.jsx';

const API_BASE = 'http://localhost:3000';
let climaData = [];
let heroStats = { tempMax: '--', tempMin: '--', avgTemp: '--', totalProvincias: 0 };

try {
  const res = await fetch(`${API_BASE}/api/clima`);
  if (res.ok) {
    climaData = await res.json();
    
    const temps = climaData.map((p: any) => p.temperatura).filter((t: number) => typeof t === 'number');
    if (temps.length > 0) {
      heroStats = {
        tempMax: Math.max(...temps).toFixed(1),
        tempMin: Math.min(...temps).toFixed(1),
        avgTemp: (temps.reduce((a: number, b: number) => a + b, 0) / temps.length).toFixed(1),
        totalProvincias: climaData.length
      };
    }
  }
} catch (e) {
  console.error('Error fetching clima:', e);
}

const getRiesgoEmoji = (riesgo: string) => {
  return riesgo === 'alto' ? '🔴' : riesgo === 'medio' ? '🟡' : '🟢';
};

const tablaProvinciasHTML = [...climaData]
  .sort((a: any, b: any) => b.temperatura - a.temperatura)
  .map((p: any) => `
    <tr class="riesgo-${p.riesgo}">
      <td style="font-weight: 600;">${p.provincia}</td>
      <td class="temp-cell">${p.temperatura}°C</td>
      <td>${p.humedad}%</td>
      <td>${p.lluvia}mm</td>
      <td>${p.estado || ''}</td>
      <td><span class="badge-riesgo ${p.riesgo}">${getRiesgoEmoji(p.riesgo)} ${p.riesgo}</span></td>
    </tr>
  `).join('');
---

<Layout title="olivaξ - Protege tu olivar del cambio climático">
  <style is:global>
  /* BENTO GRID */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    grid-template-rows: auto auto auto;
    gap: 10px;
    max-width: 1000px;
    margin: 80px auto 2rem;
    padding: 0 1rem;
  }

  @media (max-width: 767px) {
    .bento-grid { grid-template-columns: 1fr; }
  }

    .bento-card {
      background: var(--color-white-surface);
      border: 2px solid var(--color-border);
      border-radius: 6px;
      padding: 16px;
      overflow: hidden;
    }

    .bento-card.accent {
      background: var(--color-limon);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .stat-number {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 36px;
      color: var(--color-aceituna);
    }

    .stat-label {
      font-size: 11px;
      color: var(--color-muted);
    }

    .hero-card {
      background: var(--color-aceituna);
      border: 2px solid var(--color-aceituna);
      border-radius: 6px;
      padding: 20px 20px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .hero-title {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 38px;
      color: var(--color-sal);
      line-height: 1.2;
    }

    .hero-title em {
      color: var(--color-limon);
      font-style: normal;
    }

    .hero-subtitle {
      font-size: 13px;
      color: rgba(247,244,238,0.55);
      margin-top: 12px;
    }

    .hero-buttons {
      display: flex;
      gap: 12px;
      margin-top: 20px;
    }

    .hero-provincia {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.12);
    }

    .hero-provincia label {
      color: rgba(247,244,238,0.7);
      font-size: 13px;
    }

    .hero-provincia select {
      background: rgba(247,244,238,0.1);
      color: var(--color-sal);
      border: 1px solid rgba(247,244,238,0.3);
      border-radius: 4px;
      padding: 6px 12px;
      font-size: 14px;
      cursor: pointer;
    }

    .hero-provincia select option {
      background: var(--color-aceituna);
      color: var(--color-sal);
    }

    .btn-primary {
      background: var(--color-limon);
      color: var(--color-aceituna);
      padding: 10px 20px;
      border-radius: 4px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      border: 2px solid var(--color-limon);
    }

    .btn-secondary {
      background: transparent;
      color: rgba(247,244,238,0.8);
      padding: 10px 20px;
      border-radius: 4px;
      font-size: 14px;
      text-decoration: none;
      border: 2px solid rgba(247,244,238,0.3);
    }

    .hero-stats {
      display: flex;
      gap: 24px;
      margin-top: 24px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.12);
    }

    .hero-stat-item { display: flex; flex-direction: column; }

    .hero-stat-num {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 24px;
      color: var(--color-sal);
    }

    .hero-stat-label { font-size: 11px; color: rgba(240,237,230,0.6); }

    .consejero-preview h3 {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 14px;
      color: var(--color-aceituna);
      margin-bottom: 8px;
    }

    .consejero-preview p { font-size: 12px; color: var(--color-muted); line-height: 1.5; }

    .variedad-destacada {
      background: var(--color-white-surface);
      padding: 12px;
      border-radius: 4px;
    }

    .variedad-destacada h3 {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 14px;
      color: var(--color-aceituna);
      margin-bottom: 8px;
    }

    .variedad-destacada p { font-size: 12px; color: var(--color-muted); }

    .variedad-tag {
      display: inline-block;
      background: var(--color-limon);
      color: var(--color-aceituna);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 10px;
      margin-top: 8px;
      font-weight: 700;
    }

    .mapa-card { 
      padding: 0; 
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-height: 380px;
      height: 380px;
    }

    /* SECTION VALUES */
    .section-values { background-color: var(--color-sal); padding: 4rem 0; }

    .values-title {
      text-align: center;
      font-size: 1.875rem;
      font-weight: 700;
      color: var(--color-aceituna);
      margin-bottom: 3rem;
      font-family: Georgia, 'Palatino Linotype', serif;
    }

    .values-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 56rem;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    @media (min-width: 768px) { .values-grid { grid-template-columns: 1fr 1fr; } }

    .value-card {
      border-radius: 6px;
      padding: 2rem;
      border-top: 3px solid var(--color-aceituna);
    }

    .value-card.light { background-color: var(--color-white-surface); }
    .value-card.dark { background-color: var(--color-aceituna); color: var(--color-sal); }
    .value-card:hover { border-top-color: var(--color-limon); }

    .value-icon { font-size: 2.25rem; }

    .value-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin: 0.5rem 0;
      font-family: Georgia, 'Palatino Linotype', serif;
    }

    .value-card.dark h3 { color: var(--color-sal); }
    .value-card p { color: var(--color-muted); font-size: 0.9rem; }
    .value-card.dark p { color: rgba(247,244,238,0.7); }

    /* SECTION CTA */
    .section-cta { background: var(--color-aceituna); padding: 4rem 0; }

    .cta-content {
      text-align: center;
      color: var(--color-sal);
      max-width: 42rem;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .cta-title {
      font-size: 1.875rem;
      font-weight: 700;
      font-family: Georgia, 'Palatino Linotype', serif;
    }

    .cta-subtitle {
      color: rgba(247,244,238,0.8);
      margin-top: 1rem;
      line-height: 1.6;
    }

    .cta-btn {
      display: inline-block;
      background-color: var(--color-limon);
      color: var(--color-aceituna);
      padding: 1rem 2rem;
      border-radius: 4px;
      font-size: 1.125rem;
      font-weight: 700;
      text-decoration: none;
      margin-top: 2rem;
      border: none;
    }

    .cta-btn:hover { opacity: 0.9; }

    /* SECTION STEPS */
    .section-steps { background-color: var(--color-white-surface); padding: 4rem 0; }

    .steps-title {
      text-align: center;
      font-size: 1.875rem;
      font-weight: 700;
      color: var(--color-aceituna);
      margin-bottom: 3rem;
      font-family: Georgia, 'Palatino Linotype', serif;
    }

    .steps-container { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }

    .step { max-width: 20rem; text-align: center; }

    .step-number {
      font-size: 3.75rem;
      font-weight: 700;
      color: var(--color-limon);
      line-height: 1;
      font-family: Georgia, 'Palatino Linotype', serif;
    }

    .step-icon {
      background-color: var(--color-sal);
      border-radius: 4px;
      width: 4rem;
      height: 4rem;
      margin: 1rem auto;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }

    .step-title {
      font-weight: 700;
      color: var(--color-aceituna);
      margin-top: 1rem;
      font-family: Georgia, 'Palatino Linotype', serif;
    }

    .step-desc { color: var(--color-muted); font-size: 0.875rem; margin-top: 0.5rem; }

    /* SECTION SIGNUP */
    .section-signup { background-color: var(--color-muted); padding: 4rem 0; }

    .signup-content {
      text-align: center;
      color: var(--color-sal);
      max-width: 28rem;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .signup-title { font-size: 1.875rem; font-weight: 700; font-family: Georgia, 'Palatino Linotype', serif; }

    .signup-subtitle { margin-top: 1rem; color: rgba(247,244,238,0.8); }

    .signup-form { display: flex; gap: 0.5rem; margin-top: 2rem; justify-content: center; flex-wrap: wrap; }

    .signup-input {
      background-color: var(--color-sal);
      color: var(--color-aceituna);
      padding: 0.75rem 1rem;
      border-radius: 4px;
      width: 16rem;
      border: none;
    }

    .signup-input::placeholder { color: var(--color-muted); }

    .signup-btn {
      background-color: var(--color-limon);
      color: var(--color-aceituna);
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      font-weight: 700;
      border: none;
      cursor: pointer;
    }

    .signup-btn:hover { opacity: 0.9; }

    .signup-footer { font-size: 0.875rem; color: rgba(247,244,238,0.6); margin-top: 1rem; }

    /* MAPA */
    .mapa-loading { text-align: center; padding: 2rem 0; }
    .spinner {
      border: 4px solid #D4E849;
      border-top: 4px solid transparent;
      border-radius: 50%;
      width: 2rem;
      height: 2rem;
      margin: 0 auto 1rem;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .mapa-loading p { color: var(--color-muted); font-size: 12px; }
    .mapa-error { text-align: center; padding: 2rem 0; color: #ef4444; font-size: 12px; }
    .mapa-container { border-radius: 6px; overflow: hidden; height: 100%; }

    /* DECISIONES RÁPIDAS */
    .decisiones-rapidas { background: var(--color-aceituna); padding: 3rem 1rem; }

    .decisiones-container { max-width: 1000px; margin: 0 auto; }

    .decisiones-title {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 24px;
      color: var(--color-sal);
      text-align: center;
      margin-bottom: 2rem;
    }

    .decisiones-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    @media (max-width: 767px) {
      .decisiones-grid { grid-template-columns: 1fr; }
    }

    .decision-card {
      background: var(--color-white-surface);
      border: 2px solid var(--color-border);
      border-radius: 6px;
      padding: 20px;
    }

    .decision-card.temp { border-left: 4px solid var(--color-limon); }
    .decision-card.riesgo { border-left: 4px solid; }
    .decision-card.riesgo.bajo { border-left-color: #22c55e; }
    .decision-card.riesgo.medio { border-left-color: #f59e0b; }
    .decision-card.riesgo.alto { border-left-color: #ef4444; }
    .decision-card.acciones { border-left: 4px solid #8b5cf6; }

    .decision-label {
      font-size: 11px;
      color: var(--color-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .decision-value {
      font-family: Georgia, 'Palatino Linotype', serif;
      font-size: 28px;
      color: var(--color-aceituna);
      font-weight: 700;
    }

    .decision-value.alto { color: #ef4444; }
    .decision-value.medio { color: #f59e0b; }
    .decision-value.bajo { color: #22c55e; }

    .decision-actions {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .decision-actions li {
      font-size: 13px;
      color: var(--color-muted);
      padding: 6px 0;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .decision-actions li:last-child { border-bottom: none; }

    .decisiones-placeholder {
      grid-column: 1 / -1;
      text-align: center;
      color: var(--color-muted);
      padding: 2rem;
    }

    /* TABLA DE PROVINCIAS */
    .tabla-provincias {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }
    .tabla-provincias th {
      text-align: left;
      padding: 8px 6px;
      border-bottom: 2px solid var(--color-border);
      color: var(--color-muted);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .tabla-provincias td {
      padding: 8px 6px;
      border-bottom: 1px solid var(--color-border);
    }
    .tabla-provincias tr.riesgo-alto {
      background: rgba(239, 68, 68, 0.1);
    }
    .tabla-provincias tr.riesgo-medio {
      background: rgba(245, 158, 11, 0.1);
    }
    .tabla-provincias tr.riesgo-bajo {
      background: rgba(34, 197, 94, 0.1);
    }
    .tabla-provincias .temp-cell {
      font-weight: 700;
    }
    .badge-riesgo {
      padding: 2px 6px;
      border-radius: 3px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .badge-riesgo.alto {
      background: rgba(239, 68, 68, 0.2);
      color: #dc2626;
    }
    .badge-riesgo.medio {
      background: rgba(245, 158, 11, 0.2);
      color: #b45309;
    }
    .badge-riesgo.bajo {
      background: rgba(34, 197, 94, 0.2);
      color: #15803d;
    }

    /* ANALISIS CARD */
    .analisis-card {
      grid-column: 2;
      grid-row: 2;
    }

    @media (max-width: 767px) {
      .analisis-card { grid-column: 1; grid-row: auto; }
    }
  </style>

  <!-- BENTO GRID HERO -->
  <div class="bento-grid">
    <!-- Hero card principal - left side -->
    <div class="bento-card hero-card">
      <div>
        <h1 class="hero-title">
          Protege tu <em>olivar</em><br />
          del cambio climático
        </h1>
        <p class="hero-subtitle">
          Alertas climáticas, consejero experto y análisis de 
          variedades para el agricultor español.
        </p>
        <div class="hero-buttons">
          <a href="/variedades" class="btn-secondary" style="background: var(--color-white-surface); color: var(--color-aceituna);">Variedades →</a>
          <a href="/consejero" class="btn-primary">Hablar con el consejeros →</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat-item">
            <span class="hero-stat-num">{heroStats.tempMax}°</span>
            <span class="hero-stat-label">Máx</span>
          </div>
          <div class="hero-stat-item">
            <span class="hero-stat-num">{heroStats.tempMin}°</span>
            <span class="hero-stat-label">Mín</span>
          </div>
          <div class="hero-stat-item">
            <span class="hero-stat-num">{heroStats.avgTemp}°</span>
            <span class="hero-stat-label">Media</span>
          </div>
          <div class="hero-stat-item">
            <span class="hero-stat-num">{heroStats.totalProvincias}</span>
            <span class="hero-stat-label">Provincias</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Map - right side (large) -->
    <div class="bento-card mapa-card">
      <MapaCalor client:only="react" id="mapa-calor" />
    </div>

    <!-- Bottom row - Alertas Climáticas -->
    <div class="bento-card accent" style="grid-column: 1 / -1;">
      <AlertasClimaticas client:load />
    </div>

    <!-- Card análisis olivar -->
    <div class="bento-card" id="analisis-card">
      <AnalisisOlivar client:load id="analisis-olivar" />
    </div>

    <!-- Card alertas plagas -->
    <div class="bento-card" id="plagas-card">
      <AlertasPlagas client:load id="alertas-plagas" />
    </div>
  </div>

  <!-- TABLA DE PROVINCIAS -->
  <div style="max-width: 1000px; margin: 1rem auto; padding: 0 1rem;">
    <h3 style="font-family: Georgia, serif; color: var(--color-aceituna); margin-bottom: 0.5rem;">
      📊 Todas las provincias
    </h3>
    <div class="bento-card" style="padding: 0;">
      <table class="tabla-provincias" id="tabla-provincias">
        <thead>
          <tr>
            <th>Provincia</th>
            <th>Temp</th>
            <th>Humedad</th>
            <th>Lluvia</th>
            <th>Estado</th>
            <th>Riesgo</th>
          </tr>
        </thead>
        <tbody id="tabla-provincias-body">
          {climaData.length > 0 ? (
            <Fragment set:html={tablaProvinciasHTML} />
          ) : (
            <tr><td colspan="6" style="text-align: center; padding: 2rem;">Cargando datos...</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- DECISIONES RÁPIDAS -->
  <section class="decisiones-rapidas">
    <div class="decisiones-container">
      <h2 class="decisiones-title">⚡ Qué hacer hoy</h2>
      <div class="decisiones-grid" id="decisiones-grid">
        <div class="decisiones-placeholder">
          <p>Selecciona tu provincia arriba para ver las recomendaciones.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2 — Grid valores -->
  <section class="section-values">
    <h2 class="values-title">Todo lo que necesita tu olivar</h2>
    <div class="values-grid">
      <div class="value-card light">
        <div class="value-icon">🌡️</div>
        <h3>Clima en tiempo real</h3>
        <p>Temperatura y riesgo por provincia cada 6 horas</p>
      </div>
      <div class="value-card dark">
        <div class="value-icon">💬</div>
        <h3>Consejero experto</h3>
        <p>Respuestas basadas en el clima de hoy</p>
      </div>
      <div class="value-card dark">
        <div class="value-icon">🧬</div>
        <h3>Laboratorio de variedades</h3>
        <p>Compara resistencia al calor y sequía</p>
      </div>
      <div class="value-card light">
        <div class="value-icon">🔔</div>
        <h3>Alertas por email</h3>
        <p>Aviso cuando tu zona supere los 38°C</p>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 3 — Banner CTA -->
  <section class="section-cta">
    <div class="cta-content">
      <h2 class="cta-title">El calor extremo no avisa. Tú sí puedes.</h2>
      <p class="cta-subtitle">
        Regístrate gratis y recibe alertas cuando<br />
        tu provincia entre en riesgo alto
      </p>
      <a href="/alertas/nueva" class="cta-btn">Quiero mis alertas →</a>
    </div>
  </section>

  <!-- SECCIÓN 4 — Cómo funciona -->
  <section class="section-steps">
    <h2 class="steps-title">Así funciona olivaξ</h2>
    <div class="steps-container">
      <div class="step">
        <div class="step-number">01</div>
        <div class="step-icon">📍</div>
        <h3 class="step-title">Elige tu provincia</h3>
        <p class="step-desc">Selecciona dónde están tus olivos</p>
      </div>
      <div class="step">
        <div class="step-number">02</div>
        <div class="step-icon">🌡️</div>
        <h3 class="step-title">Monitoriza el clima</h3>
        <p class="step-desc">Seguimos la temperatura en tiempo real</p>
      </div>
      <div class="step">
        <div class="step-number">03</div>
        <div class="step-icon">📧</div>
        <h3 class="step-title">Recibe la alerta</h3>
        <p class="step-desc">Te avisamos antes de que llegue el calor</p>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 5 — CTA cierre -->
  <section class="section-signup">
    <div class="signup-content">
      <h2 class="signup-title">Empieza gratis hoy</h2>
      <p class="signup-subtitle">Sin tarjeta de crédito. Solo tu email y provincia.</p>
      <form class="signup-form" action="/api/register" method="POST">
        <input type="email" class="signup-input" placeholder="tucorreo@gmail.com" required />
        <button type="submit" class="signup-btn">Unirse a olivaξ</button>
      </form>
      <p class="signup-footer">🔒 Solo te escribimos cuando tu zona esté en riesgo</p>
    </div>
  </section>
</Layout>

<script>
  const decisionesGrid = document.getElementById('decisiones-grid');
  const analisisOlivar = document.getElementById('analisis-olivar');
  const alertasPlagas = document.getElementById('alertas-plagas');

  async function fetchAnalisisProvincia(provincia) {
    try {
      const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, '') || 'http://localhost:3000';
      const [climaRes, analisisRes] = await Promise.all([
        fetch(`${apiBase}/api/clima`),
        fetch(`${apiBase}/api/analisis/${encodeURIComponent(provincia)}`)
      ]);
      
      const datos = await climaRes.json();
      const analisis = analisisRes.ok ? await analisisRes.json() : null;
      
      const provData = datos.find((p) => p.provincia === provincia);
      if (provData) {
        renderDecisiones(provincia, analisis, provData);
        window.dispatchEvent(new CustomEvent('datos-provincia', {
          detail: {
            provincia: provData.provincia,
            temperatura: provData.temperatura,
            humedad: provData.humedad,
            lluvia: provData.lluvia,
            riesgos_plaga: provData.riesgos_plaga
          }
        }));
      } else {
        decisionesGrid.innerHTML = '<div class="decisiones-placeholder"><p>No hay datos para esta provincia.</p></div>';
      }
    } catch (err) {
      console.error('Error cargando datos:', err);
      decisionesGrid.innerHTML = '<div class="decisiones-placeholder"><p>Error al cargar datos.</p></div>';
    }
  }

  function renderDecisiones(provincia, analisis, climaData) {
    const tempDisplay = climaData?.temperatura ? `${climaData.temperatura}°C` : '--';
    const humedadDisplay = climaData?.humedad ? `${climaData.humedad}%` : '--';
    const lluviaDisplay = climaData?.lluvia ? `${climaData.lluvia}mm` : '--';
    const riesgo = climaData?.riesgo || 'bajo';
    
    const recomendaciones = analisis?.recomendaciones || [];
    const alertas = analisis?.alertas || [];

    decisionesGrid.innerHTML = `
      <div class="decision-card temp">
        <div class="decision-label">Temperatura actual</div>
        <div class="decision-value">${tempDisplay}</div>
        <div style="font-size: 10px; color: var(--color-muted); margin-top: 4px;">
          💧 ${humedadDisplay} · 🌧️ ${lluviaDisplay}
        </div>
      </div>
      <div class="decision-card riesgo ${riesgo}">
        <div class="decision-label">Nivel de riesgo</div>
        <div class="decision-value ${riesgo}">${riesgo === 'alto' ? 'Alto' : riesgo === 'medio' ? 'Medio' : 'Bajo'}</div>
        ${alertas.length > 0 ? `<div style="font-size: 10px; color: #ef4444; margin-top: 4px;">⚠️ ${alertas[0]}</div>` : ''}
      </div>
      <div class="decision-card acciones">
        <div class="decision-label">Recomendaciones</div>
        <ul class="decision-actions">
          ${recomendaciones.length > 0 
            ? recomendaciones.map(r => `<li>${r}</li>`).join('')
            : '<li>✅ Condiciones óptimas</li><li>🌱 Buenas condiciones para tratamientos</li>'}
        </ul>
      </div>
    `;
  }

  // Listen for province selection from map
  window.addEventListener('provincia-seleccionada', (e) => {
    const provincia = e.detail.provincia;
    fetchAnalisisProvincia(provincia);
  });
</script>