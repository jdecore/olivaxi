---
import Layout from '../layouts/Layout.astro';
import MapaCalor from '../components/MapaCalor.astro';
---

<Layout title="olivaξ - Protege tu olivar del cambio climático">
<style is:global>
.hero-section{min-height:40vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:50px 24px 30px;gap:16px}
.hero-title{font-size:clamp(36px,6vw,56px);font-weight:700;color:var(--color-aceituna);margin:0;max-width:700px}
.hero-subtitle{font-size:clamp(16px,2vw,20px);font-weight:400;color:var(--color-muted);margin:0;max-width:600px;line-height:1.5}
.hero-contextual{font-size:clamp(14px,1.5vw,16px);font-weight:600;color:var(--color-aceituna);margin-top:8px;padding:8px 16px;background:rgba(212,232,73,0.2);border-radius:20px}
@keyframes heroFadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.hero-title,.hero-subtitle,.hero-contextual{animation:heroFadeIn .8s ease-out both}
.hero-subtitle{animation-delay:.15s}
.hero-contextual{animation-delay:.3s}
@media(max-width:640px){.hero-section{min-height:30vh;padding:40px 16px 20px;gap:10px}.hero-title{font-size:1.75rem}.hero-subtitle{font-size:.9rem}}
.hero-badge{display:inline-block;padding:6px 14px;background:var(--color-limon);border-radius:20px;font-size:12px;font-weight:600;color:var(--color-aceituna);margin-bottom:12px}
.hero-stats{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin:16px 0;font-size:13px;color:var(--color-muted)}
.hero-stats span{white-space:nowrap}
.hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:8px}
.cta-primary{padding:12px 24px;background:var(--color-aceituna);color:var(--color-sal);border-radius:8px;font-weight:700;text-decoration:none;transition:transform .15s}
.cta-primary:hover{transform:translateY(-2px)}
.cta-secondary{padding:12px 24px;background:transparent;border:2px solid var(--color-aceituna);color:var(--color-aceituna);border-radius:8px;font-weight:600;text-decoration:none;transition:background .15s}
.cta-secondary:hover{background:var(--color-aceituna);color:var(--color-sal)}
.alert-strip{display:flex;align-items:center;justify-content:space-between;max-width:1200px;margin:0 auto 16px;padding:12px 20px;border-radius:8px;font-size:14px;font-weight:600}
.alert-strip.medio{background:rgba(245,158,11,.15);border:2px solid #f59e0b;color:#b45309}
.alert-strip.alto{background:rgba(239,68,68,.15);border:2px solid #ef4444;color:#dc2626}
.alert-strip-content{display:flex;align-items:center;gap:10px}
.alert-strip-icon{font-size:18px}
.alert-strip-btn{padding:8px 16px;background:currentColor;color:white;border-radius:6px;font-size:12px;text-decoration:none;white-space:nowrap}
.alert-strip.medio .alert-strip-btn{background:#f59e0b}
.alert-strip.alto .alert-strip-btn{background:#ef4444}
@media(max-width:600px){.alert-strip{flex-direction:column;gap:10px;text-align:center}}
.ecosistema-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:1200px;margin:0 auto 1rem;padding:0 1rem}
.eco-card{display:flex;align-items:center;gap:12px;padding:16px;background:var(--color-white-surface);border:2px solid var(--color-border);border-radius:8px;text-decoration:none;transition:transform .15s,border-color .15s}
.eco-card:hover{transform:translateY(-2px);border-color:var(--color-aceituna)}
.eco-icon{font-size:1.8rem;flex-shrink:0}
.eco-content{flex:1;min-width:0}
.eco-category{font-size:.65rem;font-weight:700;color:var(--color-muted);letter-spacing:.1em}
.eco-title{font-size:.95rem;font-weight:700;color:var(--color-aceituna);margin:2px 0}
.eco-desc{font-size:.8rem;color:var(--color-muted);margin:0}
@media(max-width:900px){.ecosistema-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.ecosistema-grid{grid-template-columns:1fr}}
.bento-grid{display:grid;grid-template-columns:60fr 40fr;gap:8px;max-width:1200px;margin:0 auto 1rem;padding:0 1rem}
.mapa-card,.sidebar-panels{background:var(--color-white-surface);border:2px solid var(--color-border);border-radius:6px;overflow:hidden}
.mapa-card{display:flex;flex-direction:column;height:450px}
.mapa-card :global(olivaxi-mapa){flex:1;min-height:0}
.sidebar-panels{background:var(--color-limon);height:450px}
.carousel-container{display:flex;flex-direction:column;height:100%}
.carousel-nav{display:flex;background:var(--color-limon);border-bottom:2px solid var(--color-border);flex-shrink:0}
.carousel-tab{flex:1;padding:12px 8px;border:none;border-right:1px solid var(--color-border);background:transparent;color:var(--color-aceituna);font-size:12px;font-weight:700;cursor:pointer;text-align:center}
.carousel-tab:last-child{border-right:none}
.carousel-tab:hover{background:rgba(255,255,255,.5)}
.carousel-tab.active{background:var(--color-white-surface)}
.carousel-slide{display:none;flex-direction:column;flex:1;padding:12px;gap:8px;overflow-y:auto}
.carousel-slide.active{display:flex}
.provincias-grid,.variedades-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px}
.provincia-btn,.variedad-btn{padding:10px 8px;border:1.5px solid var(--color-border);background:var(--color-white-surface);border-radius:4px;cursor:pointer;font-size:12px;font-weight:600;color:var(--color-aceituna);text-align:center}
.provincia-btn:hover,.variedad-btn:hover{background:var(--color-aceituna);color:var(--color-sal)}
.provincia-btn.selected,.variedad-btn.selected{background:var(--color-aceituna);color:var(--color-sal)}
.provincia-btn .riesgo-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:4px}
.riesgo-dot.alto{background:#ef4444}.riesgo-dot.medio{background:#f59e0b}.riesgo-dot.bajo{background:#22c55e}
.provincia-btn .temp{font-size:10px;color:var(--color-muted);display:block;margin-top:2px}
.variedad-btn{text-align:left}.variedad-btn .nombre{font-weight:700}
.variedad-btn .riesgo-label{font-size:9px;padding:2px 5px;border-radius:3px;display:inline-block;margin-top:4px}
.riesgo-label.alto{background:rgba(239,68,68,.15);color:#dc2626}.riesgo-label.medio{background:rgba(245,158,11,.15);color:#b45309}.riesgo-label.bajo{background:rgba(34,197,94,.15);color:#15803d}
.variedades-link{display:block;text-align:center;padding:8px;margin-top:8px;background:var(--color-white-surface);border:1.5px dashed var(--color-border);border-radius:4px;color:var(--color-aceituna);font-size:11px;font-weight:600;text-decoration:none}
.variedades-link:hover{background:var(--color-aceituna);color:var(--color-sal);border-style:solid}
.alertas-list{flex:1;overflow-y:auto}
.riesgos-categorias{display:flex;flex-direction:column;gap:8px}
.riesgo-categoria{padding:8px;background:rgba(255,255,255,.55);border:1px solid var(--color-border);border-radius:6px}
.riesgo-categoria-titulo{font-size:10px;font-weight:700;color:var(--color-aceituna);margin-bottom:6px}
.alerta-item{padding:8px;margin-bottom:6px;border-radius:4px;border-left:3px solid;font-size:11px;background:var(--color-white-surface)}
.alerta-item.alto{border-color:#ef4444}.alerta-item.medio{border-color:#f59e0b}.alerta-item.bajo{border-color:#22c55e}
.alerta-actions{display:flex;gap:8px;flex-shrink:0}
.alerta-action-btn{flex:1;padding:8px;border:1.5px solid var(--color-border);background:var(--color-white-surface);border-radius:4px;font-size:11px;font-weight:600;color:var(--color-aceituna);text-decoration:none;text-align:center}
.alerta-action-btn:hover{background:var(--color-aceituna);color:var(--color-sal)}
.no-province-msg{text-align:center;padding:16px;color:var(--color-aceituna);font-size:12px;background:var(--color-white-surface);border-radius:4px}
.provincia-info{padding:8px;margin-bottom:8px;background:rgba(212,232,73,0.15);border-radius:6px;font-size:10px}
.provincia-info div{margin-bottom:2px}
.quick-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:8px}
.quick-stat{padding:6px;text-align:center;background:var(--color-white-surface);border-radius:4px;border:1px solid var(--color-border)}
.quick-stat .icon{font-size:14px}
.quick-stat .value{font-size:11px;font-weight:700;color:var(--color-aceituna)}
.quick-stat .label{font-size:8px;color:var(--color-muted)}
.consejos-panel{margin-top:8px;padding:8px;background:rgba(255,255,255,0.7);border-radius:4px;border-left:3px solid var(--color-limon)}
.consejos-panel .titulo{font-size:10px;font-weight:700;color:var(--color-aceituna);margin-bottom:4px}
.consejos-panel .consejo{font-size:9px;color:var(--color-muted);margin-bottom:2px}
@media(max-width:900px){.bento-grid{grid-template-columns:1fr}.mapa-card{height:300px}.sidebar-panels{min-height:300px}}
@media(max-width:600px){.bento-grid{gap:6px;padding:0 .5rem}.mapa-card{height:260px}.sidebar-panels{min-height:260px}.provincias-grid,.variedades-grid{gap:4px}}
.mi-olivar-panel{display:none;margin:0 auto 1rem;padding:0 1rem;max-width:1200px}
.mi-olivar-panel.visible{display:block}
.mi-olivar-card{background:var(--color-white-surface);border:2px solid var(--color-limon);border-radius:8px;padding:16px;position:relative}
.mi-olivar-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.mi-olivar-title{font-size:.9rem;font-weight:700;color:var(--color-aceituna);display:flex;align-items:center;gap:8px}
.mi-olivar-close{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--color-muted);padding:4px}
.mi-olivar-content{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px}
.mi-olivar-stat{padding:10px;background:rgba(212,232,73,.1);border-radius:6px;text-align:center}
.mi-olivar-stat .icon{font-size:1.2rem}
.mi-olivar-stat .value{font-size:1.1rem;font-weight:700;color:var(--color-aceituna)}
.mi-olivar-stat .label{font-size:.7rem;color:var(--color-muted)}
.mi-olivar-alerts{margin-top:12px;display:flex;flex-wrap:wrap;gap:6px}
.mi-olivar-alert{padding:4px 10px;border-radius:12px;font-size:.75rem;font-weight:600}
.mi-olivar-alert.alto{background:rgba(239,68,68,.15);color:#dc2626}
.mi-olivar-alert.medio{background:rgba(245,158,11,.15);color:#b45309}
.mi-olivar-alert.bajo{background:rgba(34,197,94,.15);color:#15803d}
.mi-olivar-actions{display:flex;gap:8px;margin-top:12px}
.mi-olivar-btn{flex:1;padding:8px;border:1.5px solid var(--color-border);background:var(--color-white-surface);border-radius:6px;font-size:.8rem;font-weight:600;color:var(--color-aceituna);text-decoration:none;text-align:center}
.mi-olivar-btn:hover{background:var(--color-limon)}
.narrative-section{display:none;margin:0 auto 1rem;padding:0 1rem;max-width:1200px}
.narrative-section.visible{display:block}
.narrative-card{background:var(--color-white-surface);border:2px solid var(--color-border);border-radius:8px;padding:20px}
.narrative-title{font-size:1rem;font-weight:700;color:var(--color-aceituna);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.narrative-content{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}
.narrative-item{padding:12px;background:rgba(212,232,73,.1);border-radius:6px}
.narrative-item .narrative-label{font-size:.75rem;color:var(--color-muted);margin-bottom:4px}
.narrative-item .narrative-value{font-size:1.1rem;font-weight:700;color:var(--color-aceituna)}
.narrative-item .narrative-sub{font-size:.8rem;color:var(--color-muted)}
.narrative-item.positivo .narrative-value{color:#dc2626}
.narrative-item.negativo .narrative-value{color:#15803d}
.riesgo-badge{position:absolute;top:10px;right:10px;z-index:10;padding:6px 12px;border-radius:20px;font-size:11px;font-weight:700;background:var(--color-white-surface);border:2px solid;display:flex;align-items:center;gap:6px;cursor:pointer;transition:transform .15s ease}
.riesgo-badge:hover{transform:scale(1.05)}
.riesgo-badge.alto{border-color:#ef4444;color:#dc2626}
.riesgo-badge.medio{border-color:#f59e0b;color:#b45309}
.riesgo-badge.bajo{border-color:#22c55e;color:#15803d}
.mapa-card{position:relative;transition:border-color .3s ease,border-width .3s ease}
.mapa-card.riesgo-alto{border-color:#ef4444;border-width:4px}
.mapa-card.riesgo-medio{border-color:#f59e0b;border-width:4px}
.mapa-card.riesgo-bajo{border-color:#22c55e;border-width:2px}
.card-actions{padding:0 12px 12px}
.card-btn-secondary{display:block;text-align:center;padding:8px;background:var(--color-limon);border-radius:6px;font-size:11px;font-weight:600;color:var(--color-aceituna);text-decoration:none;transition:background .15s ease,color .15s ease}
.card-btn-secondary:hover{background:var(--color-aceituna);color:var(--color-sal)}
</style>

<section class="hero-section">
<span class="hero-badge">📡 Monitor en tiempo real · 10 provincias · Datos científicos</span>
<h1 class="hero-title">Tu olivar protegido con datos reales</h1>
<p class="hero-subtitle">Temperatura, humedad, plagas y riego en un solo lugar. Datos científicos actualizados cada 6 horas.</p>
<div class="hero-stats">
<span>6 variedades</span>·<span>10 provincias</span>·<span>4 plagas</span>·<span>actualización cada 6h</span>
</div>
<div class="hero-ctas">
<a href="#mapa-card-wrapper" class="cta-primary">Ver mi olivar</a>
<a href="/consejero" class="cta-secondary">Hablar con el counsellor IA</a>
</div>
</section>

<div id="alert-strip" class="alert-strip" style="display:none">
  <div class="alert-strip-content">
    <span class="alert-strip-icon"></span>
    <span class="alert-strip-text"></span>
  </div>
  <a href="/alertas" class="alert-strip-btn">Activar alertas</a>
</div>

<div class="bento-grid">
  <div class="mapa-card" id="mapa-card-wrapper"><MapaCalor id="mapa-calor" /><div class="riesgo-badge bajo" id="riesgo-badge">✅ Sin riesgo</div></div>
<div class="sidebar-panels carousel-container">
<div class="carousel-nav">
