---
import Layout from '../layouts/Layout.astro';
import ProvinciaSelect from '../components/ProvinciaSelect.astro';
import VariedadSelect from '../components/VariedadSelect.astro';
import { ICONOS_ALERTAS } from '../lib/variedades';
---

<Layout title="Alertas - olivaξ">
  <!-- Hero -->
  <section class="alertas-hero">
    <h1>🔔 Alertas Inteligentes para tu Olivar</h1>
    <p>Te avisamos cuando las condiciones climáticas o plagas afecten a tu cultivo. Datos reales de tu provincia basados en RAIF.</p>
    <p style="font-size: 0.85rem; opacity: 0.7; margin-top: 0.5rem;">
      🌱 Datos climáticos + 🦟 Plagas activas + 🪨 Consejos según tu suelo
    </p>
  </section>

  <!-- Form -->
  <section class="alertas-section">
    <div id="provincia-info" class="provincia-info-panel"></div>
    <form id="form-alerta" class="alertas-form">
      <div class="form-field">
        <label for="nombre">Tu nombre</label>
        <input id="nombre" type="text" required />
      </div>

      <div class="form-field">
        <label for="email">Tu email</label>
        <input id="email" type="email" required />
      </div>

      <div class="form-field">
        <label for="provincia">Provincia</label>
        <ProvinciaSelect id="provincia" />
      </div>

      <div class="form-field">
        <label for="variedad">Variedad de olivo</label>
        <VariedadSelect id="variedad" />
      </div>

      <div class="form-field">
        <label for="tipo">Tipo de alerta</label>
        <select id="tipo">
          <option value="">Selecciona...</option>
        </select>
      </div>

      <div class="form-field">
        <label for="fenologia">Fase fenológica (opcional)</label>
        <select id="fenologia">
          <option value="">No específica</option>
          <option value="reposo">🌑 Reposo (Nov-Ene)</option>
          <option value="brotacion">🌱 Brotación (Feb-Mar)</option>
          <option value="floracion">🌸 Floración (Abr-May)</option>
          <option value="cuaje">🫒 Cuaje (May-Jun)</option>
          <option value="desarrollo">📈 Desarrollo fruto (Jun-Ago)</option>
          <option value="envero">🍇 Envero (Sep-Oct)</option>
          <option value="cosecha">🧺 Cosecha (Oct-Nov)</option>
        </select>
      </div>

      <button id="btn-submit" type="button">Activar alerta 🔔</button>

      <p class="alertas-info">Se te avisará cuando cualquier riesgo aparezca en tu zona para tu cultivo de olivo.</p>

      <div id="mensaje" hidden></div>
    </form>
  </section>
</Layout>

<style is:global>
  .alertas-hero {
    background: var(--color-aceituna);
    color: var(--color-sal);
    padding: 100px 1rem 3rem;
    text-align: center;
  }

  .alertas-hero h1 {
    font-size: 1.875rem;
    font-weight: 700;
    font-family: 'Literata', Georgia, serif;
  }

  .alertas-hero p {
    color: rgba(247,244,238,0.7);
    margin-top: 0.5rem;
  }

  .alertas-section {
    background-color: var(--color-sal);
    padding: 2rem 1rem;
  }

  .alertas-form {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid rgba(28, 28, 28, 0.15);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    max-width: 100%;
    margin: 0 auto;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255,255,255,0.5) inset;
    animation: formEntry 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    opacity: 0;
    transform: translateY(60px) scale(0.9);
  }

  @keyframes formEntry {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .form-field {
    margin-bottom: 1rem;
    opacity: 1;
    animation: none;
    transform: none;
  }

  .form-field:nth-child(1) { animation-delay: 0s; }
  .form-field:nth-child(2) { animation-delay: 0s; }
  .form-field:nth-child(3) { animation-delay: 0s; }
  .form-field:nth-child(4) { animation-delay: 0s; }
  .form-field:nth-child(5) { animation-delay: 0s; }
  .form-field:nth-child(6) { animation-delay: 0s; }

  .form-field label {
    display: block;
    font-weight: 800;
    color: var(--color-aceituna);
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }

  .form-field input,
  .form-field select {
    width: 100%;
    background: rgba(247, 244, 238, 0.9);
    border: 2px solid rgba(28, 28, 28, 0.2);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    color: var(--color-aceituna);
    font-size: 1rem;
    font-family: 'Outfit', system-ui, sans-serif;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, border-color 0.3s ease, filter 0.3s ease;
    will-change: transform;
  }

  .form-field input:hover,
  .form-field select:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 10px 25px rgba(212, 232, 73, 0.3);
    border-color: rgba(212, 232, 73, 0.5);
  }

  .form-field label:hover {
    color: var(--color-limon);
  }

  .form-field input:focus,
  .form-field select:focus {
    outline: none;
    border-color: var(--color-limon);
    box-shadow: 0 0 0 4px rgba(212, 232, 73, 0.4), 0 8px 25px rgba(212, 232, 73, 0.25);
    transform: scale(1.03) translateY(-2px);
    filter: brightness(1.05);
    background: var(--color-white);
  }

  #btn-submit {
    width: 100%;
    background: linear-gradient(135deg, var(--color-aceituna) 0%, #3C3C3C 100%);
    color: var(--color-white);
    padding: 1rem 1.5rem;
    border-radius: 14px;
    font-weight: 800;
    margin-top: 1.5rem;
    cursor: pointer;
    border: none;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    box-shadow: 0 10px 30px rgba(28, 28, 28, 0.3);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, filter 0.3s ease;
    will-change: transform;
    opacity: 1;
    animation: none;
    position: relative;
    overflow: hidden;
  }

  #btn-submit::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -75%;
    width: 40%;
    height: 300%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
    transform: skewX(-20deg);
    animation: shine 4s linear infinite;
  }

  @keyframes shine {
    100% { left: 150%; }
  }

  @keyframes btnEntry {
    to { opacity: 1; transform: translateY(0); }
  }

  #btn-submit:hover { 
    transform: translateY(-6px) scale(1.05);
    filter: brightness(1.3);
    box-shadow: 0 20px 40px rgba(212, 232, 73, 0.4);
  }

  #btn-submit:active {
    transform: scale(0.95) translateY(-2px);
    transition-duration: 0.1s;
    filter: brightness(0.9);
  }

  #btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .provincia-info-panel {
    background: rgba(212, 232, 73, 0.1);
    border: 2px solid var(--color-limon);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    display: none;
  }

  .provincia-info-panel.show { display: block; }

  .provincia-info-panel h4 {
    margin: 0 0 0.5rem;
    color: var(--color-aceituna);
    font-size: 1rem;
  }

  .provincia-info-panel .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .provincia-info-panel .info-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .provincia-info-panel .consejos {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    font-size: 0.75rem;
    list-style: none;
  }

  .provincia-info-panel .consejos li {
    margin-bottom: 0.25rem;
  }

  .provincia-info-panel .info-section {
    margin-bottom: 0.6rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .provincia-info-panel .info-section:last-child {
    border-bottom: none;
  }

  .provincia-info-panel .info-title {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-aceituna);
    margin-bottom: 0.3rem;
    letter-spacing: 0.05em;
  }

  .provincia-info-panel .info-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.3rem;
  }

  .provincia-info-panel .info-item {
    font-size: 0.7rem;
    padding: 3px 5px;
    background: rgba(255,255,255,0.5);
    border-radius: 4px;
  }

  .provincia-info-panel .riesgo-item {
    padding: 4px 6px;
    margin-bottom: 3px;
    border-radius: 4px;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .alertas-info {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-align: center;
    margin-top: 1rem;
    font-weight: 600;
  }

  #mensaje {
    margin-top: 1rem;
    border-radius: 12px;
    padding: 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(15px) scale(0.95);
    transition: opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #mensaje.show {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #mensaje.hidden { display: none; }

  #mensaje.warning {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  #mensaje.success {
    background: #22c55e;
    border: 2px solid #22c55e;
    color: #166534;
  }

  #mensaje.error {
    background: #ef4444;
    border: 2px solid #ef4444;
    color: var(--color-white);
  }

  @media (max-width: 480px) {
    .alertas-form {
      padding: 1.5rem 1rem;
      border-radius: 16px;
    }
    .alertas-hero { padding: 100px 1rem 2rem; }
    .alertas-hero h1 { font-size: 1.5rem; }
    .alertas-hero p { font-size: 0.9rem; }
    .form-field { margin-bottom: 0.75rem; }
    .form-field label { font-size: 0.75rem; }
    #btn-submit { padding: 0.85rem 1rem; font-size: 0.9rem; }
  }
</style>

<script>
  import OlivaxiEcosistema from '../lib/ecosistema';
  import { ICONOS_ALERTAS } from '../lib/variedades';
  import { apiUrl } from '../lib/api';

  const btn = document.getElementById("btn-submit");
  const msg = document.getElementById("mensaje");
  const form = document.getElementById("form-alerta");
  const provinciaInfoPanel = document.getElementById("provincia-info");
  const selectTipo = document.getElementById("tipo");
  const provinciaSelect = document.getElementById("provincia");
  const variedadSelect = document.getElementById("variedad");

  // --- Cargar datos de provincia via ecosistema ---
  async function cargarDatosProvincia() {
    const provincia = OlivaxiEcosistema.provincia;
    if (!provincia || !provinciaInfoPanel) return;

    const d = await OlivaxiEcosistema.fetchDashboard();
    if (!d) return;

    const getIcono = (nivel) => nivel === 'alto' ? '🔴' : nivel === 'medio' ? '🟡' : '🟢';
    
    const riesgosHTML = d.riesgosActivos?.length 
      ? d.riesgosActivos.map(r => `<div class="riesgo-item ${r.nivel}"><span>${r.icono}</span> ${r.titulo} - ${r.nivel.toUpperCase()}</div>`).join('')
      : '<div class="riesgo-item bajo">✅ Sin riesgos activos</div>';
    
    const consejosHTML = d.consejos?.length
      ? d.consejos.slice(0, 2).map(c => `<li>💡 ${c.replace(/^\S+\s/, '')}</li>`).join('')
      : '';
    
    provinciaInfoPanel.innerHTML = `
      <h4>📍 ${provincia} - Datos en tiempo real</h4>
      <div class="info-section">
        <div class="info-title">🌡️ CLIMA</div>
        <div class="info-grid">
          <div class="info-item">🌡️ <b>${d.clima.temperatura}°C</b></div>
          <div class="info-item">💧 <b>${d.clima.humedad}%</b></div>
          <div class="info-item">🌧️ <b>${d.clima.lluvia}mm</b></div>
          <div class="info-item">📊 <b>${d.clima.estado}</b></div>
        </div>
      </div>
      <div class="info-section">
        <div class="info-title">🪨 SUELO</div>
        <div class="info-grid">
          <div class="info-item">🌡️ suelo <b>${Math.round(d.suelo?.temperatura || 0)}°C</b></div>
          <div class="info-item">💧 suelo <b>${Math.round(d.suelo?.humedad || 0)}%</b></div>
          <div class="info-item">📈 ETo <b>${(d.suelo?.evapotranspiracion || 0).toFixed(1)}mm</b></div>
          <div class="info-item">🚿 déficit <b>${(d.sueloAnalitica?.deficitRiego || 0).toFixed(1)}mm</b></div>
          <div class="info-item">🫒 <b>${d.provinciaInfo?.variedadPredominante || 'N/A'}</b></div>
          <div class="info-item">🪨 <b>${d.provinciaInfo?.tipoSuelo || 'N/A'}</b></div>
          <div class="info-item">⛰️ <b>${d.provinciaInfo?.altitud || '?'}m</b></div>
          <div class="info-item">🌧️ <b>${d.provinciaInfo?.pluviometriaAnual || '?'}mm</b></div>
        </div>
      </div>
      <div class="info-section">
        <div class="info-title">🦟 PLAGAS (RAIF)</div>
        <div class="info-grid">
          <div class="info-item">🪰 ${getIcono(d.plagas?.mosca?.nivel)} <b>${d.plagas?.mosca?.nivel || 'bajo'}</b></div>
          <div class="info-item">🦋 ${getIcono(d.plagas?.polilla?.nivel)} <b>${d.plagas?.polilla?.nivel || 'bajo'}</b></div>
          <div class="info-item">🍂 ${getIcono(d.plagas?.repilo?.nivel)} <b>${d.plagas?.repilo?.nivel || 'bajo'}</b></div>
          <div class="info-item">🚨 ${getIcono(d.plagas?.xylella?.nivel)} <b>${d.plagas?.xylella?.nivel || 'bajo'}</b></div>
          <div class="info-item">🦠 ${getIcono(d.plagas?.tuberculosis?.nivel)} <b>${d.plagas?.tuberculosis?.nivel || 'bajo'}</b></div>
          <div class="info-item">🪲 ${getIcono(d.plagas?.barrenillo?.nivel)} <b>${d.plagas?.barrenillo?.nivel || 'bajo'}</b></div>
          <div class="info-item">🐛 ${getIcono(d.plagas?.cochinilla?.nivel)} <b>${d.plagas?.cochinilla?.nivel || 'bajo'}</b></div>
          <div class="info-item">🍄 ${getIcono(d.plagas?.phytophthora?.nivel)} <b>${d.plagas?.phytophthora?.nivel || 'bajo'}</b></div>
          <div class="info-item">🤕 ${getIcono(d.plagas?.lepra?.nivel)} <b>${d.plagas?.lepra?.nivel || 'bajo'}</b></div>
          <div class="info-item">🥀 ${getIcono(d.plagas?.verticillium?.nivel)} <b>${d.plagas?.verticillium?.nivel || 'bajo'}</b></div>
        </div>
      </div>
      <div class="info-section">
        <div class="info-title">⚠️ RIESGOS ACTIVOS</div>
        ${riesgosHTML}
      </div>
      ${consejosHTML ? `<div class="info-section"><div class="info-title">💡 CONSEJOS</div><ul class="consejos">${consejosHTML}</ul></div>` : ''}
    `;
    provinciaInfoPanel.classList.add('show');
  }

  // --- Calcular tipos de alerta ---
  async function actualizarTipoAlerta() {
    const provincia = OlivaxiEcosistema.provincia;
    const variedad = OlivaxiEcosistema.variedad;
    
    selectTipo.innerHTML = '<option value="">Selecciona...</option>';
    if (!provincia) return;

    try {
      const res = await fetch(apiUrl(`/api/alertas/tipos?provincia=${encodeURIComponent(provincia)}&variedad=${encodeURIComponent(variedad)}`));
      if (!res.ok) return;
      const data = await res.json();
      const alertas = data.tipos || [];

      if (alertas.length === 0) {
        const opt = document.createElement("option");
        opt.value = "condiciones_optimas";
        opt.textContent = ICONOS_ALERTAS.condiciones_optimas.label;
        selectTipo.appendChild(opt);
        selectTipo.value = "condiciones_optimas";
      } else {
        alertas.forEach((alerta) => {
          const opt = document.createElement("option");
          opt.value = alerta;
          opt.textContent = ICONOS_ALERTAS[alerta]?.label || alerta;
          selectTipo.appendChild(opt);
        });
        if (alertas.includes('todas_alertas')) {
          selectTipo.value = 'todas_alertas';
        } else {
          selectTipo.value = alertas[0];
        }
      }
    } catch (e) {
      console.error("Error calculating alert types:", e);
    }
  }

  async function confirmarTokenDesdeURL() {
    const params = new URLSearchParams(window.location.search);
    const token = params.get('verify');
    if (!token) return;

    if (msg) {
      msg.textContent = "⏳ Confirmando alerta...";
      msg.className = "warning show";
      msg.removeAttribute("hidden");
    }

    try {
      const res = await fetch(apiUrl('/api/alertas/verify'), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || "No se pudo confirmar");

      if (msg) {
        msg.textContent = "✅ Alerta confirmada correctamente. Ya recibirás notificaciones.";
        msg.className = "success show";
        msg.removeAttribute("hidden");
      }

      const cleanUrl = window.location.origin + window.location.pathname;
      window.history.replaceState({}, "", cleanUrl);
    } catch (e) {
      if (msg) {
        msg.textContent = `❌ ${e?.message || "Error al confirmar alerta"}`;
        msg.className = "error show";
        msg.removeAttribute("hidden");
      }
    }
  }

  // --- Escuchar cambios del ecosistema ---
  const offEcosistema = OlivaxiEcosistema.onChange((state) => {
    if (provinciaSelect && state.provincia && provinciaSelect.value !== state.provincia) {
      provinciaSelect.value = state.provincia;
    }
    if (variedadSelect && state.variedad && variedadSelect.value !== state.variedad) {
      variedadSelect.value = state.variedad;
    }
    if (state.provincia) {
      cargarDatosProvincia();
      actualizarTipoAlerta();
    }
  });
  window.addEventListener('beforeunload', offEcosistema);

  // --- Submit del formulario ---
  btn?.addEventListener("click", async () => {
    const nombre = document.getElementById("nombre").value.trim();
    const email = document.getElementById("email").value.trim();
    const provincia = OlivaxiEcosistema.provincia;
    const variedad = OlivaxiEcosistema.variedad;
    const tipo = selectTipo.value;
    const fenologia = document.getElementById("fenologia").value;

    if (!nombre || !email || !provincia) {
      msg.textContent = "⚠️ Por favor completa los campos obligatorios.";
      msg.className = "warning show";
      msg.removeAttribute("hidden");
      return;
    }

    btn.textContent = "Activando...";
    btn.disabled = true;

    try {
      const res = await fetch(apiUrl('/api/alertas'), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nombre, email, provincia, variedad, tipo, fenologia }),
      });

      if (res.ok) {
        const data = await res.json().catch(() => ({}));
        msg.textContent = data.message ? `✅ ${data.message}` : "✅ ¡Alerta activada!";
        msg.className = "success show";
      } else {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || "Respuesta no OK");
      }
    } catch (e) {
      msg.textContent = `❌ ${e?.message || "Algo salió mal. Inténtalo de nuevo."}`;
      msg.className = "error show";
    } finally {
      msg.removeAttribute("hidden");
      btn.textContent = "Activar alerta 🔔";
      btn.disabled = false;
    }
  });

  // --- Carga inicial si ya hay provincia ---
  confirmarTokenDesdeURL();

  if (OlivaxiEcosistema.provincia) {
    if (provinciaSelect && !provinciaSelect.value) provinciaSelect.value = OlivaxiEcosistema.provincia;
    if (variedadSelect && OlivaxiEcosistema.variedad && !variedadSelect.value) variedadSelect.value = OlivaxiEcosistema.variedad;
    cargarDatosProvincia();
    actualizarTipoAlerta();
  }
</script>
