---
import Layout from '../layouts/Layout.astro';
import { ICONOS_ALERTAS } from '../lib/variedades';
---

<Layout title="Alertas - olivaξ">
  <!-- Hero -->
  <section class="alertas-hero">
    <h1>🔔 Alertas para tu Cultivo</h1>
    <p>Te avisamos cuando las condiciones climáticas afecten a tu olivar</p>
  </section>

  <!-- Form -->
  <section class="alertas-section">
    <form id="form-alerta" class="alertas-form">
      <div class="form-field">
        <label for="nombre">Tu nombre</label>
        <input id="nombre" type="text" required />
      </div>

      <div class="form-field">
        <label for="email">Tu email</label>
        <input id="email" type="email" required />
      </div>

      <div class="form-field">
        <label for="provincia">Provincia</label>
        <select id="provincia">
          <option value="">Selecciona tu provincia...</option>
          <option value="Jaén">Jaén</option>
          <option value="Córdoba">Córdoba</option>
          <option value="Sevilla">Sevilla</option>
          <option value="Granada">Granada</option>
          <option value="Málaga">Málaga</option>
          <option value="Badajoz">Badajoz</option>
          <option value="Toledo">Toledo</option>
          <option value="Ciudad Real">Ciudad Real</option>
          <option value="Almería">Almería</option>
          <option value="Huelva">Huelva</option>
        </select>
      </div>

      <div class="form-field">
        <label for="variedad">Variedad de olivo</label>
        <select id="variedad">
          <option value="">Selecciona tu variedad...</option>
          <option value="cornicabra">Cornicabra</option>
          <option value="picual">Picual</option>
          <option value="arbequina">Arbequina</option>
          <option value="hojiblanca">Hojiblanca</option>
          <option value="manzanilla">Manzanilla</option>
          <option value="empeltre">Empeltre</option>
        </select>
      </div>

      <div class="form-field">
        <label for="tipo">Tipo de alerta</label>
        <select id="tipo">
          <option value="">Selecciona...</option>
        </select>
      </div>

      <div class="form-field">
        <label for="fenologia">Fase fenológica (opcional)</label>
        <select id="fenologia">
          <option value="">No específica</option>
          <option value="reposo">🌑 Reposo (Nov-Ene)</option>
          <option value="brotacion">🌱 Brotación (Feb-Mar)</option>
          <option value="floracion">🌸 Floración (Abr-May)</option>
          <option value="cuaje">🫒 Cuaje (May-Jun)</option>
          <option value="desarrollo">📈 Desarrollo fruto (Jun-Ago)</option>
          <option value="envero">🍇 Envero (Sep-Oct)</option>
          <option value="cosecha">🧺 Cosecha (Oct-Nov)</option>
        </select>
      </div>

      <button id="btn-submit" type="button">Activar alerta 🔔</button>

      <p class="alertas-info">Se te avisará cuando cualquier riesgo aparezca en tu zona para tu cultivo de olivo.</p>

      <div id="mensaje" hidden></div>
    </form>
  </section>
</Layout>

<style is:global>
  .alertas-hero {
    background: var(--color-aceituna);
    color: var(--color-sal);
    padding: 100px 1rem 3rem;
    text-align: center;
  }

  .alertas-hero h1 {
    font-size: 1.875rem;
    font-weight: 700;
    font-family: 'Literata', Georgia, serif;
  }

  .alertas-hero p {
    color: rgba(247,244,238,0.7);
    margin-top: 0.5rem;
  }

  .alertas-section {
    background-color: var(--color-sal);
    padding: 3rem 1rem;
  }

  .alertas-form {
    background: var(--color-white-surface);
    border: 2px solid var(--color-border);
    border-radius: 6px;
    padding: 2rem;
    max-width: 28rem;
    margin: 0 auto;
  }

  .form-field { margin-bottom: 1rem; }

  .form-field label {
    display: block;
    font-weight: 700;
    color: var(--color-aceituna);
    margin-bottom: 0.25rem;
  }

  .form-field input,
  .form-field select {
    width: 100%;
    background: var(--color-sal);
    border: 2px solid var(--color-border);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    color: var(--color-aceituna);
    font-size: 1rem;
  }

  .form-field input:focus,
  .form-field select:focus {
    outline: none;
    border-color: var(--color-limon);
  }

  #btn-submit {
    width: 100%;
    background: var(--color-limon);
    color: var(--color-aceituna);
    padding: 0.75rem;
    border-radius: 4px;
    font-weight: 700;
    margin-top: 1.5rem;
    cursor: pointer;
    border: 2px solid var(--color-aceituna);
    font-size: 1rem;
  }

  #btn-submit:hover { opacity: 0.9; }
  #btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .alertas-info {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-align: center;
    margin-top: 1rem;
  }

  #mensaje {
    margin-top: 1rem;
    border-radius: 4px;
    padding: 0.75rem;
    font-size: 0.875rem;
  }

  #mensaje.hidden { display: none; }

  #mensaje.warning {
    background: rgba(212, 232, 73, 0.2);
    border: 2px solid var(--color-limon);
    color: var(--color-aceituna);
  }

  #mensaje.success {
    background: rgba(34, 197, 94, 0.2);
    border: 2px solid #22c55e;
    color: #166534;
  }

  #mensaje.error {
    background: rgba(239, 68, 68, 0.2);
    border: 2px solid #ef4444;
    color: #991b1b;
  }
</style>

<script>
  import { ICONOS_ALERTAS } from '../lib/variedades';
  
  const btn = document.getElementById("btn-submit");
  const msg = document.getElementById("mensaje");
  const form = document.getElementById("form-alerta");
  const selectProvincia = document.getElementById("provincia") as HTMLSelectElement;
  const selectVariedad = document.getElementById("variedad") as HTMLSelectElement;
  const selectTipo = document.getElementById("tipo") as HTMLSelectElement;

  async function calcularTipoAlerta(provincia: string, variedad: string) {
    try {
      const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, "") || "http://localhost:3000";
      const res = await fetch(`${apiBase}/api/clima`);
      const datos = await res.json();
      const datosProv = datos.find((p: any) => p.provincia === provincia);
      
      if (!datosProv) return [];

      const riesgos_variedad = datosProv.riesgos_variedad?.[variedad];
      const riesgos_olivar = datosProv.riesgos_olivar || {};
      const riesgos_plaga = datosProv.riesgos_plaga || {};
      const alertas: string[] = [];

      // Riesgos de la variedad
      if (riesgos_variedad?.nivel === 'crítico') alertas.push("calor_critico");
      if (riesgos_variedad?.nivel === 'medio') alertas.push("calor_critico");

      // Riesgos del olivar
      if (riesgos_olivar?.calor?.nivel === 'alto') alertas.push("ola_calor");
      if (riesgos_olivar?.frio?.nivel === 'alto') alertas.push("helada");
      if (riesgos_olivar?.baja_humedad?.nivel === 'alto') alertas.push("sequia_extrema");
      if (riesgos_olivar?.alta_humedad?.nivel === 'alto') alertas.push("alta_humedad");
      if (riesgos_olivar?.baja_lluvia?.nivel === 'alto') alertas.push("sequia_extrema");
      if (riesgos_olivar?.alta_lluvia?.nivel === 'alto') alertas.push("inundacion");

      // Riesgos de plagas
      if (riesgos_plaga?.mosca?.nivel === 'alto') alertas.push("mosca");
      if (riesgos_plaga?.polilla?.nivel === 'alto') alertas.push("polilla");
      if (riesgos_plaga?.xylella?.nivel === 'alto') alertas.push("xylella");
      if (riesgos_plaga?.repilo?.nivel === 'alto') alertas.push("repilo");

      return [...new Set(alertas)];
    } catch (e) {
      console.error("Error calculating alert:", e);
      return [];
    }
  }

  async function actualizarTipoAlerta() {
    const provincia = selectProvincia.value;
    const variedad = selectVariedad.value;

    selectTipo.innerHTML = '<option value="">Selecciona...</option>';

    if (!provincia) return;

    const alertas = await calcularTipoAlerta(provincia, variedad);

    if (alertas.length === 0) {
      const opt = document.createElement("option");
      opt.value = "condiciones_optimas";
      opt.textContent = ICONOS_ALERTAS.condiciones_optimas.label;
      selectTipo.appendChild(opt);
    } else {
      alertas.forEach((alerta) => {
        const opt = document.createElement("option");
        opt.value = alerta;
        opt.textContent = ICONOS_ALERTAS[alerta]?.label || alerta;
        selectTipo.appendChild(opt);
      });
    }
  }

  selectProvincia?.addEventListener("change", async () => {
    if (selectProvincia.value && selectVariedad.value) {
      await actualizarTipoAlerta();
    }
  });

  selectVariedad?.addEventListener("change", async () => {
    if (selectProvincia.value && selectVariedad.value) {
      await actualizarTipoAlerta();
    }
  });

  const provGuardada = localStorage.getItem("olivaxi_provincia");
  const varGuardada = localStorage.getItem("olivaxi_variedad");

  if (provGuardada && selectProvincia) {
    selectProvincia.value = provGuardada;
  }
  if (varGuardada && selectVariedad) {
    selectVariedad.value = varGuardada;
  }

  if (provGuardada && varGuardada) {
    setTimeout(actualizarTipoAlerta, 100);
  }

  btn?.addEventListener("click", async () => {
    const nombre = (document.getElementById("nombre") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const provincia = (document.getElementById("provincia") as HTMLSelectElement).value;
    const variedad = (document.getElementById("variedad") as HTMLSelectElement).value;
    const tipo = (document.getElementById("tipo") as HTMLSelectElement).value;
    const fenologia = (document.getElementById("fenologia") as HTMLSelectElement).value;

    if (!nombre || !email || !provincia) {
      msg.textContent = "⚠️ Por favor completa los campos obligatorios.";
      msg.className = "warning";
      msg.removeAttribute("hidden");
      return;
    }

    btn.textContent = "Activando...";
    btn.disabled = true;

    try {
      const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, "") || "http://localhost:3000";
      const res = await fetch(`${apiBase}/api/alertas`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nombre, email, provincia, variedad, tipo, fenologia }),
      });

      if (res.ok) {
        msg.textContent = `✅ ¡Alerta activada! Se te avisará cuando cualquier riesgo aparezca en tu zona para tu cultivo de olivo.`;
        msg.className = "success";
        localStorage.setItem("olivaxi_provincia", provincia);
        if (variedad) localStorage.setItem("olivaxi_variedad", variedad);
      } else {
        throw new Error("Respuesta no OK");
      }
    } catch {
      msg.textContent = "❌ Algo salió mal. Inténtalo de nuevo.";
      msg.className = "error";
    } finally {
      msg.removeAttribute("hidden");
      btn.textContent = "Activar alerta 🔔";
      btn.disabled = false;
    }
  });
</script>
