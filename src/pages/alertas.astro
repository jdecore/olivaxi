---
import Layout from '../layouts/Layout.astro';
import ProvinciaSelect from '../components/ProvinciaSelect.astro';
import VariedadSelect from '../components/VariedadSelect.astro';
import { ICONOS_ALERTAS } from '../lib/variedades';
---

<Layout title="Alertas - olivaξ">
  <div id="verify-top-banner" class="verify-top-banner" hidden></div>
  <div id="verify-celebration" class="verify-celebration" hidden>
    <div id="verify-celebration-inner" class="verify-celebration-inner success">
      <span id="verify-icon" class="verify-icon">✅</span>
      <span id="verify-text" class="verify-text">Correo confirmado: alertas activadas correctamente</span>
      <span id="verify-spark" class="verify-spark">✨</span>
    </div>
  </div>
  <!-- Hero -->
  <section class="alertas-hero">
    <span class="hero-badge">🔔 Notificaciones en tiempo real · RAIF + clima</span>
    <h1>Activa alertas para tu olivar</h1>
    <p>Te avisamos cuando las condiciones climáticas o plagas afecten tu cultivo</p>
  </section>

  <!-- Form -->
  <section class="alertas-section">
    <div id="provincia-info" class="provincia-info-panel"></div>
    <form id="form-alerta" class="alertas-form">
      <div class="form-field">
        <label for="nombre">Tu nombre</label>
        <input id="nombre" type="text" required />
      </div>

      <div class="form-field">
        <label for="email">Tu email</label>
        <input id="email" type="email" required />
      </div>

      <div class="form-field">
        <label for="provincia">Provincia</label>
        <ProvinciaSelect id="provincia" />
      </div>

      <div class="form-field">
        <label for="variedad">Variedad de olivo</label>
        <VariedadSelect id="variedad" />
      </div>

      <div class="form-field">
        <label for="tipo">Tipo de alerta</label>
        <select id="tipo">
          <option value="">Selecciona...</option>
        </select>
      </div>

      <div class="form-field">
        <label for="fenologia">Fase fenológica (opcional)</label>
        <select id="fenologia">
          <option value="">No específica</option>
          <option value="reposo">🌑 Reposo (Nov-Ene)</option>
          <option value="brotacion">🌱 Brotación (Feb-Mar)</option>
          <option value="floracion">🌸 Floración (Abr-May)</option>
          <option value="cuaje">🫒 Cuaje (May-Jun)</option>
          <option value="desarrollo">📈 Desarrollo fruto (Jun-Ago)</option>
          <option value="envero">🍇 Envero (Sep-Oct)</option>
          <option value="cosecha">🧺 Cosecha (Oct-Nov)</option>
        </select>
      </div>

      <button id="btn-submit" type="button">Activar alertas para mi olivar</button>

      <p class="alertas-info">Se te avisará cuando cualquier riesgo aparezca en tu zona para tu cultivo de olivo.</p>

      <div id="mensaje" hidden></div>
    </form>
  </section>
</Layout>

<style is:global>
  .alertas-hero {
    background: #f5f0e8;
    color: var(--color-aceituna);
    padding: 60px 1rem 1.5rem;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-limon);
    color: var(--color-aceituna);
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .alertas-hero h1 {
    font-size: 1.875rem;
    font-weight: 700;
    font-family: 'Literata', Georgia, serif;
    margin-bottom: 0.5rem;
  }

  .alertas-hero p {
    color: var(--color-muted);
    margin-top: 0.5rem;
    font-size: 1.1rem;
  }

  .alertas-section {
    background-color: var(--color-sal);
    padding: 2rem 1rem;
  }

  .alertas-form {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid rgba(28, 28, 28, 0.15);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    max-width: 100%;
    margin: 0 auto;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255,255,255,0.5) inset;
    animation: formEntry 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    opacity: 0;
    transform: translateY(60px) scale(0.9);
  }

  @keyframes formEntry {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .form-field {
    margin-bottom: 1rem;
    opacity: 1;
    animation: none;
    transform: none;
  }

  .form-field:nth-child(1) { animation-delay: 0s; }
  .form-field:nth-child(2) { animation-delay: 0s; }
  .form-field:nth-child(3) { animation-delay: 0s; }
  .form-field:nth-child(4) { animation-delay: 0s; }
  .form-field:nth-child(5) { animation-delay: 0s; }
  .form-field:nth-child(6) { animation-delay: 0s; }

  .form-field label {
    display: block;
    font-weight: 700;
    color: #1C1C1C;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .form-field input,
  .form-field select {
    width: 100%;
    background: #faf9f6;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--color-aceituna);
    font-size: 0.95rem;
    font-family: 'Outfit', system-ui, sans-serif;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .form-field input::placeholder {
    color: #999;
  }

  .form-field input:hover,
  .form-field select:hover {
    border-color: #3b6d11;
  }

  .form-field label:hover {
    color: #3b6d11;
  }

  .form-field input:focus,
  .form-field select:focus {
    outline: none;
    border-color: #3b6d11;
    box-shadow: 0 0 0 3px rgba(59, 109, 17, 0.15);
  }

  #btn-submit {
    width: 100%;
    background: #3b6d11;
    color: #eaf3de;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    margin-top: 1.5rem;
    cursor: pointer;
    border: none;
    font-size: 1.15rem;
    box-shadow: 0 4px 12px rgba(59, 109, 17, 0.25);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  #btn-submit:hover { 
    background: #2d5a0c;
    transform: translateY(-2px);
  }

  #btn-submit:active {
    transform: translateY(0);
  }

  #btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .provincia-info-panel {
    background: var(--color-white-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    display: none;
  }

  .provincia-info-panel.show { display: block; }

  .provincia-info-panel .metrics-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-aceituna);
  }

  .provincia-info-panel .metrics-strip .prov-name {
    font-weight: 700;
  }

  .provincia-info-panel .riesgos-section {
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
  }

  .provincia-info-panel .riesgos-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-aceituna);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .provincia-info-panel .riesgos-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .provincia-info-panel .riesgo-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .provincia-info-panel .riesgo-badge.alto {
    background: #fcebeb;
    color: #a32d2d;
    border: 0.5px solid #f09595;
  }

  .provincia-info-panel .riesgo-badge.medio {
    background: #faeeda;
    color: #92400e;
    border: 0.5px solid #fac775;
  }

  .provincia-info-panel .consejos-box {
    margin-top: 0.75rem;
    padding: 0.75rem;
    background: rgba(212, 232, 73, 0.15);
    border-radius: 8px;
    font-size: 0.8rem;
    color: var(--color-aceituna);
  }

  .alertas-info {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-align: center;
    margin-top: 1rem;
    font-weight: 600;
  }

  #mensaje {
    margin-top: 1rem;
    border-radius: 12px;
    padding: 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(15px) scale(0.95);
    transition: opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #mensaje.show {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #mensaje.hidden { display: none; }

  #mensaje.warning {
    background: var(--color-limon);
    color: var(--color-aceituna);
  }

  #mensaje.success {
    background: #22c55e;
    border: 2px solid #22c55e;
    color: #166534;
  }

  #mensaje.error {
    background: #ef4444;
    border: 2px solid #ef4444;
    color: var(--color-white);
  }

  .verify-celebration {
    position: fixed;
    top: 100px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    z-index: 150;
    pointer-events: none;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .verify-top-banner {
    position: fixed;
    top: 90px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 200;
    margin: 0 auto 8px;
    max-width: 920px;
    width: 90%;
    border-radius: 10px;
    padding: 14px 20px;
    font-weight: 700;
    font-size: 1rem;
    border: 2px solid transparent;
    text-align: center;
  }

  .verify-top-banner.success {
    background: #dcfce7;
    color: #14532d;
    border-color: #22c55e;
  }
  .verify-top-banner.warning {
    background: #fef9c3;
    color: #713f12;
    border-color: #eab308;
  }
  .verify-top-banner.error {
    background: #fee2e2;
    color: #7f1d1d;
    border-color: #ef4444;
  }

  .verify-celebration.show {
    opacity: 1;
    transform: translateX(-50%);
  }

  .verify-celebration-inner {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #22c55e;
    color: #052e16;
    border: 2px solid #16a34a;
    border-radius: 999px;
    padding: 10px 16px;
    box-shadow: 0 10px 26px rgba(34, 197, 94, 0.35);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .verify-celebration-inner.warning {
    background: #facc15;
    color: #422006;
    border-color: #eab308;
    box-shadow: 0 10px 26px rgba(250, 204, 21, 0.30);
  }

  .verify-celebration-inner.error {
    background: #ef4444;
    color: #fff;
    border-color: #dc2626;
    box-shadow: 0 10px 26px rgba(239, 68, 68, 0.30);
  }

  .verify-celebration.show .verify-icon {
    animation: verifyBounce 0.9s ease;
  }

  .verify-celebration.show .verify-spark {
    animation: verifyPulse 0.9s ease;
  }

  @keyframes verifyBounce {
    0%, 100% { transform: translateY(0) scale(1); }
    35% { transform: translateY(-4px) scale(1.12); }
    70% { transform: translateY(0) scale(1); }
  }

  @keyframes verifyPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.2); opacity: 0.75; }
  }

  @media (max-width: 480px) {
    .alertas-form {
      padding: 1.5rem 1rem;
      border-radius: 16px;
    }
    .alertas-hero { padding: 100px 1rem 2rem; }
    .alertas-hero h1 { font-size: 1.5rem; }
    .alertas-hero p { font-size: 0.9rem; }
    .form-field { margin-bottom: 0.75rem; }
    .form-field label { font-size: 0.75rem; }
    #btn-submit { padding: 0.85rem 1rem; font-size: 0.9rem; }
  }
</style>

<script>
  import OlivaxiEcosistema from '../lib/ecosistema';
  import { ICONOS_ALERTAS } from '../lib/variedades';
  import { apiUrl } from '../lib/api';

  const btn = document.getElementById("btn-submit");
  const msg = document.getElementById("mensaje");
  const form = document.getElementById("form-alerta");
  const provinciaInfoPanel = document.getElementById("provincia-info");
  const selectTipo = document.getElementById("tipo");
  const provinciaSelect = document.getElementById("provincia");
  const variedadSelect = document.getElementById("variedad");
  const verifyCelebration = document.getElementById("verify-celebration");
  const verifyTopBanner = document.getElementById("verify-top-banner");
  const verifyInner = document.getElementById("verify-celebration-inner");
  const verifyIcon = document.getElementById("verify-icon");
  const verifyText = document.getElementById("verify-text");
  const verifySpark = document.getElementById("verify-spark");
  let verifyCelebrationTimeout = null;

  function clearNode(node) {
    if (!node) return;
    while (node.firstChild) node.removeChild(node.firstChild);
  }

  function showVerifyCelebration(type = 'success', text = '', opts = { autoHideMs: 3200 }) {
    if (!verifyCelebration || !verifyInner || !verifyIcon || !verifyText || !verifySpark) return;
    if (verifyCelebrationTimeout) clearTimeout(verifyCelebrationTimeout);
    verifyInner.classList.remove('success', 'warning', 'error');
    verifyInner.classList.add(type);
    verifyIcon.textContent = type === 'error' ? '❌' : type === 'warning' ? '⏳' : '✅';
    verifySpark.textContent = type === 'error' ? '⚠️' : '✨';
    verifyText.textContent = text || (type === 'success'
      ? 'Correo confirmado: alertas activadas correctamente'
      : type === 'warning'
      ? 'Confirmando alerta...'
      : 'No se pudo confirmar la alerta');
    verifyCelebration.style.display = 'block';
    verifyCelebration.classList.add("show");
    const autoHideMs = opts?.autoHideMs ?? 3200;
    if (autoHideMs > 0) {
      verifyCelebrationTimeout = setTimeout(() => {
        verifyCelebration.classList.remove("show");
        setTimeout(() => verifyCelebration.style.display = 'none', 350);
      }, autoHideMs);
    }
  }

  function showVerifyTopBanner(type = 'success', text = '') {
    if (!verifyTopBanner) return;
    verifyTopBanner.classList.remove('success', 'warning', 'error');
    verifyTopBanner.classList.add(type);
    verifyTopBanner.textContent = text;
    verifyTopBanner.style.display = 'block';
  }

  // --- Cargar datos de provincia via ecosistema ---
  async function cargarDatosProvincia() {
    const provincia = OlivaxiEcosistema.provincia;
    if (!provincia || !provinciaInfoPanel) return;

    const d = await OlivaxiEcosistema.fetchDashboard();
    if (!d) return;

    clearNode(provinciaInfoPanel);

    // Strip de 3 métricas clave
    const temp = Math.round(d.suelo?.temperatura || d.clima?.temperatura || 0);
    let humedadSuelo = d.suelo?.humedad || 0;
    if (humedadSuelo <= 1) humedadSuelo = Math.round(humedadSuelo * 100);
    const eto = (d.suelo?.evapotranspiracion || 0).toFixed(1);

    const metricsStrip = document.createElement('div');
    metricsStrip.className = 'metrics-strip';
    const metricProv = document.createElement('span');
    metricProv.className = 'prov-name';
    metricProv.textContent = provincia;
    const metricTemp = document.createElement('span');
    metricTemp.textContent = `${temp}°C`;
    const metricSep1 = document.createElement('span');
    metricSep1.textContent = '·';
    const metricSuelo = document.createElement('span');
    metricSuelo.textContent = `Suelo ${humedadSuelo}% humedad`;
    const metricSep2 = document.createElement('span');
    metricSep2.textContent = '·';
    const metricEto = document.createElement('span');
    metricEto.textContent = `ETo ${eto}mm`;
    metricsStrip.append(metricProv, metricTemp, metricSep1, metricSuelo, metricSep2, metricEto);
    provinciaInfoPanel.appendChild(metricsStrip);

    // Riesgos activos (solo MEDIO y ALTO)
    const riesgosFiltrados = (d.riesgosActivos || []).filter(r => r.nivel === 'medio' || r.nivel === 'alto');
    
    if (riesgosFiltrados.length > 0) {
      const riesgosSection = document.createElement('div');
      riesgosSection.className = 'riesgos-section';
      
      const riesgosTitle = document.createElement('div');
      riesgosTitle.className = 'riesgos-title';
      riesgosTitle.textContent = 'Riesgos activos:';
      riesgosSection.appendChild(riesgosTitle);

      const riesgosList = document.createElement('div');
      riesgosList.className = 'riesgos-list';
      riesgosFiltrados.forEach(r => {
        const badge = document.createElement('span');
        badge.className = `riesgo-badge ${r.nivel}`;
        badge.textContent = `${r.icono || '⚠️'} ${r.titulo} — ${String(r.nivel).toUpperCase()}`;
        riesgosList.appendChild(badge);
      });
      riesgosSection.appendChild(riesgosList);
      provinciaInfoPanel.appendChild(riesgosSection);
    }

    // Consejos
    if (d.consejos?.length) {
      const consejosBox = document.createElement('div');
      consejosBox.className = 'consejos-box';
      consejosBox.textContent = `💡 ${d.consejos[0]}`;
      provinciaInfoPanel.appendChild(consejosBox);
    }

    provinciaInfoPanel.classList.add('show');
  }

  // --- Calcular tipos de alerta ---
  async function actualizarTipoAlerta() {
    const provincia = OlivaxiEcosistema.provincia;
    const variedad = OlivaxiEcosistema.variedad;
    
    const emptyOption = document.createElement('option');
    emptyOption.value = '';
    emptyOption.textContent = 'Selecciona...';
    selectTipo.replaceChildren(emptyOption);
    if (!provincia) return;

    try {
      const res = await fetch(apiUrl(`/api/alertas/tipos?provincia=${encodeURIComponent(provincia)}&variedad=${encodeURIComponent(variedad)}`));
      if (!res.ok) return;
      const data = await res.json();
      const alertas = data.tipos || [];

      if (alertas.length === 0) {
        const opt = document.createElement("option");
        opt.value = "condiciones_optimas";
        opt.textContent = ICONOS_ALERTAS.condiciones_optimas.label;
        selectTipo.appendChild(opt);
        selectTipo.value = "condiciones_optimas";
      } else {
        alertas.forEach((alerta) => {
          const opt = document.createElement("option");
          opt.value = alerta;
          opt.textContent = ICONOS_ALERTAS[alerta]?.label || alerta;
          selectTipo.appendChild(opt);
        });
        if (alertas.includes('todas_alertas')) {
          selectTipo.value = 'todas_alertas';
        } else {
          selectTipo.value = alertas[0];
        }
      }
    } catch (e) {
      console.error("Error calculating alert types:", e);
    }
  }

  async function confirmarTokenDesdeURL() {
    const params = new URLSearchParams(window.location.search);
    const token = params.get('verify');
    if (!token) return;

    if (msg) {
      msg.textContent = "⏳ Confirmando alerta...";
      msg.className = "warning show";
      msg.removeAttribute("hidden");
    }
    showVerifyTopBanner('warning', '⏳ Confirmando correo de alerta...');
    showVerifyCelebration('warning', 'Confirmando alerta...', { autoHideMs: 0 });

    try {
      console.log('[confirmarToken] Enviando request a:', apiUrl('/api/alertas/verify'));
      const res = await fetch(apiUrl('/api/alertas/verify'), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token }),
      });
      console.log('[confirmarToken] Response status:', res.status);
      const data = await res.json().catch(() => ({}));
      console.log('[confirmarToken] Response data:', data);
      if (!res.ok) throw new Error(data.error || "No se pudo confirmar");

      // Mostrar mensaje de éxito más prominente
      const mensajeExito = document.createElement('div');
      mensajeExito.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#22c55e;color:#fff;padding:24px 32px;border-radius:16px;font-size:18px;font-weight:700;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,0.3);text-align:center;';
      mensajeExito.innerHTML = '✅<br><br>Tu alerta está activa!<br><br>Recibirás un email con los riesgos actuales de tu zona.<br><br><span style="font-size:14px;font-weight:400">Redirigiendo al formulario...</span>';
      document.body.appendChild(mensajeExito);
      
      setTimeout(() => {
        mensajeExito.remove();
        window.location.href = window.location.origin + window.location.pathname;
      }, 4000);

      if (msg) {
        msg.textContent = "✅ Alerta confirmada correctamente. Ya recibirás notificaciones.";
        msg.className = "success show";
        msg.removeAttribute("hidden");
      }
      showVerifyTopBanner('success', '✅ Correo confirmado correctamente. Alertas activadas.');
      showVerifyCelebration('success', 'Correo confirmado: alertas activadas correctamente', { autoHideMs: 3200 });

      const cleanUrl = window.location.origin + window.location.pathname;
      window.history.replaceState({}, "", cleanUrl);
    } catch (e) {
      if (msg) {
        msg.textContent = `❌ ${e?.message || "Error al confirmar alerta"}`;
        msg.className = "error show";
        msg.removeAttribute("hidden");
      }
      showVerifyTopBanner('error', `❌ ${e?.message || 'Error al confirmar alerta'}`);
      showVerifyCelebration('error', e?.message || 'Error al confirmar alerta', { autoHideMs: 5000 });
    }
  }

  // --- Escuchar cambios del ecosistema ---
  const offEcosistema = OlivaxiEcosistema.onChange((state) => {
    if (provinciaSelect && state.provincia && provinciaSelect.value !== state.provincia) {
      provinciaSelect.value = state.provincia;
    }
    if (variedadSelect && state.variedad && variedadSelect.value !== state.variedad) {
      variedadSelect.value = state.variedad;
    }
    if (state.provincia) {
      cargarDatosProvincia();
      actualizarTipoAlerta();
    }
  });
  window.addEventListener('beforeunload', offEcosistema);

  // --- Submit del formulario ---
  btn?.addEventListener("click", async () => {
    const nombre = document.getElementById("nombre").value.trim();
    const email = document.getElementById("email").value.trim();
    const provincia = OlivaxiEcosistema.provincia;
    const variedad = OlivaxiEcosistema.variedad;
    const tipo = selectTipo.value;
    const fenologia = document.getElementById("fenologia").value;

    if (!nombre || !email || !provincia) {
      msg.textContent = "⚠️ Por favor completa los campos obligatorios.";
      msg.className = "warning show";
      msg.removeAttribute("hidden");
      return;
    }

    btn.textContent = "Activando...";
    btn.disabled = true;

    try {
      const res = await fetch(apiUrl('/api/alertas'), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nombre, email, provincia, variedad, tipo, fenologia }),
      });

      if (res.ok) {
        const data = await res.json().catch(() => ({}));
        msg.textContent = data.message ? `✅ ${data.message}` : "✅ ¡Alerta activada!";
        msg.className = "success show";
      } else {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || "Respuesta no OK");
      }
    } catch (e) {
      msg.textContent = `❌ ${e?.message || "Algo salió mal. Inténtalo de nuevo."}`;
      msg.className = "error show";
    } finally {
      msg.removeAttribute("hidden");
      btn.textContent = "Activar alerta 🔔";
      btn.disabled = false;
    }
  });

  // --- Verificar estado del sistema ---
  async function verificarSistema() {
    try {
      const res = await fetch(apiUrl('/api/alertas/status'));
      const data = await res.json();
      if (data.ok) {
        console.log('[Alertas] Sistema:', data.message);
        if (data.email !== 'ready') {
          const warningDiv = document.createElement('div');
          warningDiv.style.cssText = 'background:#fef9c3;color:#713f12;padding:12px 16px;border-radius:8px;font-size:13px;margin-bottom:16px;text-align:center;';
          warningDiv.textContent = `⚠️ ${data.message}. Las alertas por email no se enviarán.`;
          const alertasSection = document.querySelector('.alertas-section');
          if (alertasSection) alertasSection.prepend(warningDiv);
        }
      }
    } catch (e) {
      console.warn('[Alertas] No se pudo verificar estado del sistema');
    }
  }

  // --- Carga inicial si ya hay provincia ---
  confirmarTokenDesdeURL();
  verificarSistema();

  if (OlivaxiEcosistema.provincia) {
    if (provinciaSelect && !provinciaSelect.value) provinciaSelect.value = OlivaxiEcosistema.provincia;
    if (variedadSelect && OlivaxiEcosistema.variedad && !variedadSelect.value) variedadSelect.value = OlivaxiEcosistema.variedad;
    cargarDatosProvincia();
    actualizarTipoAlerta();
  }
</script>
