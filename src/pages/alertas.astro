---
import Layout from '../layouts/Layout.astro';
import { ICONOS_ALERTAS } from '../lib/variedades';
---

<Layout title="Alertas - olivaξ">
  <!-- Hero -->
  <section class="alertas-hero">
    <h1>🔔 Alertas Inteligentes para tu Olivar</h1>
    <p>Te avisamos cuando las condiciones climáticas o plagas afecten a tu cultivo. Datos reales de tu provincia basados en RAIF.</p>
    <p style="font-size: 0.85rem; opacity: 0.7; margin-top: 0.5rem;">
      🌱 Datos climáticos + 🦟 Plagas activas + 🪨 Consejos según tu suelo
    </p>
  </section>

  <!-- Form -->
  <section class="alertas-section">
    <div id="provincia-info" class="provincia-info-panel"></div>
    <form id="form-alerta" class="alertas-form">
      <div class="form-field">
        <label for="nombre">Tu nombre</label>
        <input id="nombre" type="text" required />
      </div>

      <div class="form-field">
        <label for="email">Tu email</label>
        <input id="email" type="email" required />
      </div>

      <div class="form-field">
        <label for="provincia">Provincia</label>
        <select id="provincia">
          <option value="">Selecciona tu provincia...</option>
          <option value="Jaén">Jaén</option>
          <option value="Córdoba">Córdoba</option>
          <option value="Sevilla">Sevilla</option>
          <option value="Granada">Granada</option>
          <option value="Málaga">Málaga</option>
          <option value="Badajoz">Badajoz</option>
          <option value="Toledo">Toledo</option>
          <option value="Ciudad Real">Ciudad Real</option>
          <option value="Almería">Almería</option>
          <option value="Huelva">Huelva</option>
        </select>
      </div>

      <div class="form-field">
        <label for="variedad">Variedad de olivo</label>
        <select id="variedad">
          <option value="">Selecciona tu variedad...</option>
          <option value="cornicabra">Cornicabra</option>
          <option value="picual">Picual</option>
          <option value="arbequina">Arbequina</option>
          <option value="hojiblanca">Hojiblanca</option>
          <option value="manzanilla">Manzanilla</option>
          <option value="empeltre">Empeltre</option>
        </select>
      </div>

      <div class="form-field">
        <label for="tipo">Tipo de alerta</label>
        <select id="tipo">
          <option value="">Selecciona...</option>
        </select>
      </div>

      <div class="form-field">
        <label for="fenologia">Fase fenológica (opcional)</label>
        <select id="fenologia">
          <option value="">No específica</option>
          <option value="reposo">🌑 Reposo (Nov-Ene)</option>
          <option value="brotacion">🌱 Brotación (Feb-Mar)</option>
          <option value="floracion">🌸 Floración (Abr-May)</option>
          <option value="cuaje">🫒 Cuaje (May-Jun)</option>
          <option value="desarrollo">📈 Desarrollo fruto (Jun-Ago)</option>
          <option value="envero">🍇 Envero (Sep-Oct)</option>
          <option value="cosecha">🧺 Cosecha (Oct-Nov)</option>
        </select>
      </div>

      <button id="btn-submit" type="button">Activar alerta 🔔</button>

      <p class="alertas-info">Se te avisará cuando cualquier riesgo aparezca en tu zona para tu cultivo de olivo.</p>

      <div id="mensaje" hidden></div>
    </form>
  </section>
</Layout>

<style is:global>
  .alertas-hero {
    background: var(--color-aceituna);
    color: var(--color-sal);
    padding: 100px 1rem 3rem;
    text-align: center;
  }

  .alertas-hero h1 {
    font-size: 1.875rem;
    font-weight: 700;
    font-family: 'Literata', Georgia, serif;
  }

  .alertas-hero p {
    color: rgba(247,244,238,0.7);
    margin-top: 0.5rem;
  }

  .alertas-section {
    background-color: var(--color-sal);
    padding: 2rem 1rem;
  }

  .alertas-form {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid rgba(28, 28, 28, 0.15);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    max-width: 100%;
    margin: 0 auto;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255,255,255,0.5) inset;
    animation: formEntry 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    opacity: 0;
    transform: translateY(60px) scale(0.9);
  }

  @keyframes formEntry {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .form-field {
    opacity: 0;
    animation: fieldEntry 0.6s ease forwards;
    transform: translateY(15px);
  }
  .form-field:nth-child(1) { animation-delay: 0.15s; }
  .form-field:nth-child(2) { animation-delay: 0.25s; }
  .form-field:nth-child(3) { animation-delay: 0.35s; }
  .form-field:nth-child(4) { animation-delay: 0.45s; }
  .form-field:nth-child(5) { animation-delay: 0.55s; }
  .form-field:nth-child(6) { animation-delay: 0.65s; }

  @keyframes fieldEntry {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 480px) {
    .alertas-form {
      padding: 1.5rem 1rem;
      border-radius: 16px;
    }
    .alertas-hero h1 {
      font-size: 1.5rem;
    }
    .form-field {
      margin-bottom: 0.75rem;
    }
    .form-field label {
      font-size: 0.75rem;
    }
    #btn-submit {
      padding: 0.85rem 1rem;
      font-size: 0.9rem;
    }
  }

  .form-field { margin-bottom: 1rem; }

  .form-field label {
    display: block;
    font-weight: 800;
    color: #1C1C1C;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }

  .form-field input,
  .form-field select {
    width: 100%;
    background: rgba(247, 244, 238, 0.9);
    border: 2px solid rgba(28, 28, 28, 0.2);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    color: #1C1C1C;
    font-size: 1rem;
    font-family: 'Outfit', system-ui, sans-serif;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, border-color 0.3s ease, filter 0.3s ease;
    will-change: transform;
  }

  .form-field input:hover,
  .form-field select:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 10px 25px rgba(212, 232, 73, 0.3);
    border-color: rgba(212, 232, 73, 0.5);
  }

  .form-field label:hover {
    color: #D4E849;
  }

  .form-field input:focus,
  .form-field select:focus {
    outline: none;
    border-color: #D4E849;
    box-shadow: 0 0 0 4px rgba(212, 232, 73, 0.4), 0 8px 25px rgba(212, 232, 73, 0.25);
    transform: scale(1.03) translateY(-2px);
    filter: brightness(1.05);
    background: #fff;
  }

  #btn-submit {
    width: 100%;
    background: linear-gradient(135deg, #1C1C1C 0%, #3C3C3C 100%);
    color: #FFFFFF;
    padding: 1rem 1.5rem;
    border-radius: 14px;
    font-weight: 800;
    margin-top: 1.5rem;
    cursor: pointer;
    border: none;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    box-shadow: 0 10px 30px rgba(28, 28, 28, 0.3);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, filter 0.3s ease;
    will-change: transform;
    opacity: 0;
    animation: btnEntry 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.75s forwards;
    position: relative;
    overflow: hidden;
  }

  #btn-submit::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -75%;
    width: 40%;
    height: 300%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
    transform: skewX(-20deg);
    animation: shine 4s linear infinite;
  }

  @keyframes shine {
    100% { left: 150%; }
  }

  @keyframes btnEntry {
    to { opacity: 1; transform: translateY(0); }
  }

  #btn-submit:hover { 
    transform: translateY(-6px) scale(1.05);
    filter: brightness(1.3);
    box-shadow: 0 20px 40px rgba(212, 232, 73, 0.4);
  }

  #btn-submit:active {
    transform: scale(0.95) translateY(-2px);
    transition-duration: 0.1s;
    filter: brightness(0.9);
  }

  #btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .provincia-info-panel {
    background: rgba(212, 232, 73, 0.1);
    border: 2px solid var(--color-limon);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    display: none;
  }
  .provincia-info-panel.show {
    display: block;
  }
  .provincia-info-panel h4 {
    margin: 0 0 0.5rem;
    color: var(--color-aceituna);
    font-size: 1rem;
  }
  .provincia-info-panel .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  .provincia-info-panel .info-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .provincia-info-panel .consejos {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(0,0,0,0.1);
    font-size: 0.8rem;
  }
  .provincia-info-panel .consejos li {
    margin-bottom: 0.25rem;
  }

  .alertas-info {
    font-size: 0.8rem;
    color: #6b6b60;
    text-align: center;
    margin-top: 1rem;
    font-weight: 600;
  }

  #mensaje {
    margin-top: 1rem;
    border-radius: 12px;
    padding: 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(15px) scale(0.95);
    transition: opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #mensaje.show {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #mensaje.hidden { display: none; }

  #mensaje.warning {
    background: #D4E849;
    color: #1C1C1C;
  }

  #mensaje.success {
    background: #22c55e;
    border: 2px solid #22c55e;
    color: #166534;
  }

  #mensaje.error {
    background: #ef4444;
    border: 2px solid #ef4444;
    color: #FFFFFF;
  }
</style>

<script>
  import { ICONOS_ALERTAS } from '../lib/variedades';
  
  const btn = document.getElementById("btn-submit");
  const msg = document.getElementById("mensaje");
  const form = document.getElementById("form-alerta");
  const selectProvincia = document.getElementById("provincia");
  const selectVariedad = document.getElementById("variedad");
  const selectTipo = document.getElementById("tipo");

  async function calcularTipoAlerta(provincia, variedad) {
    try {
      const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, "") || "http://45.90.237.135:3001";
      const res = await fetch(`${apiBase}/api/alertas/tipos?provincia=${encodeURIComponent(provincia)}&variedad=${encodeURIComponent(variedad)}`);
      if (!res.ok) return [];
      const data = await res.json();
      return data.tipos || [];
    } catch (e) {
      console.error("Error calculating alert:", e);
      return [];
    }
  }

  async function actualizarTipoAlerta() {
    const provincia = selectProvincia.value;
    const variedad = selectVariedad.value;

    selectTipo.innerHTML = '<option value="">Selecciona...</option>';

    if (!provincia) return;

    const alertas = await calcularTipoAlerta(provincia, variedad);

    if (alertas.length === 0) {
      const opt = document.createElement("option");
      opt.value = "condiciones_optimas";
      opt.textContent = ICONOS_ALERTAS.condiciones_optimas.label;
      selectTipo.appendChild(opt);
    } else {
      alertas.forEach((alerta) => {
        const opt = document.createElement("option");
        opt.value = alerta;
        opt.textContent = ICONOS_ALERTAS[alerta]?.label || alerta;
        selectTipo.appendChild(opt);
      });
    }
  }

  const provinciaInfoPanel = document.getElementById("provincia-info");
  
  async function cargarDatosProvincia(provinciaNombre) {
    if (!provinciaNombre || !provinciaInfoPanel) return;
    
    try {
      const res = await fetch(`${apiBase}/api/clima`);
      const datos = await res.json();
      const prov = datos.find(p => p.provincia === provinciaNombre);
      
      if (prov) {
        const plagaNivel = prov.riesgos_plaga?.polilla?.nivelRAIF || prov.riesgos_plaga?.polilla?.nivel || 'bajo';
        const iconoPlaga = plagaNivel === 'alto' ? '🔴' : plagaNivel === 'medio' ? '🟡' : '🟢';
        
        provinciaInfoPanel.innerHTML = `
          <h4>📍 Información de ${provinciaNombre}</h4>
          <div class="info-grid">
            ${prov.variedadPredominante ? `<div class="info-item">🫒 <b>${prov.variedadPredominante}</b></div>` : ''}
            ${prov.tipoSuelo ? `<div class="info-item">🪨 ${prov.tipoSuelo}</div>` : ''}
            ${prov.altitud ? `<div class="info-item">⛰️ ${prov.altitud}m</div>` : ''}
            ${prov.pluviometriaAnual ? `<div class="info-item">🌧️ ${prov.pluviometriaAnual}mm/año</div>` : ''}
            ${prov.epocaCritica ? `<div class="info-item">⚠️ ${prov.epocaCritica}</div>` : ''}
            <div class="info-item">🦟 Plagas: ${iconoPlaga} ${plagaNivel}</div>
          </div>
          ${prov.consejosSuelo?.length ? `<ul class="consejos">${prov.consejosSuelo.map(c => `<li>💡 ${c}</li>`).join('')}</ul>` : ''}
        `;
        provinciaInfoPanel.classList.add('show');
      }
    } catch (e) {
      console.error('Error cargando datos provinciales:', e);
    }
  }

  selectProvincia?.addEventListener("change", async () => {
    await cargarDatosProvincia(selectProvincia.value);
    if (selectProvincia.value && selectVariedad.value) {
      await actualizarTipoAlerta();
    }
  });

  selectVariedad?.addEventListener("change", async () => {
    if (selectProvincia.value && selectVariedad.value) {
      await actualizarTipoAlerta();
    }
  });

  const provGuardada = localStorage.getItem("olivaxi_provincia");
  const varGuardada = localStorage.getItem("olivaxi_variedad");

  if (provGuardada && selectProvincia) {
    selectProvincia.value = provGuardada;
  }
  if (varGuardada && selectVariedad) {
    selectVariedad.value = varGuardada;
  }

  if (provGuardada && varGuardada) {
    setTimeout(actualizarTipoAlerta, 100);
  }

  btn?.addEventListener("click", async () => {
    const nombre = document.getElementById("nombre").value.trim();
    const email = document.getElementById("email").value.trim();
    const provincia = document.getElementById("provincia").value;
    const variedad = document.getElementById("variedad").value;
    const tipo = document.getElementById("tipo").value;
    const fenologia = document.getElementById("fenologia").value;

    if (!nombre || !email || !provincia) {
      msg.textContent = "⚠️ Por favor completa los campos obligatorios.";
      msg.className = "warning show";
      msg.removeAttribute("hidden");
      return;
    }

    btn.textContent = "Activando...";
    btn.disabled = true;

    try {
      const apiBase = import.meta.env.PUBLIC_API_URL?.replace(/\/$/, "") || "http://45.90.237.135:3001";
      const res = await fetch(`${apiBase}/api/alertas`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nombre, email, provincia, variedad, tipo, fenologia }),
      });

      if (res.ok) {
        msg.textContent = `✅ ¡Alerta activada! Se te avisará cuando cualquier riesgo aparezca en tu zona para tu cultivo de olivo.`;
        msg.className = "success show";
        localStorage.setItem("olivaxi_provincia", provincia);
        if (variedad) localStorage.setItem("olivaxi_variedad", variedad);
      } else {
        throw new Error("Respuesta no OK");
      }
    } catch {
      msg.textContent = "❌ Algo salió mal. Inténtalo de nuevo.";
      msg.className = "error show";
    } finally {
      msg.removeAttribute("hidden");
      btn.textContent = "Activar alerta 🔔";
      btn.disabled = false;
    }
  });

  // Escuchar cambios de estado desde otras páginas (index, chat)
  window.addEventListener('olivaxi-state-change', (e) => {
    const { provincia, variedad } = e.detail;
    if (provincia && provincia !== selectProvincia.value) {
      selectProvincia.value = provincia;
      actualizarTipoAlerta();
    }
    if (variedad && variedad !== selectVariedad.value) {
      selectVariedad.value = variedad;
    }
  });
</script>
